{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=MedyxHMS;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=true",
    "MedyxHMSConnection": "Server=localhost;Database=MedyxHMS;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=true"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/medyx-hms-.log",
          "rollingInterval": "Day",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "HospitalSettings": {
    "Name": "Medyx Hospital Management System",
    "Version": "1.0.0",
    "DefaultLanguage": "en",
    "SupportedLanguages": ["en", "es", "fr", "ar"],
    "TimeZone": "UTC",
    "Currency": "USD",
    "DateFormat": "yyyy-MM-dd",
    "EnableAuditLogging": true,
    "EnableEmailNotifications": true,
    "EnableSMSNotifications": false,
    "FileUploadPath": "uploads/",
    "MaxFileSizeMB": 10,
    "AllowedFileTypes": [".jpg", ".jpeg", ".png", ".pdf", ".doc", ".docx"]
  },
  "FeatureToggles": {
    "PatientPortal": true,
    "AppointmentSystem": true,
    "BillingModule": true,
    "OPDModule": true,
    "IPDModule": true,
    "PharmacyModule": true,
    "LabModule": true,
    "RadiologyModule": true,
    "HRModule": false,
    "PayrollModule": false,
    "InventoryModule": false,
    "ReportsModule": true,
    "PublicWebsite": false,
    "MobileAPI": false
  },
  "Notification": {
    "Smtp": {
      "Host": "",
      "Port": "587",
      "FromEmail": "",
      "FromName": "Medyx Hospital",
      "Username": "",
      "Password": "",
      "EnableSsl": "true"
    },
    "Sms": {
      "Twilio": {
        "AccountSid": "",
        "AuthToken": "",
        "FromPhone": "",
        "EnableLiveSend": "false"
      }
    }
  },
  "OpenAI": {
    "Enabled": false,
    "BaseUrl": "https://api.openai.com",
    "ApiKey": "",
    "Model": "gpt-4o-mini"
  },
  "Security": {
    "Cors": {
      "AllowedOrigins": [],
      "AllowedMethods": [ "GET", "POST", "OPTIONS" ],
      "AllowedHeaders": [ "Content-Type", "X-Requested-With", "RequestVerificationToken" ],
      "AllowCredentials": false
    }
  },
  "AllowedHosts": "*"
}
