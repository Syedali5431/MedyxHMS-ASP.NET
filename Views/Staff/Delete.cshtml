@model MedyxHMS.ViewModels.StaffDeleteViewModel

@{
    ViewData["Title"] = "Delete Staff Member";
}

<div class="container-fluid">
    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="h3 mb-0 text-gray-800">Delete Staff Member</h1>
                    <p class="text-muted">Confirm deletion of @Model.Staff.FullName</p>
                </div>
                <div>
                    <a href="@Url.Action("Details", "Staff", new { id = Model.Staff.Id })" class="btn btn-info">
                        <i class="fas fa-eye"></i> View Details
                    </a>
                    <a href="@Url.Action("Index", "Staff")" class="btn btn-secondary ml-2">
                        <i class="fas fa-arrow-left"></i> Back to Staff List
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Warning Alert -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <h4 class="alert-heading"><i class="fas fa-exclamation-triangle"></i> Warning: Irreversible Action</h4>
                <p>Deleting a staff member is a permanent action that cannot be undone. All associated data will be permanently removed from the system.</p>
                <hr>
                <p class="mb-0">Consider deactivating the staff member instead if you might need to reactivate them later.</p>
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        </div>
    </div>

    <!-- Staff Information -->
    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow mb-4">
                <div class="card-header py-3 bg-danger text-white">
                    <h6 class="m-0 font-weight-bold">Staff Member to Delete</h6>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="form-label text-muted">Employee ID</label>
                                <p class="h5">@Model.Staff.EmployeeId</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="form-label text-muted">Full Name</label>
                                <p class="h5">@Model.Staff.FullName</p>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="form-label text-muted">Email</label>
                                <p class="h5">@Model.Staff.Email</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="form-label text-muted">Department</label>
                                <p class="h5">
                                    <span class="badge badge-secondary">@Model.Staff.Department</span>
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="form-label text-muted">Designation</label>
                                <p class="h5">@Model.Staff.Designation</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="form-label text-muted">Status</label>
                                <p>
                                    <span class="badge @Model.Staff.StatusBadgeClass">@Model.Staff.StatusText</span>
                                </p>
                            </div>
                        </div>
                    </div>

                    @if (Model.Staff.Roles.Any())
                    {
                        <div class="form-group">
                            <label class="form-label text-muted">Assigned Roles</label>
                            <div class="row">
                                @foreach (var role in Model.Staff.Roles)
                                {
                                    <div class="col-md-4 mb-2">
                                        <span class="badge badge-primary">@role</span>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Impact Assessment -->
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Impact Assessment</h6>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        <h6><i class="fas fa-chart-line"></i> Data Impact</h6>
                        <p>The following data will be permanently removed:</p>
                        <ul>
                            <li><strong>Staff Profile:</strong> All personal and employment information</li>
                            <li><strong>Login Credentials:</strong> User account and authentication data</li>
                            <li><strong>Role Assignments:</strong> All permission and role associations</li>
                            <li><strong>Audit Logs:</strong> Activity history and system logs</li>
                            <li><strong>Related Records:</strong> Any data directly associated with this staff member</li>
                        </ul>
                    </div>

                    <div class="row">
                        <div class="col-md-4">
                            <div class="card border-info">
                                <div class="card-body text-center">
                                    <div class="h3 mb-0 text-info">@Model.PatientsManaged</div>
                                    <small class="text-muted">Patients Managed</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card border-success">
                                <div class="card-body text-center">
                                    <div class="h3 mb-0 text-success">@Model.AppointmentsScheduled</div>
                                    <small class="text-muted">Appointments</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="card border-warning">
                                <div class="card-body text-center">
                                    <div class="h3 mb-0 text-warning">@Model.BillsCreated</div>
                                    <small class="text-muted">Bills Created</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-3">
                        <div class="card border-secondary">
                            <div class="card-body text-center">
                                <div class="h3 mb-0 text-secondary">@Model.RecentActivities</div>
                                <small class="text-muted">Recent Activities (Last 30 days)</small>
                            </div>
                        </div>
                    </div>

                    <small class="text-muted mt-2 d-block">
                        * Statistics shown are estimates and may not reflect all associated data
                    </small>
                </div>
            </div>

            <!-- Data Transfer Option -->
            @if (Model.AvailableStaffForTransfer.Any())
            {
                <div class="card shadow mb-4">
                    <div class="card-header py-3">
                        <h6 class="m-0 font-weight-bold text-primary">Data Transfer (Optional)</h6>
                    </div>
                    <div class="card-body">
                        <div class="alert alert-info">
                            <h6><i class="fas fa-exchange-alt"></i> Transfer Associated Data</h6>
                            <p>If this staff member has associated records (patients, appointments, etc.), you can transfer them to another active staff member before deletion.</p>
                        </div>

                        <form method="post" id="deleteForm">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Staff.Id" />

                            <div class="form-check mb-3">
                                <input class="form-check-input" type="checkbox" id="transferData" name="transferData">
                                <label class="form-check-label" for="transferData">
                                    Transfer associated data to another staff member
                                </label>
                            </div>

                            <div class="form-group" id="transferStaffGroup" style="display: none;">
                                <label for="transferToStaffId" class="form-label">Transfer to Staff Member</label>
                                <select class="form-control" id="transferToStaffId" name="transferToStaffId">
                                    <option value="">Select staff member...</option>
                                    @foreach (var staff in Model.AvailableStaffForTransfer)
                                    {
                                        <option value="@staff.Id">@staff.FullName (@staff.EmployeeId) - @staff.Department</option>
                                    }
                                </select>
                            </div>

                            <div class="form-group mt-4">
                                <button type="submit" class="btn btn-danger btn-lg">
                                    <i class="fas fa-trash"></i> Delete Staff Member
                                </button>
                                <a href="@Url.Action("Details", "Staff", new { id = Model.Staff.Id })" class="btn btn-secondary btn-lg ml-2">
                                    <i class="fas fa-times"></i> Cancel
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            }
            else
            {
                <!-- Simple Delete Form -->
                <div class="card shadow mb-4">
                    <div class="card-body">
                        <form method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Staff.Id" />
                            <input type="hidden" name="transferData" value="false" />

                            <div class="text-center">
                                <p class="lead">Are you sure you want to delete this staff member?</p>
                                <div class="form-group mt-4">
                                    <button type="submit" class="btn btn-danger btn-lg">
                                        <i class="fas fa-trash"></i> Yes, Delete Staff Member
                                    </button>
                                    <a href="@Url.Action("Details", "Staff", new { id = Model.Staff.Id })" class="btn btn-secondary btn-lg ml-2">
                                        <i class="fas fa-times"></i> No, Cancel
                                    </a>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            }
        </div>

        <!-- Sidebar Information -->
        <div class="col-lg-4">
            <!-- Alternatives -->
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Alternatives to Deletion</h6>
                </div>
                <div class="card-body">
                    <div class="alert alert-success">
                        <h6><i class="fas fa-lightbulb"></i> Consider These Options</h6>
                        <p>Instead of deleting, you might want to:</p>
                        <ul class="mb-0">
                            <li><strong>Deactivate:</strong> Temporarily disable login without losing data</li>
                            <li><strong>Change Roles:</strong> Modify permissions instead of removing access</li>
                            <li><strong>Transfer Data:</strong> Move responsibilities to another staff member</li>
                        </ul>
                    </div>

                    <div class="d-grid gap-2">
                        <form method="post" action="@Url.Action("Deactivate", "Staff")" style="display: inline;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Staff.Id" />
                            <button type="submit" class="btn btn-warning btn-block"
                                    onclick="return confirm('Are you sure you want to deactivate this staff member instead?')">
                                <i class="fas fa-user-times"></i> Deactivate Instead
                            </button>
                        </form>

                        <a href="@Url.Action("Edit", "Staff", new { id = Model.Staff.Id })" class="btn btn-primary btn-block">
                            <i class="fas fa-edit"></i> Edit Roles & Permissions
                        </a>
                    </div>
                </div>
            </div>

            <!-- Deletion Checklist -->
            <div class="card shadow mb-4">
                <div class="card-header py-3 bg-danger text-white">
                    <h6 class="m-0 font-weight-bold">Deletion Checklist</h6>
                </div>
                <div class="card-body">
                    <p class="text-muted">Before deleting, ensure:</p>
                    <ul class="list-unstyled">
                        <li><i class="fas fa-check-circle text-success"></i> All patient records are transferred</li>
                        <li><i class="fas fa-check-circle text-success"></i> Appointments are reassigned</li>
                        <li><i class="fas fa-check-circle text-success"></i> Financial records are handled</li>
                        <li><i class="fas fa-check-circle text-success"></i> No pending tasks remain</li>
                        <li><i class="fas fa-check-circle text-success"></i> Backup of important data exists</li>
                    </ul>

                    <div class="alert alert-danger mt-3">
                        <small><strong>Remember:</strong> This action cannot be reversed. Deleted data cannot be recovered.</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Toggle transfer staff selection
            $('#transferData').on('change', function() {
                if ($(this).is(':checked')) {
                    $('#transferStaffGroup').show();
                    $('#transferToStaffId').attr('required', 'required');
                } else {
                    $('#transferStaffGroup').hide();
                    $('#transferToStaffId').removeAttr('required');
                }
            });

            // Form validation
            $('#deleteForm').on('submit', function(e) {
                if ($('#transferData').is(':checked') && !$('#transferToStaffId').val()) {
                    e.preventDefault();
                    alert('Please select a staff member to transfer data to.');
                    $('#transferToStaffId').focus();
                    return false;
                }

                return confirm('Are you absolutely sure you want to delete this staff member? This action cannot be undone.');
            });
        });
    </script>
}