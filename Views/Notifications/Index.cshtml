@using MedyxHMS.Models
@model IEnumerable<SystemNotification>
@{
    ViewData["Title"] = "Notifications";
}

<div class="container-fluid">
    <div class="row mb-3">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <h3><i class="fas fa-bell"></i> Notifications</h3>
            @if (Model.Any())
            {
                <form asp-action="MarkAllRead" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-secondary btn-sm">Mark all as read</button>
                </form>
            }
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">@TempData["SuccessMessage"]<button class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info"><i class="fas fa-info-circle"></i> No notifications.</div>
    }
    else
    {
        <div class="list-group">
            @foreach (var n in Model)
            {
                var rowCss = n.IsRead ? "list-group-item list-group-item-action" : "list-group-item list-group-item-action list-group-item-primary";
                <div class="@rowCss">
                    <div class="d-flex w-100 justify-content-between align-items-start">
                        <div class="flex-grow-1">
                            <div class="fw-semibold">
                                @if (!n.IsRead)
                                {
                                    <span class="badge bg-primary me-1">New</span>
                                }
                                @n.Title
                            </div>
                            <p class="mb-1 text-muted small">@n.Message</p>
                            <small class="text-muted">@n.CreatedAtUtc.ToLocalTime().ToString("MMM dd, yyyy hh:mm tt") — @n.Type</small>
                        </div>
                        <div class="ms-3 d-flex gap-2">
                            @if (!n.IsRead)
                            {
                                <form asp-action="MarkRead" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@n.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-primary" title="Mark as read"><i class="fas fa-check"></i></button>
                                </form>
                            }
                            <form asp-action="Delete" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@n.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this notification?')" title="Delete"><i class="fas fa-trash"></i></button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
