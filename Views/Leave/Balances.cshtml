@model LeaveBalanceViewModel
@{
    ViewData["Title"] = "Leave Balances";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Leave Balances</h2>
        <a class="btn btn-secondary" asp-action="Index">Back to Leave Requests</a>
    </div>

    <div class="card mb-4">
        <div class="card-header"><strong>Filters</strong></div>
        <div class="card-body">
            <form method="get" asp-action="Balances" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">Year</label>
                    <input type="number" class="form-control" name="year" value="@Model.Year" min="2000" max="2100" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Staff</label>
                    <select name="staffId" class="form-select">
                        <option value="">All staff</option>
                        @foreach (var s in Model.StaffOptions)
                        {
                            <option value="@s.Id" selected="@(Model.StaffIdFilter == s.Id)">@s.FirstName @s.LastName (@s.EmployeeId)</option>
                        }
                    </select>
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button class="btn btn-primary w-100" type="submit">Apply</button>
                    <a class="btn btn-outline-secondary w-100" asp-action="Balances">Reset</a>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-body table-responsive">
            <table class="table table-striped table-bordered">
                <thead>
                    <tr>
                        <th>Staff</th>
                        <th>Leave Type</th>
                        <th>Allocated</th>
                        <th>Used</th>
                        <th>Remaining</th>
                        <th>Year</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Balances.Any())
                    {
                        @foreach (var item in Model.Balances)
                        {
                            <tr>
                                <td>@item.Staff?.FirstName @item.Staff?.LastName</td>
                                <td>@item.LeaveType?.Name</td>
                                <td>@item.AllocatedDays</td>
                                <td>@item.UsedDays</td>
                                <td class="@(item.RemainingDays <= 0 ? "text-danger fw-bold" : "")">@item.RemainingDays</td>
                                <td>@item.Year</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted">No leave balances found for selected filters.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
