@model List<dynamic>

@{
    ViewData["Title"] = "Payroll Report";
    var month = ViewData["Month"] as DateTime?;
}

<div class="container-fluid mt-4">
    <div class="card">
        <div class="card-header bg-danger text-white">
            <h4 class="mb-0"><i class="fas fa-money-check-alt me-2"></i>Payroll Report</h4>
        </div>
        <div class="card-body">
            <form method="get" class="row g-2 mb-3">
                <div class="col-md-4">
                    <label class="form-label">Month</label>
                    <input type="month" name="month" class="form-control" value="@month?.ToString("yyyy-MM")" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-danger w-100">Generate</button>
                </div>
            </form>

            <div class="table-responsive">
                <table class="table table-striped table-bordered">
                    <thead class="table-dark">
                        <tr>
                            <th>Staff ID</th>
                            <th>Staff Name</th>
                            <th>Basic Salary</th>
                            <th>Allowances</th>
                            <th>Deductions</th>
                            <th>Net Salary</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var row in Model)
                            {
                                var rowType = ((object)row).GetType();
                                <tr>
                                    <td>@(rowType.GetProperty("StaffId")?.GetValue(row)?.ToString() ?? "-")</td>
                                    <td>@(rowType.GetProperty("StaffName")?.GetValue(row)?.ToString() ?? "-")</td>
                                    <td>@(rowType.GetProperty("BasicSalary")?.GetValue(row)?.ToString() ?? "0")</td>
                                    <td>@(rowType.GetProperty("Allowances")?.GetValue(row)?.ToString() ?? "0")</td>
                                    <td>@(rowType.GetProperty("Deductions")?.GetValue(row)?.ToString() ?? "0")</td>
                                    <td>@(rowType.GetProperty("NetSalary")?.GetValue(row)?.ToString() ?? "0")</td>
                                    <td>@(rowType.GetProperty("Status")?.GetValue(row)?.ToString() ?? "-")</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted">No payroll records found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <a asp-action="Index" class="btn btn-outline-secondary">Back to Reports</a>
        </div>
    </div>
</div>
