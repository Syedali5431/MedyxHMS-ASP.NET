<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MedyxHMS</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MedyxHMS.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/mobile-friendly.css" asp-append-version="true" />
    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <link rel="stylesheet" href="/SystemManagement/ThemeStylesheet" />
    }
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                @if (User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <button id="sidebar-toggle-btn"
                            class="btn btn-sm btn-outline-secondary me-2 d-lg-none"
                            type="button"
                            title="Toggle sidebar"
                            aria-label="Toggle sidebar">
                        <i class="fas fa-bars"></i>
                    </button>
                }
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">MedyxHMS</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                        <li class="nav-item dropdown">
                            <a class="nav-link text-dark dropdown-toggle" href="#" id="reportsDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Reports &amp; Audit
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="reportsDropdown">
                                <li><a class="dropdown-item" asp-area="" asp-controller="Report" asp-action="Index">Reports</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="Report" asp-action="Generate">Generate Report</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="Audit" asp-action="Index">Audit Logs</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="Audit" asp-action="UserActions">User Actions</a></li>
                            </ul>
                        </li>
                        @if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link text-dark dropdown-toggle" href="#" id="cmsDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Website CMS
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="cmsDropdown">
                                    <li><a class="dropdown-item" asp-area="" asp-controller="AccountsApproval" asp-action="Index">Accounts Approval</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="AccountsApproval" asp-action="Passwords">Password Management</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="Cms" asp-action="Index">Pages</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="Cms" asp-action="Notices">Notices</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="Cms" asp-action="Menu">Menu</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="Cms" asp-action="AppointmentRequests">Appointment Requests</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="Cms" asp-action="NotificationSettings">Notification Settings</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="Cms" asp-action="DeliveryLogs">Delivery Logs</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="PublicSiteAdmin" asp-action="Settings">Public Site Settings</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="Site" asp-action="Index" target="_blank">View Public Site</a></li>
                                </ul>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link text-dark dropdown-toggle" href="#" id="chatbotAdminDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Chatbot Admin
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="chatbotAdminDropdown">
                                    <li><a class="dropdown-item" asp-area="" asp-controller="ChatbotAdmin" asp-action="Settings">Settings</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="ChatbotAdmin" asp-action="Analytics">Analytics</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="ChatbotAdmin" asp-action="Escalations">Escalations</a></li>
                                </ul>
                            </li>
                        }
                        @if (User.IsInRole("SuperAdmin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="License" asp-action="Index">License</a>
                            </li>
                        }
                        }
                    </ul>
                    <ul class="navbar-nav ms-auto">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item me-2 d-flex align-items-center">
                                <a class="btn btn-outline-secondary btn-sm position-relative" asp-controller="Notifications" asp-action="Index" title="Notifications">
                                    <i class="fas fa-bell"></i>
                                    <span id="notif-badge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none" style="font-size:0.6rem"></span>
                                </a>
                            </li>
                            <li class="nav-item me-2 d-flex align-items-center text-muted small">
                                Signed in as @User.Identity.Name
                            </li>
                            <li class="nav-item">
                                <form action="/Account/Logout" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger btn-sm">Logout</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-primary btn-sm" asp-controller="Account" asp-action="Login">Login</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <div class="d-flex staff-wrapper">
            <nav id="staff-sidebar" class="staff-sidebar">
                @await Component.InvokeAsync("SidebarNav")
            </nav>
            <div class="staff-main-content">
                <main role="main" class="pb-3 px-3 pt-2">
                    @RenderBody()
                </main>
            </div>
        </div>
        <div id="sidebar-overlay" class="staff-sidebar-overlay"></div>
    }
    else
    {
        <div class="container">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>
    }

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - MedyxHMS - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <a class="chatbot-fab"
       asp-controller="Chatbot"
       asp-action="Index"
       title="Open AI Assistant"
       aria-label="Open AI Assistant">
        AI
    </a>

    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <script>
            (function() {
                function refreshBadge() {
                    fetch('/Notifications/UnreadCount', { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                        .then(function(r) { return r.ok ? r.json() : Promise.reject(); })
                        .then(function(data) {
                            var badge = document.getElementById('notif-badge');
                            if (!badge) return;
                            if (data.count > 0) {
                                badge.textContent = data.count > 99 ? '99+' : data.count;
                                badge.classList.remove('d-none');
                            } else {
                                badge.classList.add('d-none');
                            }
                        })
                        .catch(function() {});
                }
                refreshBadge();
                setInterval(refreshBadge, 60000);
            }());
        </script>
    }
    @await RenderSectionAsync("Scripts", required: false)
    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <script>
            (function () {
                var sidebar = document.getElementById('staff-sidebar');
                var overlay = document.getElementById('sidebar-overlay');
                var toggleBtn = document.getElementById('sidebar-toggle-btn');

                function openSidebar() {
                    if (sidebar) sidebar.classList.add('show');
                    if (overlay) overlay.classList.add('show');
                }

                function closeSidebar() {
                    if (sidebar) sidebar.classList.remove('show');
                    if (overlay) overlay.classList.remove('show');
                }

                if (toggleBtn) {
                    toggleBtn.addEventListener('click', function () {
                        if (sidebar && sidebar.classList.contains('show')) {
                            closeSidebar();
                        } else {
                            openSidebar();
                        }
                    });
                }

                if (overlay) {
                    overlay.addEventListener('click', closeSidebar);
                }
            }());
        </script>
    }
</body>
</html>
