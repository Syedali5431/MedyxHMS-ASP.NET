@model List<dynamic>

@{
    ViewData["Title"] = "Department Report";
    var startDate = ViewData["StartDate"] as DateTime?;
    var endDate = ViewData["EndDate"] as DateTime?;
}

<div class="container-fluid mt-4">
    <div class="card">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0"><i class="fas fa-building me-2"></i>Department Report</h4>
        </div>
        <div class="card-body">
            <form method="get" class="row g-2 mb-3">
                <div class="col-md-5">
                    <label class="form-label">Start Date</label>
                    <input type="date" name="startDate" class="form-control" value="@startDate?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-5">
                    <label class="form-label">End Date</label>
                    <input type="date" name="endDate" class="form-control" value="@endDate?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">Generate</button>
                </div>
            </form>

            <div class="table-responsive">
                <table class="table table-striped table-bordered">
                    <thead class="table-dark">
                        <tr>
                            <th>Staff ID</th>
                            <th>Staff Name</th>
                            <th>Department</th>
                            <th>Attendance Days</th>
                            <th>Approved Leaves</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var row in Model)
                            {
                                var rowType = ((object)row).GetType();
                                <tr>
                                    <td>@(rowType.GetProperty("StaffId")?.GetValue(row)?.ToString() ?? "-")</td>
                                    <td>@(rowType.GetProperty("StaffName")?.GetValue(row)?.ToString() ?? "-")</td>
                                    <td>@(rowType.GetProperty("Department")?.GetValue(row)?.ToString() ?? "-")</td>
                                    <td>@(rowType.GetProperty("AttendanceDays")?.GetValue(row)?.ToString() ?? "0")</td>
                                    <td>@(rowType.GetProperty("ApprovedLeaves")?.GetValue(row)?.ToString() ?? "0")</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted">No data available.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <a asp-action="Index" class="btn btn-outline-secondary">Back to Reports</a>
        </div>
    </div>
</div>
