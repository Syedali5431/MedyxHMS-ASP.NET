@model IEnumerable<MedyxHMS.Models.InventoryTransaction>
@{
    ViewData["Title"] = "Inventory Transactions";
}

<div class="container-fluid mt-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0"><i class="fas fa-exchange-alt text-secondary me-2"></i>Transactions</h4>
        <div class="d-flex gap-2">
            <a asp-action="AddTransaction" class="btn btn-primary btn-sm">
                <i class="fas fa-plus me-1"></i>Add Transaction
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Inventory</a>
        </div>
    </div>

    @if (ViewBag.FilterItem != null)
    {
        <div class="alert alert-info py-2">
            Showing transactions for: <strong>@ViewBag.FilterItem</strong>
            <a asp-action="Transactions" class="ms-2 small">Show all</a>
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Date</th>
                        <th>Item</th>
                        <th>Type</th>
                        <th>Qty</th>
                        <th>Unit Cost</th>
                        <th>Reference</th>
                        <th>Remarks</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in Model)
                    {
                        var typeBadge = t.TransactionType switch
                        {
                            "IN"         => "bg-success",
                            "OUT"        => "bg-danger",
                            _            => "bg-primary"
                        };
                        <tr>
                            <td><small>@t.TransactionDate.ToString("MMM dd, yyyy HH:mm")</small></td>
                            <td>@t.InventoryItem?.Name</td>
                            <td><span class="badge @typeBadge">@t.TransactionType</span></td>
                            <td>@t.Quantity @t.InventoryItem?.Unit</td>
                            <td>@t.UnitCost.ToString("N2")</td>
                            <td><small>@t.ReferenceNumber</small></td>
                            <td><small>@t.Remarks</small></td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="7" class="text-center text-muted py-4">No transactions found.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
