@model MedyxHMS.ViewModels.StaffEditViewModel

@{
    ViewData["Title"] = "Edit Staff Member";
}

<div class="container-fluid">
    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="h3 mb-0 text-gray-800">Edit Staff Member</h1>
                    <p class="text-muted">Update staff member information and roles</p>
                </div>
                <div>
                    <a href="@Url.Action("Details", "Staff", new { id = Model.Staff.Id })" class="btn btn-info">
                        <i class="fas fa-eye"></i> View Details
                    </a>
                    <a href="@Url.Action("Index", "Staff")" class="btn btn-secondary ml-2">
                        <i class="fas fa-arrow-left"></i> Back to Staff List
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Edit Form -->
    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Staff Information</h6>
                </div>
                <div class="card-body">
                    <form method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="Staff.Id" value="@Model.Staff.Id" />

                        <!-- Basic Information -->
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="Staff_EmployeeId" class="form-label">Employee ID <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control @Html.ValidationCssClassFor(m => m.Staff.EmployeeId)"
                                           id="Staff_EmployeeId" name="Staff.EmployeeId" value="@Model.Staff.EmployeeId" required>
                                    @Html.ValidationMessageFor(m => m.Staff.EmployeeId, "", new { @class = "text-danger" })
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="Staff_Email" class="form-label">Email Address <span class="text-danger">*</span></label>
                                    <input type="email" class="form-control @Html.ValidationCssClassFor(m => m.Staff.Email)"
                                           id="Staff_Email" name="Staff.Email" value="@Model.Staff.Email" required>
                                    @Html.ValidationMessageFor(m => m.Staff.Email, "", new { @class = "text-danger" })
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="Staff_FirstName" class="form-label">First Name <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control @Html.ValidationCssClassFor(m => m.Staff.FirstName)"
                                           id="Staff_FirstName" name="Staff.FirstName" value="@Model.Staff.FirstName" required>
                                    @Html.ValidationMessageFor(m => m.Staff.FirstName, "", new { @class = "text-danger" })
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="Staff_LastName" class="form-label">Last Name <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control @Html.ValidationCssClassFor(m => m.Staff.LastName)"
                                           id="Staff_LastName" name="Staff.LastName" value="@Model.Staff.LastName" required>
                                    @Html.ValidationMessageFor(m => m.Staff.LastName, "", new { @class = "text-danger" })
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="Staff_Phone" class="form-label">Phone Number</label>
                                    <input type="tel" class="form-control @Html.ValidationCssClassFor(m => m.Staff.Phone)"
                                           id="Staff_Phone" name="Staff.Phone" value="@Model.Staff.Phone">
                                    @Html.ValidationMessageFor(m => m.Staff.Phone, "", new { @class = "text-danger" })
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="Staff_Department" class="form-label">Department <span class="text-danger">*</span></label>
                                    <select class="form-control @Html.ValidationCssClassFor(m => m.Staff.Department)"
                                            id="Staff_Department" name="Staff.Department" required>
                                        <option value="">Select Department</option>
                                        <option value="Administration" selected="@(Model.Staff.Department == "Administration")">Administration</option>
                                        <option value="Medical" selected="@(Model.Staff.Department == "Medical")">Medical</option>
                                        <option value="Nursing" selected="@(Model.Staff.Department == "Nursing")">Nursing</option>
                                        <option value="Pharmacy" selected="@(Model.Staff.Department == "Pharmacy")">Pharmacy</option>
                                        <option value="Laboratory" selected="@(Model.Staff.Department == "Laboratory")">Laboratory</option>
                                        <option value="Radiology" selected="@(Model.Staff.Department == "Radiology")">Radiology</option>
                                        <option value="IT" selected="@(Model.Staff.Department == "IT")">IT</option>
                                        <option value="Finance" selected="@(Model.Staff.Department == "Finance")">Finance</option>
                                        <option value="HR" selected="@(Model.Staff.Department == "HR")">HR</option>
                                        <option value="Maintenance" selected="@(Model.Staff.Department == "Maintenance")">Maintenance</option>
                                    </select>
                                    @Html.ValidationMessageFor(m => m.Staff.Department, "", new { @class = "text-danger" })
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="Staff_Designation" class="form-label">Designation <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control @Html.ValidationCssClassFor(m => m.Staff.Designation)"
                                           id="Staff_Designation" name="Staff.Designation" value="@Model.Staff.Designation" required>
                                    @Html.ValidationMessageFor(m => m.Staff.Designation, "", new { @class = "text-danger" })
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="Staff_DateOfJoining" class="form-label">Date of Joining <span class="text-danger">*</span></label>
                                    <input type="date" class="form-control @Html.ValidationCssClassFor(m => m.Staff.DateOfJoining)"
                                           id="Staff_DateOfJoining" name="Staff.DateOfJoining"
                                           value="@(Model.Staff.DateOfJoining?.ToString("yyyy-MM-dd"))" required>
                                    @Html.ValidationMessageFor(m => m.Staff.DateOfJoining, "", new { @class = "text-danger" })
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="Staff_Salary" class="form-label">Salary</label>
                                    <div class="input-group">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text">$</span>
                                        </div>
                                        <input type="number" step="0.01" class="form-control @Html.ValidationCssClassFor(m => m.Staff.Salary)"
                                               id="Staff_Salary" name="Staff.Salary" value="@Model.Staff.Salary">
                                        @Html.ValidationMessageFor(m => m.Staff.Salary, "", new { @class = "text-danger" })
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label for="Staff_IsActive" class="form-label">Status</label>
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="Staff_IsActive" name="Staff.IsActive"
                                               value="true" @(Model.Staff.IsActive ? "checked" : "")>
                                        <label class="form-check-label" for="Staff_IsActive">
                                            Active Staff Member
                                        </label>
                                    </div>
                                    <small class="form-text text-muted">Uncheck to deactivate this staff member</small>
                                </div>
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="Staff_Address" class="form-label">Address</label>
                            <textarea class="form-control @Html.ValidationCssClassFor(m => m.Staff.Address)"
                                      id="Staff_Address" name="Staff.Address" rows="3">@Model.Staff.Address</textarea>
                            @Html.ValidationMessageFor(m => m.Staff.Address, "", new { @class = "text-danger" })
                        </div>

                        <!-- Roles Section -->
                        <div class="form-group">
                            <label class="form-label">Roles & Permissions <span class="text-danger">*</span></label>
                            <div class="card border">
                                <div class="card-header bg-light">
                                    <h6 class="mb-0">Assign Roles</h6>
                                </div>
                                <div class="card-body">
                                    <div class="row">
                                        @foreach (var role in Model.AvailableRoles)
                                        {
                                            <div class="col-md-6 mb-3">
                                                <div class="form-check">
                                                    <input class="form-check-input role-checkbox" type="checkbox"
                                                           id="role_@role.Id" name="Staff.SelectedRoleIds" value="@role.Id"
                                                           @(role.IsSelected ? "checked" : "")>
                                                    <label class="form-check-label" for="role_@role.Id">
                                                        <strong>@role.Name</strong>
                                                        @if (!string.IsNullOrEmpty(role.Description))
                                                        {
                                                            <br><small class="text-muted">@role.Description</small>
                                                        }
                                                        @if (role.IsAssigned)
                                                        {
                                                            <br><small class="text-success"><i class="fas fa-check-circle"></i> Currently assigned</small>
                                                        }
                                                    </label>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                    @if (!Model.AvailableRoles.Any())
                                    {
                                        <div class="alert alert-warning">
                                            <i class="fas fa-exclamation-triangle"></i> No roles are available. Please create roles first.
                                        </div>
                                    }
                                </div>
                            </div>
                            @Html.ValidationMessageFor(m => m.Staff.SelectedRoleIds, "", new { @class = "text-danger" })
                        </div>

                        <!-- Current Roles Display -->
                        @if (Model.CurrentRoles.Any())
                        {
                            <div class="form-group">
                                <label class="form-label">Currently Assigned Roles</label>
                                <div class="row">
                                    @foreach (var role in Model.CurrentRoles)
                                    {
                                        <div class="col-md-4 mb-2">
                                            <div class="card border-success">
                                                <div class="card-body p-2">
                                                    <div class="d-flex justify-content-between align-items-center">
                                                        <div>
                                                            <strong class="text-success">@role.RoleName</strong>
                                                            @if (!string.IsNullOrEmpty(role.RoleDescription))
                                                            {
                                                                <br><small class="text-muted">@role.RoleDescription</small>
                                                            }
                                                            <br><small class="text-muted">Assigned: @role.AssignedDate?.ToString("MMM dd, yyyy")</small>
                                                        </div>
                                                        <i class="fas fa-check-circle text-success"></i>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        <!-- Submit Buttons -->
                        <div class="form-group mt-4">
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i> Update Staff Member
                            </button>
                            <a href="@Url.Action("Index", "Staff")" class="btn btn-secondary ml-2">
                                <i class="fas fa-times"></i> Cancel
                            </a>
                            <a href="@Url.Action("ChangePassword", "Staff", new { id = Model.Staff.Id })" class="btn btn-warning ml-2">
                                <i class="fas fa-key"></i> Change Password
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Information Panel -->
        <div class="col-lg-4">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Information</h6>
                </div>
                <div class="card-body">
                    <div class="alert alert-info">
                        <h6><i class="fas fa-info-circle"></i> Edit Guidelines</h6>
                        <ul class="mb-0">
                            <li>Employee ID and Email must be unique</li>
                            <li>Changes to roles take effect immediately</li>
                            <li>Deactivating staff prevents login but keeps data</li>
                            <li>Use "Change Password" for password updates</li>
                        </ul>
                    </div>

                    <div class="alert alert-warning">
                        <h6><i class="fas fa-exclamation-triangle"></i> Important Notes</h6>
                        <ul class="mb-0">
                            <li>Removing roles may affect permissions</li>
                            <li>Staff can be reactivated later</li>
                            <li>All changes are logged for audit</li>
                        </ul>
                    </div>

                    <!-- Quick Stats -->
                    <div class="mt-3">
                        <h6>Staff Summary</h6>
                        <div class="row text-center">
                            <div class="col-6">
                                <div class="border rounded p-2">
                                    <div class="h4 mb-0 text-primary">@Model.CurrentRoles.Count</div>
                                    <small class="text-muted">Roles</small>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="border rounded p-2">
                                    <div class="h4 mb-0 @(Model.Staff.IsActive ? "text-success" : "text-danger")">
                                        @(Model.Staff.IsActive ? "Active" : "Inactive")
                                    </div>
                                    <small class="text-muted">Status</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Role selection validation
            $('form').on('submit', function(e) {
                var selectedRoles = $('input[name="Staff.SelectedRoleIds"]:checked').length;
                if (selectedRoles === 0) {
                    e.preventDefault();
                    alert('Please select at least one role for the staff member.');
                    return false;
                }
            });

            // Highlight role changes
            $('.role-checkbox').on('change', function() {
                var $label = $(this).next('label');
                if ($(this).is(':checked')) {
                    $label.addClass('text-success');
                } else {
                    $label.removeClass('text-success');
                }
            });

            // Initialize existing selections
            $('.role-checkbox:checked').next('label').addClass('text-success');
        });
    </script>
}