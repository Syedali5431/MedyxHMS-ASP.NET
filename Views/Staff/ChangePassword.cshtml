@model MedyxHMS.ViewModels.StaffPasswordChangeViewModel

@{
    ViewData["Title"] = "Change Password";
}

<div class="container-fluid">
    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="h3 mb-0 text-gray-800">Change Password</h1>
                    <p class="text-muted">Update password for @Model.StaffName</p>
                </div>
                <div>
                    <a href="@Url.Action("Details", "Staff", new { id = Model.PasswordChange.StaffId })" class="btn btn-info">
                        <i class="fas fa-eye"></i> View Details
                    </a>
                    <a href="@Url.Action("Index", "Staff")" class="btn btn-secondary ml-2">
                        <i class="fas fa-arrow-left"></i> Back to Staff List
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Password Change Form -->
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Change Staff Password</h6>
                </div>
                <div class="card-body">
                    <!-- Staff Information -->
                    <div class="text-center mb-4">
                        <div class="avatar-circle bg-primary text-white mx-auto mb-3"
                             style="width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 24px;">
                            @Model.StaffName.Split(' ').Select(n => n.FirstOrDefault()).Take(2).ToArray()
                        </div>
                        <h5>@Model.StaffName</h5>
                        <p class="text-muted">@Model.StaffEmail</p>
                    </div>

                    <form method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="PasswordChange.StaffId" value="@Model.PasswordChange.StaffId" />

                        <!-- New Password -->
                        <div class="form-group">
                            <label for="PasswordChange_NewPassword" class="form-label">New Password <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input type="password" class="form-control @Html.ValidationCssClassFor(m => m.PasswordChange.NewPassword)"
                                       id="PasswordChange_NewPassword" name="PasswordChange.NewPassword" required>
                                <div class="input-group-append">
                                    <button class="btn btn-outline-secondary" type="button" id="togglePassword">
                                        <i class="fas fa-eye"></i>
                                    </button>
                                </div>
                            </div>
                            @Html.ValidationMessageFor(m => m.PasswordChange.NewPassword, "", new { @class = "text-danger" })
                            <small class="form-text text-muted">
                                Password must be at least 8 characters long and contain uppercase, lowercase, and numeric characters.
                            </small>
                        </div>

                        <!-- Confirm Password -->
                        <div class="form-group">
                            <label for="confirmPassword" class="form-label">Confirm New Password <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input type="password" class="form-control" id="confirmPassword" name="confirmPassword" required>
                                <div class="input-group-append">
                                    <button class="btn btn-outline-secondary" type="button" id="toggleConfirmPassword">
                                        <i class="fas fa-eye"></i>
                                    </button>
                                </div>
                            </div>
                            <div id="passwordMatchMessage" class="invalid-feedback" style="display: none;">
                                Passwords do not match.
                            </div>
                        </div>

                        <!-- Password Requirements -->
                        <div class="form-group">
                            <label class="form-label">Password Requirements</label>
                            <div class="password-requirements">
                                <div class="requirement" id="req-length">
                                    <i class="fas fa-times text-danger"></i>
                                    <span>At least 8 characters long</span>
                                </div>
                                <div class="requirement" id="req-uppercase">
                                    <i class="fas fa-times text-danger"></i>
                                    <span>Contains uppercase letter</span>
                                </div>
                                <div class="requirement" id="req-lowercase">
                                    <i class="fas fa-times text-danger"></i>
                                    <span>Contains lowercase letter</span>
                                </div>
                                <div class="requirement" id="req-number">
                                    <i class="fas fa-times text-danger"></i>
                                    <span>Contains number</span>
                                </div>
                                <div class="requirement" id="req-match">
                                    <i class="fas fa-times text-danger"></i>
                                    <span>Passwords match</span>
                                </div>
                            </div>
                        </div>

                        <!-- Security Notice -->
                        <div class="alert alert-warning">
                            <h6><i class="fas fa-shield-alt"></i> Security Notice</h6>
                            <ul class="mb-0 small">
                                <li>The staff member will be required to change their password on next login</li>
                                <li>This action will be logged in the audit trail</li>
                                <li>Consider communicating the password change to the staff member</li>
                            </ul>
                        </div>

                        <!-- Submit Buttons -->
                        <div class="form-group text-center mt-4">
                            <button type="submit" class="btn btn-primary btn-lg" id="submitBtn" disabled>
                                <i class="fas fa-save"></i> Change Password
                            </button>
                            <a href="@Url.Action("Details", "Staff", new { id = Model.PasswordChange.StaffId })"
                               class="btn btn-secondary btn-lg ml-2">
                                <i class="fas fa-times"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Password Policy Information -->
            <div class="card shadow mt-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Password Policy</h6>
                </div>
                <div class="card-body">
                    <div class="alert alert-info">
                        <h6><i class="fas fa-info-circle"></i> Hospital Password Requirements</h6>
                        <p class="mb-2">All staff passwords must meet the following criteria:</p>
                        <ul class="mb-0">
                            <li><strong>Minimum Length:</strong> 8 characters</li>
                            <li><strong>Character Requirements:</strong> At least one uppercase letter, one lowercase letter, and one number</li>
                            <li><strong>Expiration:</strong> Passwords expire every 90 days</li>
                            <li><strong>History:</strong> Cannot reuse last 5 passwords</li>
                            <li><strong>Lockout:</strong> Account locks after 5 failed attempts</li>
                        </ul>
                    </div>

                    <div class="alert alert-success">
                        <h6><i class="fas fa-lightbulb"></i> Password Best Practices</h6>
                        <ul class="mb-0">
                            <li>Use a passphrase that's easy to remember but hard to guess</li>
                            <li>Include numbers and special characters when possible</li>
                            <li>Avoid using personal information (birthdays, names, etc.)</li>
                            <li>Don't share passwords with others</li>
                            <li>Change password immediately if you suspect compromise</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            var passwordInput = $('#PasswordChange_NewPassword');
            var confirmPasswordInput = $('#confirmPassword');
            var submitBtn = $('#submitBtn');

            // Toggle password visibility
            $('#togglePassword').on('click', function() {
                var type = passwordInput.attr('type') === 'password' ? 'text' : 'password';
                passwordInput.attr('type', type);
                $(this).find('i').toggleClass('fa-eye fa-eye-slash');
            });

            $('#toggleConfirmPassword').on('click', function() {
                var type = confirmPasswordInput.attr('type') === 'password' ? 'text' : 'password';
                confirmPasswordInput.attr('type', type);
                $(this).find('i').toggleClass('fa-eye fa-eye-slash');
            });

            // Password validation function
            function validatePassword() {
                var password = passwordInput.val();
                var confirmPassword = confirmPasswordInput.val();

                // Length check
                var hasLength = password.length >= 8;
                updateRequirement('req-length', hasLength);

                // Uppercase check
                var hasUppercase = /[A-Z]/.test(password);
                updateRequirement('req-uppercase', hasUppercase);

                // Lowercase check
                var hasLowercase = /[a-z]/.test(password);
                updateRequirement('req-lowercase', hasLowercase);

                // Number check
                var hasNumber = /\d/.test(password);
                updateRequirement('req-number', hasNumber);

                // Match check
                var passwordsMatch = password === confirmPassword && password.length > 0;
                updateRequirement('req-match', passwordsMatch);

                // Show/hide match message
                if (confirmPassword.length > 0) {
                    if (passwordsMatch) {
                        confirmPasswordInput.removeClass('is-invalid');
                        $('#passwordMatchMessage').hide();
                    } else {
                        confirmPasswordInput.addClass('is-invalid');
                        $('#passwordMatchMessage').show();
                    }
                } else {
                    confirmPasswordInput.removeClass('is-invalid');
                    $('#passwordMatchMessage').hide();
                }

                // Enable/disable submit button
                var allValid = hasLength && hasUppercase && hasLowercase && hasNumber && passwordsMatch;
                submitBtn.prop('disabled', !allValid);

                return allValid;
            }

            function updateRequirement(requirementId, isValid) {
                var $req = $('#' + requirementId);
                var $icon = $req.find('i');
                var $span = $req.find('span');

                if (isValid) {
                    $icon.removeClass('fa-times text-danger').addClass('fa-check text-success');
                    $span.removeClass('text-danger').addClass('text-success');
                } else {
                    $icon.removeClass('fa-check text-success').addClass('fa-times text-danger');
                    $span.removeClass('text-success').addClass('text-danger');
                }
            }

            // Bind validation events
            passwordInput.on('input', validatePassword);
            confirmPasswordInput.on('input', validatePassword);

            // Initial validation
            validatePassword();

            // Form submission validation
            $('form').on('submit', function(e) {
                if (!validatePassword()) {
                    e.preventDefault();
                    alert('Please ensure all password requirements are met.');
                    return false;
                }
            });
        });
    </script>
}

<style>
    .password-requirements {
        background-color: #f8f9fc;
        border: 1px solid #e3e6f0;
        border-radius: 0.35rem;
        padding: 1rem;
    }

    .requirement {
        display: flex;
        align-items: center;
        margin-bottom: 0.5rem;
    }

    .requirement i {
        margin-right: 0.5rem;
        width: 16px;
    }

    .requirement span {
        font-size: 0.875rem;
    }

    .avatar-circle {
        font-weight: bold;
    }
</style>