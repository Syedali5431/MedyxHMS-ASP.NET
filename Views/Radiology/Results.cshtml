@model List<RadiologyResult>

@{
    ViewData["Title"] = "Radiology Results";
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2><i class="fas fa-image"></i> Radiology Results</h2>
            <p class="text-muted">View and manage radiology imaging results</p>
        </div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("OrderTest", "Radiology")" class="btn btn-success">
                <i class="fas fa-plus"></i> Order Test
            </a>
            <a href="@Url.Action("Index", "Radiology")" class="btn btn-secondary">
                <i class="fas fa-vial"></i> Test Catalog
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Status Filter</h5>
                </div>
                <div class="card-body">
                    <div class="btn-group" role="group">
                        <a href="@Url.Action("Results", "Radiology", new { status = "All" })" class="btn btn-outline-primary @(ViewBag.CurrentStatus == "All" ? "active" : "")">
                            All (@Model.Count)
                        </a>
                        <a href="@Url.Action("Results", "Radiology", new { status = "Ordered" })" class="btn btn-outline-primary">
                            Ordered
                        </a>
                        <a href="@Url.Action("Results", "Radiology", new { status = "In Progress" })" class="btn btn-outline-primary">
                            In Progress
                        </a>
                        <a href="@Url.Action("Results", "Radiology", new { status = "Completed" })" class="btn btn-outline-primary">
                            Completed
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="fas fa-list"></i> Results List</h5>
        </div>
        <div class="card-body">
            @if (Model.Count > 0)
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Order #</th>
                                <th>Patient</th>
                                <th>Test</th>
                                <th>Order Date</th>
                                <th>Result Date</th>
                                <th>Images</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var result in Model)
                            {
                                <tr>
                                    <td><code>@result.OrderNumber</code></td>
                                    <td><strong>@result.Patient?.FirstName @result.Patient?.LastName</strong></td>
                                    <td>@result.RadiologyTest?.TestName</td>
                                    <td>@result.OrderDate.ToString("MMM dd, yyyy hh:mm tt")</td>
                                    <td>
                                        @if (result.ResultDate.HasValue)
                                        {
                                            @result.ResultDate.Value.ToString("MMM dd, yyyy hh:mm tt")
                                        }
                                        else
                                        {
                                            <span class="text-muted">Pending</span>
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(result.ImagePath))
                                        {
                                            <span class="badge bg-success"><i class="fas fa-image"></i> Yes</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        @switch (result.Status)
                                        {
                                            case "Completed":
                                                <span class="badge bg-success">@result.Status</span>
                                                break;
                                            case "In Progress":
                                                <span class="badge bg-info">@result.Status</span>
                                                break;
                                            case "Ordered":
                                                <span class="badge bg-primary">@result.Status</span>
                                                break;
                                            case "Cancelled":
                                                <span class="badge bg-danger">@result.Status</span>
                                                break;
                                            default:
                                                <span class="badge bg-secondary">@result.Status</span>
                                                break;
                                        }
                                    </td>
                                    <td>
                                        <a href="@Url.Action("ResultDetails", "Radiology", new { id = result.Id })" class="btn btn-sm btn-info">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a href="@Url.Action("EditResult", "Radiology", new { id = result.Id })" class="btn btn-sm btn-warning">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <form method="post" action="@Url.Action("DeleteResult", "Radiology", new { id = result.Id })" style="display:inline;">
                                            <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure?')">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if ((int)ViewBag.TotalPages > 1)
                {
                    <nav aria-label="Page navigation">
                        <ul class="pagination justify-content-center">
                            @for (int i = 1; i <= (int)ViewBag.TotalPages; i++)
                            {
                                <li class="page-item @(i == (int)ViewBag.CurrentPage ? "active" : "")">
                                    <a class="page-link" href="@Url.Action("Results", "Radiology", new { page = i, status = ViewBag.CurrentStatus })">@i</a>
                                </li>
                            }
                        </ul>
                    </nav>
                }
            }
            else
            {
                <div class="alert alert-info">No radiology results found. <a href="@Url.Action("OrderTest", "Radiology")">Order a test</a></div>
            }
        </div>
    </div>
</div>
