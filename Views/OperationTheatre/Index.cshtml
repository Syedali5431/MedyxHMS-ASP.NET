@model IEnumerable<OTSchedule>
@{
    ViewData["Title"] = "Operation Theatre";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Operation Theatre Schedules</h2>
        <a class="btn btn-primary" asp-action="Create">Book OT</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="card">
        <div class="card-body table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Patient</th>
                        <th>Procedure</th>
                        <th>Surgeon</th>
                        <th>OT</th>
                        <th>Duration</th>
                        <th>Status</th>
                        <th>Bill</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.ScheduledDate.ToString("MMM dd, yyyy HH:mm")</td>
                            <td>@item.Patient?.FirstName @item.Patient?.LastName</td>
                            <td>@item.ProcedureName</td>
                            <td>@item.SurgeonName</td>
                            <td>@item.OperationTheatreNumber</td>
                            <td>@item.EstimatedDurationMinutes min</td>
                            <td>@item.Status</td>
                            <td>@(item.BillId.HasValue ? item.BillId.Value.ToString() : "-")</td>
                            <td>
                                <form method="post" asp-action="UpdateStatus" class="d-flex gap-2">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <select class="form-select form-select-sm" name="status">
                                        <option selected="@(item.Status == "Scheduled")">Scheduled</option>
                                        <option selected="@(item.Status == "Completed")">Completed</option>
                                        <option selected="@(item.Status == "Cancelled")">Cancelled</option>
                                    </select>
                                    <button class="btn btn-sm btn-outline-primary" type="submit">Save</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Charts Row -->
    <div class="row mb-4">
        <div class="col-lg-5 mb-4">
            <div class="card shadow">
                <div class="card-header py-3"><h6 class="m-0 font-weight-bold text-primary">OT Schedule Status</h6></div>
                <div class="card-body"><canvas id="otStatusChart" height="260"></canvas></div>
            </div>
        </div>
        <div class="col-lg-7 mb-4">
            <div class="card shadow">
                <div class="card-header py-3"><h6 class="m-0 font-weight-bold text-info">OT Overview</h6></div>
                <div class="card-body"><canvas id="otBarChart" height="260"></canvas></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function() {
            var schedules = @Html.Raw(Json.Serialize(Model.Select(s => new { status = s.Status })));
            var counts = {};
            schedules.forEach(function(s) { counts[s.status] = (counts[s.status] || 0) + 1; });
            new Chart(document.getElementById('otStatusChart'), {
                type: 'doughnut',
                data: { labels: Object.keys(counts).length > 0 ? Object.keys(counts) : ['No Data'], datasets: [{ data: Object.keys(counts).length > 0 ? Object.values(counts) : [1], backgroundColor: ['#f6c23e','#1cc88a','#e74a3b','#858796'], borderWidth: 2 }] },
                options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
            });
            new Chart(document.getElementById('otBarChart'), {
                type: 'bar',
                data: { labels: Object.keys(counts).length > 0 ? Object.keys(counts) : ['No Data'], datasets: [{ label: 'Schedules', data: Object.keys(counts).length > 0 ? Object.values(counts) : [0], backgroundColor: ['#f6c23e','#1cc88a','#e74a3b','#858796'] }] },
                options: { responsive: true, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } } }
            });
        })();
    </script>
}
