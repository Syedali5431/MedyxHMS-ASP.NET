@model CreateOPDVisitViewModel

@{
    ViewData["Title"] = "Create OPD Visit";
}

<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-plus-circle"></i> New OPD Visit
                    </h5>
                </div>
                <div class="card-body">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            <h6 class="alert-heading">Validation Errors:</h6>
                            <ul class="mb-0">
                                @foreach (var modelState in ViewData.ModelState.Values)
                                {
                                    @foreach (var error in modelState.Errors)
                                    {
                                        <li>@error.ErrorMessage</li>
                                    }
                                }
                            </ul>
                        </div>
                    }

                    <form method="post" action="@Url.Action("Create")">
                        @Html.AntiForgeryToken()

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label for="Visit_PatientId" class="form-label">Patient <span class="text-danger">*</span></label>
                                <select name="Visit.PatientId" id="Visit_PatientId" class="form-select" required onchange="getPatientDetails()">
                                    <option value="">-- Select Patient --</option>
                                    @foreach (var patient in Model.Patients)
                                    {
                                        <option value="@patient.Id" @(Model.Visit.PatientId == patient.Id ? "selected" : "")>
                                            @patient.FirstName @patient.LastName
                                        </option>
                                    }
                                </select>
                                <span class="text-danger">@Html.ValidationMessageFor(m => m.Visit.PatientId)</span>
                            </div>

                            <div class="col-md-6">
                                <label for="Visit_DoctorId" class="form-label">Doctor <span class="text-danger">*</span></label>
                                <select name="Visit.DoctorId" id="Visit_DoctorId" class="form-select" required>
                                    <option value="">-- Select Doctor --</option>
                                    @foreach (var doctor in Model.Doctors)
                                    {
                                        <option value="@doctor.Id" @(Model.Visit.DoctorId == doctor.Id ? "selected" : "")>
                                            Dr. @doctor.FirstName @doctor.LastName
                                        </option>
                                    }
                                </select>
                                <span class="text-danger">@Html.ValidationMessageFor(m => m.Visit.DoctorId)</span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label for="Visit_VisitDate" class="form-label">Visit Date <span class="text-danger">*</span></label>
                                <input type="datetime-local" name="Visit.VisitDate" id="Visit_VisitDate" class="form-control" 
                                       value="@Model.Visit.VisitDate.ToString("yyyy-MM-ddTHH:mm")" required>
                                <span class="text-danger">@Html.ValidationMessageFor(m => m.Visit.VisitDate)</span>
                            </div>

                            <div class="col-md-6">
                                <label for="Visit_ConsultationFee" class="form-label">Consultation Fee <span class="text-danger">*</span></label>
                                <input type="number" name="Visit.ConsultationFee" id="Visit_ConsultationFee" class="form-control" 
                                       step="0.01" value="@Model.Visit.ConsultationFee" required>
                                <span class="text-danger">@Html.ValidationMessageFor(m => m.Visit.ConsultationFee)</span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="Visit_Symptoms" class="form-label">Symptoms <span class="text-danger">*</span></label>
                            <textarea name="Visit.Symptoms" id="Visit_Symptoms" class="form-control" rows="3" required>@Model.Visit.Symptoms</textarea>
                            <span class="text-danger">@Html.ValidationMessageFor(m => m.Visit.Symptoms)</span>
                        </div>

                        <div class="mb-3">
                            <label for="Visit_Diagnosis" class="form-label">Diagnosis</label>
                            <textarea name="Visit.Diagnosis" id="Visit_Diagnosis" class="form-control" rows="3">@Model.Visit.Diagnosis</textarea>
                            <span class="text-danger">@Html.ValidationMessageFor(m => m.Visit.Diagnosis)</span>
                        </div>

                        <div class="mb-3">
                            <label for="Visit_Treatment" class="form-label">Treatment</label>
                            <textarea name="Visit.Treatment" id="Visit_Treatment" class="form-control" rows="3">@Model.Visit.Treatment</textarea>
                            <span class="text-danger">@Html.ValidationMessageFor(m => m.Visit.Treatment)</span>
                        </div>

                        <div class="mb-3">
                            <label for="Visit_Prescription" class="form-label">Prescription</label>
                            <textarea name="Visit.Prescription" id="Visit_Prescription" class="form-control" rows="3">@Model.Visit.Prescription</textarea>
                            <span class="text-danger">@Html.ValidationMessageFor(m => m.Visit.Prescription)</span>
                        </div>

                        <div class="mb-3">
                            <label for="Visit_Notes" class="form-label">Notes</label>
                            <textarea name="Visit.Notes" id="Visit_Notes" class="form-control" rows="2">@Model.Visit.Notes</textarea>
                            <span class="text-danger">@Html.ValidationMessageFor(m => m.Visit.Notes)</span>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label for="Visit_PaymentStatus" class="form-label">Payment Status <span class="text-danger">*</span></label>
                                <select name="Visit.PaymentStatus" id="Visit_PaymentStatus" class="form-select" required>
                                    <option value="Pending" @(Model.Visit.PaymentStatus == "Pending" ? "selected" : "")>Pending</option>
                                    <option value="Paid" @(Model.Visit.PaymentStatus == "Paid" ? "selected" : "")>Paid</option>
                                    <option value="Waived" @(Model.Visit.PaymentStatus == "Waived" ? "selected" : "")>Waived</option>
                                </select>
                                <span class="text-danger">@Html.ValidationMessageFor(m => m.Visit.PaymentStatus)</span>
                            </div>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a href="@Url.Action("Index")" class="btn btn-secondary">
                                <i class="fas fa-times"></i> Cancel
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save"></i> Create Visit
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
function getPatientDetails() {
    var patientId = document.getElementById('Visit_PatientId').value;
    if (!patientId) return;

    fetch(`/OPD/GetPatientDetails?patientId=${patientId}`)
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                console.log('Patient details loaded:', data.patient);
            }
        });
}
</script>
