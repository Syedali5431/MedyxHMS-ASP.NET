@model MedyxHMS.ViewModels.PatientDeleteViewModel

@{
    ViewData["Title"] = "Delete Patient";
}

<div class="container-fluid">
    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="h3 mb-0 text-gray-800">Delete Patient</h1>
                    <p class="text-muted">Confirm deletion of patient record</p>
                </div>
                <div>
                    <a href="@Url.Action("Details", "Patient", new { id = Model.Patient.Id })" class="btn btn-info">
                        <i class="fas fa-eye"></i> View Details
                    </a>
                    <a href="@Url.Action("Index", "Patient")" class="btn btn-secondary ml-2">
                        <i class="fas fa-arrow-left"></i> Back to Patients
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Warning Alert -->
    @if (!string.IsNullOrEmpty(Model.WarningMessage))
    {
        <div class="row mb-4">
            <div class="col-12">
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="fas fa-exclamation-triangle fa-lg mr-2"></i>
                    <strong>Warning!</strong> @Model.WarningMessage
                    <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
            </div>
        </div>
    }

    <!-- Patient Information -->
    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow mb-4 border-left-danger">
                <div class="card-header py-3 bg-danger text-white">
                    <h6 class="m-0 font-weight-bold">
                        <i class="fas fa-trash"></i> Confirm Patient Deletion
                    </h6>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        <h6><i class="fas fa-exclamation-triangle"></i> This action cannot be undone!</h6>
                        <p class="mb-0">Deleting this patient will mark them as inactive. All historical data will be preserved, but the patient will no longer appear in active searches or reports.</p>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <h5 class="text-primary">Patient Information</h5>
                            <table class="table table-borderless">
                                <tr>
                                    <td><strong>Name:</strong></td>
                                    <td>@Model.Patient.FullName</td>
                                </tr>
                                <tr>
                                    <td><strong>Patient ID:</strong></td>
                                    <td><code>@Model.Patient.PatientId</code></td>
                                </tr>
                                <tr>
                                    <td><strong>Age:</strong></td>
                                    <td>@Model.Patient.Age years</td>
                                </tr>
                                <tr>
                                    <td><strong>Gender:</strong></td>
                                    <td>@Model.Patient.Gender</td>
                                </tr>
                                <tr>
                                    <td><strong>Email:</strong></td>
                                    <td>@Model.Patient.Email</td>
                                </tr>
                                <tr>
                                    <td><strong>Phone:</strong></td>
                                    <td>@Model.Patient.Phone</td>
                                </tr>
                            </table>
                        </div>
                        <div class="col-md-6">
                            <h5 class="text-info">Related Records</h5>
                            <div class="mb-3">
                                <i class="fas fa-calendar-check text-primary mr-2"></i>
                                <strong>Appointments:</strong>
                                @if (Model.HasActiveAppointments)
                                {
                                    <span class="badge badge-warning">Has Active Appointments</span>
                                }
                                else
                                {
                                    <span class="text-muted">No active appointments</span>
                                }
                            </div>
                            <div class="mb-3">
                                <i class="fas fa-file-invoice-dollar text-success mr-2"></i>
                                <strong>Unpaid Bills:</strong>
                                @if (Model.HasUnpaidBills)
                                {
                                    <span class="badge badge-danger">Has Unpaid Bills</span>
                                }
                                else
                                {
                                    <span class="text-muted">No unpaid bills</span>
                                }
                            </div>

                            @if (Model.HasActiveAppointments || Model.HasUnpaidBills)
                            {
                                <div class="alert alert-info mt-3">
                                    <small>
                                        <strong>Note:</strong> Related records will remain in the system for audit and historical purposes.
                                        The patient will be marked as inactive and won't appear in regular searches.
                                    </small>
                                </div>
                            }
                        </div>
                    </div>

                    <hr>

                    <!-- Deletion Form -->
                    <form asp-action="Delete" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Patient.Id" />

                        <div class="form-group">
                            <div class="custom-control custom-checkbox">
                                <input type="checkbox" class="custom-control-input" id="confirmDelete" required>
                                <label class="custom-control-label" for="confirmDelete">
                                    I understand that this action will mark the patient as inactive and cannot be easily reversed.
                                </label>
                            </div>
                        </div>

                        <div class="form-group mt-4">
                            <button type="submit" class="btn btn-danger" id="deleteBtn" disabled>
                                <i class="fas fa-trash"></i> Delete Patient
                            </button>
                            <a href="@Url.Action("Details", "Patient", new { id = Model.Patient.Id })" class="btn btn-secondary ml-2">
                                <i class="fas fa-times"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Information Panel -->
        <div class="col-lg-4">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-info">What Happens When You Delete?</h6>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled">
                        <li class="mb-2">
                            <i class="fas fa-check-circle text-success mr-2"></i>
                            Patient is marked as inactive (soft delete)
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-check-circle text-success mr-2"></i>
                            All historical data is preserved
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-check-circle text-success mr-2"></i>
                            Patient won't appear in active searches
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-check-circle text-success mr-2"></i>
                            Audit trail records the deletion
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-check-circle text-success mr-2"></i>
                            Can be reactivated by admin if needed
                        </li>
                    </ul>

                    <hr>

                    <div class="alert alert-info">
                        <h6><i class="fas fa-info-circle"></i> Need to Reactivate?</h6>
                        <p class="mb-0 small">Contact your system administrator to reactivate a deleted patient account.</p>
                    </div>
                </div>
            </div>

            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-warning">Alternatives to Deletion</h6>
                </div>
                <div class="card-body">
                    <p class="small">Instead of deleting, consider:</p>
                    <ul class="small">
                        <li>Edit patient information</li>
                        <li>Mark as inactive in the edit form</li>
                        <li>Update contact information</li>
                        <li>Add notes to medical history</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Enable/disable delete button based on checkbox
            $('#confirmDelete').change(function() {
                $('#deleteBtn').prop('disabled', !$(this).is(':checked'));
            });

            // Add confirmation dialog
            $('#deleteBtn').click(function(e) {
                if (!confirm('Are you absolutely sure you want to delete this patient? This action cannot be easily undone.')) {
                    e.preventDefault();
                    return false;
                }
            });
        });
    </script>
}