@model AuditLogIndexViewModel
@{
    ViewData["Title"] = "Audit Logs";
    var entityTypes = ViewData["EntityTypes"] as List<string> ?? new List<string>();
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2>Audit Logs</h2>
            <p class="text-muted mb-0">Track user and entity changes across the system</p>
        </div>
        <a class="btn btn-sm btn-outline-success me-1" asp-action="Index" asp-route-export="csv"><i class="fas fa-file-csv me-1"></i>CSV</a>
    </div>

    <div class="card mb-4">
        <div class="card-header"><strong>Filters</strong></div>
        <div class="card-body">
            <form method="get" asp-action="Index" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">Start Date</label>
                    <input type="date" name="startDate" class="form-control" value="@Model.StartDate?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">End Date</label>
                    <input type="date" name="endDate" class="form-control" value="@Model.EndDate?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Entity</label>
                    <select name="entityType" class="form-select">
                        <option value="">All entities</option>
                        @foreach (var entity in entityTypes)
                        {
                            <option value="@entity" selected="@(Model.EntityType == entity)">@entity</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">User Id</label>
                    <input type="text" name="userId" class="form-control" placeholder="Optional" />
                </div>
                <div class="col-md-2 d-flex gap-2">
                    <button class="btn btn-primary w-100" type="submit">Apply</button>
                    <a class="btn btn-outline-secondary w-100" asp-action="Index">Reset</a>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-header d-flex justify-content-between">
            <strong>Results</strong>
            <span class="badge bg-secondary">@Model.TotalLogs log(s)</span>
        </div>
        <div class="card-body table-responsive">
            <table class="table table-striped table-bordered align-middle">
                <thead>
                    <tr>
                        <th>Time (UTC)</th>
                        <th>User</th>
                        <th>Action</th>
                        <th>Entity</th>
                        <th>Entity Id</th>
                        <th>IP</th>
                        <th>Details</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.AuditLogs != null && Model.AuditLogs.Any())
                    {
                        @foreach (var log in Model.AuditLogs)
                        {
                            var badgeClass = log.Action.Contains("FAILED") ? "bg-danger" :
                                             log.Action.Contains("SUCCESS") || log.Action.Contains("ENABLED") ? "bg-success" :
                                             log.Action.Contains("LOGIN") ? "bg-primary" :
                                             "bg-secondary";
                            <tr class="@(log.Action.Contains("FAILED") ? "table-danger" : "")">"
                                <td>@log.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                <td>@(string.IsNullOrWhiteSpace(log.UserId) ? "System" : log.UserId)</td>
                                <td><span class="badge @badgeClass">@log.Action</span></td>
                                <td>@log.EntityName</td>
                                <td>@log.EntityId</td>
                                <td>@log.IpAddress</td>
                                <td>
                                    <a asp-action="Details" asp-route-id="@log.Id" class="btn btn-sm btn-outline-primary">View</a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted">No audit logs found for selected filters.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
