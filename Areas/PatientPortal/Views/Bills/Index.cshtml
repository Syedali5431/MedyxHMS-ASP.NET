@{
    ViewData["Title"] = "Bills & Payments";
    Layout = "~/Views/PatientPortal/Shared/_Layout.cshtml";
}

@model PatientPortalBillsViewModel

<div class="bills-header mb-4">
    <div class="row align-items-center">
        <div class="col-md-8">
            <h1 class="page-title">
                <i class="fas fa-file-invoice-dollar text-primary"></i> Bills & Payments
            </h1>
            <p class="text-muted">Manage your billing information and payments</p>
        </div>
        <div class="col-md-4 text-md-end">
            <a href="@Url.Action("Export", "Bills", new { area = "PatientPortal", format = "csv", filter = Model.Filter })" class="btn btn-outline-primary btn-sm">
                <i class="fas fa-file-csv"></i> Export CSV
            </a>
            <a href="@Url.Action("Export", "Bills", new { area = "PatientPortal", format = "pdf", filter = Model.Filter })" class="btn btn-outline-danger btn-sm">
                <i class="fas fa-file-pdf"></i> Export PDF
            </a>
        </div>
    </div>
</div>

<!-- Filter Options -->
<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row align-items-end">
            <div class="col-md-4">
                <label class="form-label">Filter By Status</label>
                <select name="filter" class="form-select">
                    <option value="all" selected="@(Model.Filter == "all")">All Bills</option>
                    <option value="pending" selected="@(Model.Filter == "pending")">Pending</option>
                    <option value="paid" selected="@(Model.Filter == "paid")">Paid</option>
                    <option value="overdue" selected="@(Model.Filter == "overdue")">Overdue</option>
                </select>
            </div>
            <div class="col-md-4">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="fas fa-search"></i> Filter
                </button>
            </div>
        </form>
    </div>
</div>

@if (Model.Bills != null && Model.Bills.Any())
{
    <div class="row mb-4">
        <!-- Bills Table -->
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Recent Bills</h5>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Bill #</th>
                                <th>Date</th>
                                <th>Total Amount</th>
                                <th>Paid Amount</th>
                                <th>Due Date</th>
                                <th>Status</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var bill in Model.Bills)
                            {
                                <tr>
                                    <td><strong>@bill.BillNumber</strong></td>
                                    <td>@bill.BillDate?.ToString("MMM dd, yyyy")</td>
                                    <td>₹@bill.TotalAmount?.ToString("N2")</td>
                                    <td>₹@bill.PaidAmount?.ToString("N2")</td>
                                    <td>@bill.DueDate?.ToString("MMM dd, yyyy")</td>
                                    <td>
                                        @if (bill.Status == "Paid")
                                        {
                                            <span class="badge bg-success">
                                                <i class="fas fa-check-circle"></i> Paid
                                            </span>
                                        }
                                        else if (bill.Status == "Pending")
                                        {
                                            <span class="badge bg-warning">
                                                <i class="fas fa-clock"></i> Pending
                                            </span>
                                        }
                                        else if (bill.Status == "Overdue")
                                        {
                                            <span class="badge bg-danger">
                                                <i class="fas fa-exclamation-circle"></i> Overdue
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a href="@Url.Action("Details", "Bills", new { id = bill.Id })" class="btn btn-outline-primary" title="View Details">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            @if (bill.Status != "Paid")
                                            {
                                                <a href="@Url.Action("Pay", "Bills", new { id = bill.Id })" class="btn btn-outline-success" title="Pay Bill">
                                                    <i class="fas fa-credit-card"></i>
                                                </a>
                                            }
                                            <a href="@Url.Action("Download", "Bills", new { id = bill.Id })" class="btn btn-outline-secondary" title="Download">
                                                <i class="fas fa-download"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Pagination -->
            @if (Model.TotalPages > 1)
            {
                <nav aria-label="Page navigation" class="mt-4">
                    <ul class="pagination justify-content-center">
                        @if (Model.HasPreviousPage)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@Url.Action("Index", new { page = Model.CurrentPage - 1, filter = Model.Filter })">Previous</a>
                            </li>
                        }
                        else
                        {
                            <li class="page-item disabled">
                                <span class="page-link">Previous</span>
                            </li>
                        }

                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            if (i == Model.CurrentPage)
                            {
                                <li class="page-item active">
                                    <span class="page-link">@i</span>
                                </li>
                            }
                            else
                            {
                                <li class="page-item">
                                    <a class="page-link" href="@Url.Action("Index", new { page = i, filter = Model.Filter })">@i</a>
                                </li>
                            }
                        }

                        @if (Model.HasNextPage)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@Url.Action("Index", new { page = Model.CurrentPage + 1, filter = Model.Filter })">Next</a>
                            </li>
                        }
                        else
                        {
                            <li class="page-item disabled">
                                <span class="page-link">Next</span>
                            </li>
                        }
                    </ul>
                </nav>
            }
        </div>

        <!-- Billing Summary Sidebar -->
        <div class="col-lg-4">
            <div class="card sticky-top" style="top: 20px;">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">
                        <i class="fas fa-summary"></i> Billing Summary
                    </h5>
                </div>
                <div class="card-body">
                    <div class="billing-summary-item mb-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-muted">Total Bills:</span>
                            <strong class="text-dark">₹@Model.Bills.Sum(b => b.TotalAmount)?.ToString("N2")</strong>
                        </div>
                    </div>

                    <div class="billing-summary-item mb-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-muted">Total Paid:</span>
                            <strong class="text-success">₹@Model.Bills.Sum(b => b.PaidAmount)?.ToString("N2")</strong>
                        </div>
                    </div>

                    <div class="billing-summary-item mb-3 p-3 bg-light rounded">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-muted"><strong>Outstanding:</strong></span>
                            <strong class="text-danger fs-5">₹@Model.Bills.Where(b => b.Status != "Paid").Sum(b => b.TotalAmount - b.PaidAmount)?.ToString("N2")</strong>
                        </div>
                    </div>

                    <div class="d-grid gap-2">
                        <a href="@Url.Action("Pay", "Bills")" class="btn btn-success">
                            <i class="fas fa-credit-card"></i> Pay Outstanding Balance
                        </a>
                    </div>

                    <hr>

                    <h6 class="mb-3">Quick Info</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-2">
                            <i class="fas fa-info-circle text-info"></i>
                            Payments are processed immediately
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-info-circle text-info"></i>
                            You'll receive an email receipt
                        </li>
                        <li>
                            <i class="fas fa-info-circle text-info"></i>
                            View payment history anytime
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="alert alert-info text-center py-5">
        <i class="fas fa-file-invoice-dollar fa-3x mb-3"></i>
        <h4>No Bills Found</h4>
        <p>You don't have any bills in your account.</p>
    </div>
}

@section Styles {
    <style>
        .page-title {
            font-weight: 600;
            color: #333;
        }

        .billing-summary-item {
            border-bottom: 1px solid #e0e0e0;
        }

        .table-hover tbody tr:hover {
            background-color: #f8f9fa;
        }

        .badge {
            padding: 0.5em 0.75em;
            font-size: 0.875rem;
        }
    </style>
}