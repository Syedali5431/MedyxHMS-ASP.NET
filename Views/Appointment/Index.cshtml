@model MedyxHMS.ViewModels.AppointmentIndexViewModel

@{
    ViewData["Title"] = "Appointment Management";
}

<div class="container-fluid">
    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="h3 mb-0 text-gray-800">Appointment Management</h1>
                    <p class="text-muted">Manage patient appointments and schedules</p>
                </div>
                <div>
                    @if (User.HasPermission("Appointment", "Add"))
                    {
                        <a href="@Url.Action("Create", "Appointment")" class="btn btn-primary">
                            <i class="fas fa-plus"></i> Schedule Appointment
                        </a>
                    }
                    <a href="@Url.Action("Calendar", "Appointment")" class="btn btn-info ml-2">
                        <i class="fas fa-calendar"></i> Calendar View
                    </a>
                    <a href="@Url.Action("Dashboard", "Appointment")" class="btn btn-secondary ml-2">
                        <i class="fas fa-chart-bar"></i> Dashboard
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="row mb-4">
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-primary shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                                Total Appointments
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.TotalAppointments</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-calendar-check fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-info shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-info text-uppercase mb-1">
                                Today's Appointments
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.TodayAppointments</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-clock fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-success shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                                Upcoming
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.UpcomingAppointments</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-calendar-plus fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-primary shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                                Completed
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.CompletedAppointments</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-check-circle fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Appointment Charts -->
    <div class="row mb-4">
        <div class="col-xl-5 col-lg-5 mb-4">
            <div class="card shadow">
                <div class="card-header py-3"><h6 class="m-0 font-weight-bold text-primary"><i class="fas fa-chart-pie me-2"></i>Appointments by Status</h6></div>
                <div class="card-body"><canvas id="apptStatusChart" height="200"></canvas></div>
            </div>
        </div>
        <div class="col-xl-7 col-lg-7 mb-4">
            <div class="card shadow">
                <div class="card-header py-3"><h6 class="m-0 font-weight-bold text-primary"><i class="fas fa-chart-bar me-2"></i>Appointment Overview</h6></div>
                <div class="card-body"><canvas id="apptOverviewChart" height="120"></canvas></div>
            </div>
        </div>
    </div>

    <!-- Filters and Search -->
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <form method="get" class="row align-items-end">
                <div class="col-md-3">
                    <label class="form-label">Search</label>
                    <input type="text" name="searchTerm" value="@Model.SearchTerm"
                           class="form-control" placeholder="Patient name, ID, or doctor...">
                </div>
                <div class="col-md-2">
                    <label class="form-label">Status</label>
                    <select name="statusFilter" class="form-control">
                        @foreach (var status in Model.StatusOptions)
                        {
                            <option value="@status" selected="@(Model.StatusFilter == status)">@status</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Date</label>
                    <input type="date" name="dateFilter" value="@Model.DateFilter?.ToString("yyyy-MM-dd")"
                           class="form-control">
                </div>
                <div class="col-md-3">
                    <label class="form-label">Doctor</label>
                    <select name="doctorFilter" class="form-control">
                        <option value="">All Doctors</option>
                        @foreach (var doctor in Model.AvailableDoctors)
                        {
                            <option value="@doctor.Id" selected="@(Model.DoctorFilter == doctor.Id)">@doctor.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-search"></i> Filter
                    </button>
                    @if (!string.IsNullOrEmpty(Model.SearchTerm) || !string.IsNullOrEmpty(Model.StatusFilter) ||
                         Model.DateFilter.HasValue || Model.DoctorFilter.HasValue)
                    {
                        <a href="@Url.Action("Index", "Appointment")" class="btn btn-outline-secondary w-100 mt-1">
                            <i class="fas fa-times"></i> Clear
                        </a>
                    }
                </div>
                <div class="col-12 text-end mt-2">
                    <a href="@Url.Action("Export", "Appointment", new { format = "csv", searchTerm = Model.SearchTerm, statusFilter = Model.StatusFilter, dateFilter = Model.DateFilter?.ToString("yyyy-MM-dd"), doctorFilter = Model.DoctorFilter })" class="btn btn-outline-primary btn-sm">
                        <i class="fas fa-file-csv"></i> Export CSV
                    </a>
                    <a href="@Url.Action("Export", "Appointment", new { format = "pdf", searchTerm = Model.SearchTerm, statusFilter = Model.StatusFilter, dateFilter = Model.DateFilter?.ToString("yyyy-MM-dd"), doctorFilter = Model.DoctorFilter })" class="btn btn-outline-danger btn-sm ml-2">
                        <i class="fas fa-file-pdf"></i> Export PDF
                    </a>
                </div>
            </form>
        </div>

        <div class="card-body">
            @if (!Model.Appointments.Any())
            {
                <div class="text-center py-5">
                    <i class="fas fa-calendar-times fa-3x text-gray-300 mb-3"></i>
                    <h5 class="text-gray-500">No appointments found</h5>
                    @if (!string.IsNullOrEmpty(Model.SearchTerm) || !string.IsNullOrEmpty(Model.StatusFilter) ||
                         Model.DateFilter.HasValue || Model.DoctorFilter.HasValue)
                    {
                        <p class="text-muted">Try adjusting your search criteria or <a href="@Url.Action("Index", "Appointment")">clear all filters</a>.</p>
                    }
                    else
                    {
                        <p class="text-muted">Start by <a href="@Url.Action("Create", "Appointment")">scheduling your first appointment</a>.</p>
                    }
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-bordered" id="dataTable" width="100%" cellspacing="0">
                        <thead>
                            <tr>
                                <th>Patient</th>
                                <th>Doctor</th>
                                <th>Date & Time</th>
                                <th>Type</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var appointment in Model.Appointments)
                            {
                                <tr>
                                    <td>
                                        <strong>@appointment.PatientName</strong>
                                        <br><small class="text-muted">@appointment.PatientIdDisplay</small>
                                    </td>
                                    <td>
                                        <strong>@appointment.DoctorName</strong>
                                    </td>
                                    <td>
                                        <span class="badge badge-light">@appointment.FormattedDateTime</span>
                                        @if (appointment.AppointmentDate.Date == DateTime.Today)
                                        {
                                            <br><small class="text-success font-weight-bold">Today</small>
                                        }
                                        else if (appointment.AppointmentDate.Date == DateTime.Today.AddDays(1))
                                        {
                                            <br><small class="text-warning">Tomorrow</small>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge badge-secondary">@appointment.AppointmentType</span>
                                    </td>
                                    <td>
                                        <span class="badge @appointment.StatusBadgeClass">@appointment.Status</span>
                                    </td>
                                    <td>
                                        <div class="btn-group" role="group">
                                            @if (User.HasPermission("Appointment", "View"))
                                            {
                                                <a href="@Url.Action("Details", "Appointment", new { id = appointment.Id })"
                                                   class="btn btn-sm btn-info" title="View Details">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                            }
                                            @if (User.HasPermission("Appointment", "Edit"))
                                            {
                                                <a href="@Url.Action("UpdateStatus", "Appointment", new { id = appointment.Id })"
                                                   class="btn btn-sm btn-warning" title="Update Status">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <a href="@Url.Action("Edit", "Appointment", new { id = appointment.Id })"
                                                   class="btn btn-sm btn-secondary" title="Edit Appointment">
                                                    <i class="fas fa-pencil-alt"></i>
                                                </a>
                                            }
                                            @if (User.HasPermission("Appointment", "Delete"))
                                            {
                                                <button type="button" class="btn btn-sm btn-danger" title="Delete Appointment"
                                                        onclick="confirmDelete(@appointment.Id, '@appointment.PatientName', '@appointment.FormattedDateTime')">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" role="dialog" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteModalLabel">Confirm Delete</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to delete this appointment?</p>
                <div id="appointmentDetails"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                <form id="deleteForm" method="post" style="display: inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">Delete Appointment</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Appointment Charts
        new Chart(document.getElementById('apptStatusChart'), {
            type: 'doughnut',
            data: {
                labels: ['Today', 'Upcoming', 'Completed', 'Other'],
                datasets: [{ data: [@Model.TodayAppointments, @Model.UpcomingAppointments, @Model.CompletedAppointments, Math.max(0,@Model.TotalAppointments-@Model.TodayAppointments-@Model.UpcomingAppointments-@Model.CompletedAppointments)], backgroundColor: ['#f6c23e','#36b9cc','#1cc88a','#858796'], borderWidth: 2 }]
            },
            options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
        });
        new Chart(document.getElementById('apptOverviewChart'), {
            type: 'bar',
            data: {
                labels: ['Total', "Today's", 'Upcoming', 'Completed'],
                datasets: [{ label: 'Count', data: [@Model.TotalAppointments, @Model.TodayAppointments, @Model.UpcomingAppointments, @Model.CompletedAppointments], backgroundColor: ['#4e73df','#f6c23e','#36b9cc','#1cc88a'] }]
            },
            options: { responsive: true, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } } }
        });

        $(document).ready(function() {
            // Initialize DataTable only when plugin is available.
            if ($.fn && $.fn.DataTable) {
                $('#dataTable').DataTable({
                    "pageLength": 25,
                    "order": [[ 2, "asc" ]] // Sort by date/time ascending
                });
            }
        });

        function confirmDelete(appointmentId, patientName, appointmentDateTime) {
            $('#appointmentDetails').html(`
                <div class="alert alert-warning">
                    <strong>Patient:</strong> ${patientName}<br>
                    <strong>Date & Time:</strong> ${appointmentDateTime}
                </div>
                <p class="text-danger"><strong>Warning:</strong> This action cannot be undone!</p>
            `);
            $('#deleteForm').attr('action', '@Url.Action("Delete", "Appointment")/' + appointmentId);
            $('#deleteModal').modal('show');
        }
    </script>
}