@model OTSchedule
@{
    ViewData["Title"] = "Book OT";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Book Operation Theatre</h2>
        <a class="btn btn-secondary" asp-action="Index">Back</a>
    </div>

    <div class="card">
        <div class="card-body">
            <form method="post" asp-action="Create">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Patient</label>
                        <select asp-for="PatientId" class="form-select" required>
                            <option value="">Select patient</option>
                            @foreach (var p in (IEnumerable<Patient>)ViewBag.Patients)
                            {
                                <option value="@p.Id">@p.FirstName @p.LastName - @p.PatientId</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="ProcedureName" class="form-label"></label>
                        <input asp-for="ProcedureName" class="form-control" required />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="SurgeonName" class="form-label"></label>
                        <input asp-for="SurgeonName" class="form-control" required />
                    </div>
                    <div class="col-md-3">
                        <label asp-for="OperationTheatreNumber" class="form-label"></label>
                        <input asp-for="OperationTheatreNumber" class="form-control" placeholder="OT-1" />
                    </div>
                    <div class="col-md-3">
                        <label asp-for="EstimatedDurationMinutes" class="form-label"></label>
                        <input asp-for="EstimatedDurationMinutes" type="number" min="15" step="15" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="ScheduledDate" class="form-label"></label>
                        <input asp-for="ScheduledDate" type="datetime-local" class="form-control" value="@Model.ScheduledDate.ToString("yyyy-MM-ddTHH:mm")" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Status" class="form-label"></label>
                        <select asp-for="Status" class="form-select">
                            <option>Scheduled</option>
                            <option>Completed</option>
                            <option>Cancelled</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <label asp-for="Notes" class="form-label"></label>
                        <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                    </div>
                </div>

                <div class="mt-3">
                    <button class="btn btn-primary" type="submit">Create Booking</button>
                </div>
            </form>
        </div>
    </div>
</div>
