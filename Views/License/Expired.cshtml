@model MedyxHMS.ViewModels.LicenseExpiredViewModel
@{
    ViewData["Title"] = "License Expired";
}

<div class="row justify-content-center mt-5">
    <div class="col-lg-8">
        <div class="card border-danger shadow-sm">
            <div class="card-body p-4">
                <h1 class="h3 text-danger mb-3">System License Expired</h1>
                <p class="mb-3">
                    Access to staff and admin workflows is currently restricted because the active MedyxHMS license expired on
                    <strong>@Model.Snapshot.License.ExpiresAtUtc.ToString("yyyy-MM-dd")</strong>.
                </p>
                <p class="mb-3">
                    Please complete payment and contact a SuperAdmin user to renew the license.
                </p>
                <dl class="row mb-4">
                    <dt class="col-sm-4">SuperAdmin Contact</dt>
                    <dd class="col-sm-8">@Model.Snapshot.SuperAdminContact</dd>
                    <dt class="col-sm-4">Billing Contact</dt>
                    <dd class="col-sm-8">@Model.Snapshot.BillingContact</dd>
                </dl>

                <div class="d-flex gap-2 flex-wrap">
                    <a class="btn btn-outline-secondary" asp-controller="Home" asp-action="Index">Go Home</a>
                    @if (!string.IsNullOrWhiteSpace(Model.ReturnUrl))
                    {
                        <span class="text-muted align-self-center">Blocked request: @Model.ReturnUrl</span>
                    }
                </div>
            </div>
        </div>
    </div>
</div>