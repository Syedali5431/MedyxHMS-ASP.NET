@model MedyxHMS.Models.LiveConsultationSession
@{
    ViewData["Title"] = "Schedule Consultation";
}

<div class="container mt-3">
    <h4><i class="fas fa-calendar-plus text-success me-2"></i>Schedule Live Consultation</h4>
    <div class="card mt-3 shadow-sm" style="max-width:680px">
        <div class="card-body">
            <form asp-action="Schedule" method="post">
                @Html.AntiForgeryToken()
                <div class="row g-3 mb-3">
                    <div class="col-6">
                        <label class="form-label fw-semibold">Doctor User <span class="text-danger">*</span></label>
                        <select asp-for="DoctorUserId" class="form-select">
                            <option value="">-- Select doctor account --</option>
                            @foreach (var doctor in ViewBag.Doctors)
                            {
                                <option value="@doctor.Id">@doctor.UserName</option>
                            }
                        </select>
                    </div>
                    <div class="col-6">
                        <label class="form-label fw-semibold">Patient Record</label>
                        <select asp-for="PatientId" class="form-select">
                            <option value="">-- Optional patient --</option>
                            @foreach (var patient in ViewBag.Patients)
                            {
                                <option value="@patient.Id">@patient.FirstName @patient.LastName</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-6">
                        <label class="form-label fw-semibold">Doctor Name <span class="text-danger">*</span></label>
                        <input asp-for="DoctorName" class="form-control" required />
                    </div>
                    <div class="col-6">
                        <label class="form-label fw-semibold">Patient Name <span class="text-danger">*</span></label>
                        <input asp-for="PatientName" class="form-control" required />
                    </div>
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-7">
                        <label class="form-label fw-semibold">Scheduled At <span class="text-danger">*</span></label>
                        <input asp-for="ScheduledAt" type="datetime-local" class="form-control" required />
                    </div>
                    <div class="col-5">
                        <label class="form-label fw-semibold">Duration (minutes)</label>
                        <input asp-for="DurationMinutes" type="number" min="5" class="form-control" />
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Platform</label>
                    <select asp-for="Platform" class="form-select">
                        <option value="Zoom">Zoom</option>
                        <option value="Teams">Teams</option>
                        <option value="GoogleMeet">GoogleMeet</option>
                        <option value="Custom">Custom</option>
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Meeting Link <span class="text-danger">*</span></label>
                    <input asp-for="MeetingLink" type="url" class="form-control" placeholder="https://..." required />
                    <small class="text-muted">Must start with https://</small>
                    <span asp-validation-for="MeetingLink" class="text-danger small"></span>
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-6">
                        <label class="form-label fw-semibold">Meeting ID</label>
                        <input asp-for="MeetingId" class="form-control" />
                    </div>
                    <div class="col-6">
                        <label class="form-label fw-semibold">Meeting Password</label>
                        <input asp-for="MeetingPassword" class="form-control" />
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Notes</label>
                    <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Schedule</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
