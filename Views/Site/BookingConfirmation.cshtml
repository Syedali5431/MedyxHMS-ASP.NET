@model MedyxHMS.ViewModels.BookingConfirmationViewModel
@{
    ViewData["Title"] = "Booking Confirmed";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
    ViewBag.MenuItems = Model.MenuItems;
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 text-center">
            <div class="card border-0 shadow-sm p-5">
                <div class="mb-4">
                    <span style="font-size:4rem;">✅</span>
                </div>
                <h2 class="fw-bold text-success mb-2">Booking Request Received!</h2>
                <p class="text-muted">
                    Thank you, <strong>@Model.PatientName</strong>. Your appointment request has been submitted.
                </p>

                @if (Model.RequestId > 0)
                {
                    <div class="card bg-light border-0 mt-4 mb-3 text-start">
                        <div class="card-body">
                            <table class="table table-sm mb-0">
                                <tr>
                                    <th>Reference #</th>
                                    <td><strong class="text-primary">@Model.RequestId</strong></td>
                                </tr>
                                <tr>
                                    <th>Doctor</th>
                                    <td>@Model.DoctorName</td>
                                </tr>
                                <tr>
                                    <th>Preferred Date</th>
                                    <td>@Model.PreferredDate.ToString("dddd, dd MMMM yyyy")</td>
                                </tr>
                                <tr>
                                    <th>Preferred Time</th>
                                    <td>@Model.PreferredTime</td>
                                </tr>
                            </table>
                        </div>
                    </div>

                    <p class="text-muted small">
                        Our staff will contact you to confirm your appointment.
                        Please note your reference number <strong>#@Model.RequestId</strong>.
                    </p>
                }

                <div class="mt-4 d-flex gap-3 justify-content-center">
                    <a asp-controller="Site" asp-action="BookAppointment" class="btn btn-outline-primary">
                        Book Another
                    </a>
                    <a asp-controller="Site" asp-action="Index" class="btn btn-secondary">
                        Back to Home
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
