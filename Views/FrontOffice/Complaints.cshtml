@model ComplaintPageViewModel
@{
    ViewData["Title"] = "Complaints Management";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Complaints</h2>
        <a class="btn btn-secondary" asp-action="Index">Back</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="card mb-4">
        <div class="card-header"><strong>New Complaint</strong></div>
        <div class="card-body">
            <form method="post" asp-action="AddComplaint" class="row g-3 align-items-end">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="StatusFilter" />
                <div class="col-md-3"><label class="form-label">Name</label><input asp-for="NewComplaint.ComplainantName" class="form-control" required /></div>
                <div class="col-md-2"><label class="form-label">Phone</label><input asp-for="NewComplaint.Phone" class="form-control" /></div>
                <div class="col-md-3"><label class="form-label">Subject</label><input asp-for="NewComplaint.Subject" class="form-control" required /></div>
                <div class="col-md-3"><label class="form-label">Description</label><input asp-for="NewComplaint.Description" class="form-control" /></div>
                <div class="col-md-1"><button class="btn btn-primary w-100" type="submit">Add</button></div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-body table-responsive">
            <table class="table table-striped table-bordered">
                <thead><tr><th>Date</th><th>Name</th><th>Subject</th><th>Status</th><th>Resolution</th><th>Action</th></tr></thead>
                <tbody>
                    @if (Model.Complaints.Any())
                    {
                        @foreach (var c in Model.Complaints)
                        {
                            <tr>
                                <td>@c.CreatedDate.ToLocalTime().ToString("yyyy-MM-dd")</td>
                                <td>@c.ComplainantName</td>
                                <td>@c.Subject</td>
                                <td>@c.Status</td>
                                <td>@(string.IsNullOrWhiteSpace(c.ResolutionNotes) ? "-" : c.ResolutionNotes)</td>
                                <td>
                                    <form method="post" asp-action="UpdateComplaintStatus" class="d-grid gap-1">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@c.Id" />
                                        <select name="status" class="form-select form-select-sm">
                                            <option selected="@(c.Status == "Open")">Open</option>
                                            <option selected="@(c.Status == "InProgress")">InProgress</option>
                                            <option selected="@(c.Status == "Resolved")">Resolved</option>
                                            <option selected="@(c.Status == "Closed")">Closed</option>
                                        </select>
                                        <input type="text" name="resolutionNotes" class="form-control form-control-sm" placeholder="Resolution notes" />
                                        <button class="btn btn-sm btn-primary" type="submit">Save</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="6" class="text-center text-muted">No complaints found.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
