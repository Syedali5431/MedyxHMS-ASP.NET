<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MedyxHMS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MedyxHMS.styles.css" asp-append-version="true" />
        <link rel="stylesheet" href="~/css/mobile-friendly.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">MedyxHMS</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                        <li class="nav-item dropdown">
                            <a class="nav-link text-dark dropdown-toggle" href="#" id="reportsDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Reports &amp; Audit
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="reportsDropdown">
                                <li><a class="dropdown-item" asp-area="" asp-controller="Report" asp-action="Index">Reports</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="Report" asp-action="Generate">Generate Report</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="Audit" asp-action="Index">Audit Logs</a></li>
                                <li><a class="dropdown-item" asp-area="" asp-controller="Audit" asp-action="UserActions">User Actions</a></li>
                            </ul>
                        </li>
                        @if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link text-dark dropdown-toggle" href="#" id="cmsDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Website CMS
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="cmsDropdown">
                                    <li><a class="dropdown-item" asp-area="" asp-controller="AccountsApproval" asp-action="Index">Accounts Approval</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="AccountsApproval" asp-action="Passwords">Password Management</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="Cms" asp-action="Index">Pages</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="Cms" asp-action="Notices">Notices</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="Cms" asp-action="Menu">Menu</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="Cms" asp-action="AppointmentRequests">Appointment Requests</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="Cms" asp-action="NotificationSettings">Notification Settings</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="Cms" asp-action="DeliveryLogs">Delivery Logs</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="PublicSiteAdmin" asp-action="Settings">Public Site Settings</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="Site" asp-action="Index" target="_blank">View Public Site</a></li>
                                </ul>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link text-dark dropdown-toggle" href="#" id="chatbotAdminDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Chatbot Admin
                                </a>
                                <ul class="dropdown-menu" aria-labelledby="chatbotAdminDropdown">
                                    <li><a class="dropdown-item" asp-area="" asp-controller="ChatbotAdmin" asp-action="Settings">Settings</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="ChatbotAdmin" asp-action="Analytics">Analytics</a></li>
                                    <li><a class="dropdown-item" asp-area="" asp-controller="ChatbotAdmin" asp-action="Escalations">Escalations</a></li>
                                </ul>
                            </li>
                        }
                        @if (User.IsInRole("SuperAdmin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="License" asp-action="Index">License</a>
                            </li>
                        }
                        }
                    </ul>
                    <ul class="navbar-nav ms-auto">
                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item me-2 d-flex align-items-center text-muted small">
                                Signed in as @User.Identity.Name
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger btn-sm">Logout</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="btn btn-primary btn-sm" asp-controller="Account" asp-action="Login">Login</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - MedyxHMS - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <a class="chatbot-fab"
       asp-controller="Chatbot"
       asp-action="Index"
       title="Open AI Assistant"
       aria-label="Open AI Assistant">
        AI
    </a>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
