@model MedyxHMS.ViewModels.UserListForModulesViewModel
@{
    ViewData["Title"] = "Users – Module Access";
}

<div class="container-fluid">
    <div class="row mb-3 align-items-center">
        <div class="col">
            <h2 class="mb-0"><i class="fas fa-users-cog me-2 text-primary"></i>Users – Module Access</h2>
            <p class="text-muted small mb-0">Select a user to view and configure their module access.</p>
        </div>
        @if (User.IsInRole("SuperAdmin"))
        {
            <div class="col-auto">
                <a asp-controller="ModuleManagement" asp-action="Index" class="btn btn-outline-secondary btn-sm">
                    <i class="fas fa-puzzle-piece me-1"></i>Global Modules
                </a>
            </div>
        }
    </div>

    <form method="get" class="row g-2 mb-4">
        <div class="col-md-5">
            <div class="input-group">
                <input type="text" name="search" value="@Model.SearchTerm"
                       class="form-control" placeholder="Search by name, email, or employee ID…" />
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-search"></i>
                </button>
                @if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
                {
                    <a asp-action="Users" class="btn btn-outline-secondary">Clear</a>
                }
            </div>
        </div>
    </form>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Employee ID</th>
                        <th>Roles</th>
                        <th>Status</th>
                        <th class="text-center">Modules</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Users.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                No users found@(!string.IsNullOrWhiteSpace(Model.SearchTerm) ? " matching \"" + Model.SearchTerm + "\"" : "").
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var u in Model.Users)
                        {
                            <tr>
                                <td>@u.FullName</td>
                                <td class="small text-muted">@u.Email</td>
                                <td class="small">@u.EmployeeId</td>
                                <td>
                                    @foreach (var role in u.Roles)
                                    {
                                        <span class="badge bg-secondary me-1">@role</span>
                                    }
                                    @if (!u.Roles.Any())
                                    {
                                        <span class="text-muted small">—</span>
                                    }
                                </td>
                                <td>
                                    @if (u.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <a asp-action="UserAccess" asp-route-userId="@u.Id"
                                       class="btn btn-sm btn-outline-primary">
                                        <i class="fas fa-sliders-h me-1"></i>Configure
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
