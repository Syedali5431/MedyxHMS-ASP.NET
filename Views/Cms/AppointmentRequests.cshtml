@model MedyxHMS.ViewModels.PublicAppointmentRequestIndexViewModel
@{
    ViewData["Title"] = "Public Appointment Requests";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">Public Appointment Requests</h2>
        <span class="badge bg-primary fs-6">@Model.TotalCount records</span>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Filters -->
    <form method="get" class="row g-2 mb-4">
        <div class="col-md-2">
            <select name="status" class="form-select form-select-sm">
                <option value="">All Statuses</option>
                <option value="Pending" selected="@(Model.StatusFilter == "Pending")">Pending</option>
                <option value="Confirmed" selected="@(Model.StatusFilter == "Confirmed")">Confirmed</option>
                <option value="Cancelled" selected="@(Model.StatusFilter == "Cancelled")">Cancelled</option>
            </select>
        </div>
        <div class="col-md-3">
            <input type="text" name="search" value="@Model.SearchTerm"
                   class="form-control form-control-sm" placeholder="Patient, phone, or doctor..." />
        </div>
        <div class="col-md-2">
            <input type="date" name="dateFrom" value="@Model.DateFrom?.ToString("yyyy-MM-dd")"
                   class="form-control form-control-sm" title="From date" />
        </div>
        <div class="col-md-2">
            <input type="date" name="dateTo" value="@Model.DateTo?.ToString("yyyy-MM-dd")"
                   class="form-control form-control-sm" title="To date" />
        </div>
        <div class="col-md-2">
            <div class="form-check pt-2">
                <input class="form-check-input" type="checkbox" name="duplicatesOnly" value="true" id="duplicatesOnly" @(Model.DuplicatesOnly ? "checked" : null) />
                <label class="form-check-label small" for="duplicatesOnly">Duplicates only</label>
            </div>
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-secondary btn-sm">Filter</button>
            <a asp-action="AppointmentRequests" class="btn btn-outline-secondary btn-sm">Clear</a>
        </div>
        <div class="col-auto ms-auto">
            <a asp-action="AppointmentRequestsExport"
               asp-route-format="csv"
               asp-route-status="@Model.StatusFilter"
               asp-route-search="@Model.SearchTerm"
               asp-route-dateFrom="@Model.DateFrom?.ToString("yyyy-MM-dd")"
               asp-route-dateTo="@Model.DateTo?.ToString("yyyy-MM-dd")"
               asp-route-duplicatesOnly="@Model.DuplicatesOnly"
               class="btn btn-outline-primary btn-sm">Export CSV</a>
            <a asp-action="AppointmentRequestsExport"
               asp-route-format="pdf"
               asp-route-status="@Model.StatusFilter"
               asp-route-search="@Model.SearchTerm"
               asp-route-dateFrom="@Model.DateFrom?.ToString("yyyy-MM-dd")"
               asp-route-dateTo="@Model.DateTo?.ToString("yyyy-MM-dd")"
               asp-route-duplicatesOnly="@Model.DuplicatesOnly"
               class="btn btn-outline-danger btn-sm">Export PDF</a>
        </div>
    </form>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0 small">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Patient</th>
                        <th>Patient ID</th>
                        <th>Phone</th>
                        <th>Doctor</th>
                        <th>Pref. Date</th>
                        <th>Pref. Time</th>
                        <th>Status</th>
                        <th>Submitted</th>
                        <th>Duplicates</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.RequestRows.Any())
                    {
                        <tr>
                            <td colspan="11" class="text-center text-muted py-4">No appointment requests found.</td>
                        </tr>
                    }
                    @foreach (var row in Model.RequestRows)
                    {
                        var r = row.Request;
                        <tr>
                            <td>@r.Id</td>
                            <td>
                                <strong>@r.PatientName</strong><br />
                                <span class="text-muted">@r.Gender @r.Age</span>
                            </td>
                            <td>
                                @if (r.Patient != null)
                                {
                                    <span class="badge bg-light text-dark border">@r.Patient.PatientId</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td>@r.Phone</td>
                            <td>
                                @if (r.Doctor != null)
                                {
                                    <text>Dr. @r.Doctor.FirstName @r.Doctor.LastName</text>
                                }
                                else
                                {
                                    <text>—</text>
                                }
                            </td>
                            <td>@r.PreferredDate.ToString("dd MMM yyyy")</td>
                            <td>@DateTime.Today.Add(r.PreferredTime).ToString("hh:mm tt")</td>
                            <td>
                                <span class="badge @(r.Status == "Confirmed" ? "bg-success" : r.Status == "Cancelled" ? "bg-danger" : "bg-warning text-dark")">
                                    @r.Status
                                </span>
                            </td>
                            <td>@r.CreatedAt.ToString("dd MMM HH:mm")</td>
                            <td>
                                @if (row.HasDuplicates)
                                {
                                    <a asp-action="ReviewDuplicates" asp-route-id="@r.Id" class="btn btn-outline-warning btn-sm">
                                        @row.DuplicateCount total / @row.ActiveDuplicateCount active
                                    </a>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td>
                                @if (r.Status == "Pending")
                                {
                                    <form asp-action="UpdateRequestStatus" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@r.Id" />
                                        <input type="hidden" name="status" value="Confirmed" />
                                        <button type="submit" class="btn btn-xs btn-success btn-sm me-1">Confirm</button>
                                    </form>
                                    <form asp-action="UpdateRequestStatus" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@r.Id" />
                                        <input type="hidden" name="status" value="Cancelled" />
                                        <button type="submit" class="btn btn-xs btn-danger btn-sm">Cancel</button>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav class="mt-3" aria-label="Appointment request pagination">
            <ul class="pagination pagination-sm">
                <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="AppointmentRequests"
                       asp-route-status="@Model.StatusFilter"
                       asp-route-search="@Model.SearchTerm"
                       asp-route-dateFrom="@Model.DateFrom?.ToString("yyyy-MM-dd")"
                       asp-route-dateTo="@Model.DateTo?.ToString("yyyy-MM-dd")"
                              asp-route-duplicatesOnly="@Model.DuplicatesOnly"
                       asp-route-page="@(Model.Page - 1)"
                       asp-route-pageSize="@Model.PageSize">Previous</a>
                </li>
                @for (var i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.Page ? "active" : "")">
                        <a class="page-link"
                           asp-action="AppointmentRequests"
                           asp-route-status="@Model.StatusFilter"
                           asp-route-search="@Model.SearchTerm"
                           asp-route-dateFrom="@Model.DateFrom?.ToString("yyyy-MM-dd")"
                           asp-route-dateTo="@Model.DateTo?.ToString("yyyy-MM-dd")"
                                    asp-route-duplicatesOnly="@Model.DuplicatesOnly"
                           asp-route-page="@i"
                           asp-route-pageSize="@Model.PageSize">@i</a>
                    </li>
                }
                <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="AppointmentRequests"
                       asp-route-status="@Model.StatusFilter"
                       asp-route-search="@Model.SearchTerm"
                       asp-route-dateFrom="@Model.DateFrom?.ToString("yyyy-MM-dd")"
                       asp-route-dateTo="@Model.DateTo?.ToString("yyyy-MM-dd")"
                       asp-route-duplicatesOnly="@Model.DuplicatesOnly"
                       asp-route-page="@(Model.Page + 1)"
                       asp-route-pageSize="@Model.PageSize">Next</a>
                </li>
            </ul>
        </nav>
    }

    <div class="mt-4 d-flex gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Manage Pages</a>
        <a asp-action="Notices" class="btn btn-outline-secondary btn-sm">Manage Notices</a>
    </div>
</div>
