@model MedyxHMS.Models.AmbulanceDispatch
@{
    ViewData["Title"] = "Dispatch Ambulance";
}

<div class="container mt-3">
    <h4><i class="fas fa-truck-loading text-danger me-2"></i>Dispatch Ambulance</h4>
    <div class="card mt-3 shadow-sm" style="max-width:640px">
        <div class="card-body">
            <form asp-action="Dispatch" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label fw-semibold">Vehicle <span class="text-danger">*</span></label>
                    <select asp-for="AmbulanceVehicleId" class="form-select">
                        <option value="">-- Select available vehicle --</option>
                        @foreach (var v in (IEnumerable<MedyxHMS.Models.AmbulanceVehicle>)ViewBag.Vehicles)
                        {
                            <option value="@v.Id">@v.VehicleNumber – @v.Model (@v.DriverName)</option>
                        }
                    </select>
                    <span asp-validation-for="AmbulanceVehicleId" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Patient (optional)</label>
                    <select asp-for="PatientId" class="form-select">
                        <option value="">-- External / Walk-in --</option>
                        @foreach (var p in (IEnumerable<MedyxHMS.Models.Patient>)ViewBag.Patients)
                        {
                            <option value="@p.Id">@p.FirstName @p.LastName</option>
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Patient Name (if external)</label>
                    <input asp-for="PatientName" class="form-control" placeholder="Leave blank if registered patient selected" />
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Contact Number <span class="text-danger">*</span></label>
                    <input asp-for="ContactNumber" class="form-control" />
                    <span asp-validation-for="ContactNumber" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Pickup Address <span class="text-danger">*</span></label>
                    <textarea asp-for="PickupAddress" class="form-control" rows="2"></textarea>
                    <span asp-validation-for="PickupAddress" class="text-danger small"></span>
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-6">
                        <label class="form-label fw-semibold">Purpose</label>
                        <select asp-for="Purpose" class="form-select">
                            <option>Emergency</option>
                            <option>Transfer</option>
                            <option>Discharge</option>
                            <option>Scheduled</option>
                        </select>
                    </div>
                    <div class="col-6">
                        <label class="form-label fw-semibold">Charges (optional)</label>
                        <input asp-for="Charges" type="number" step="0.01" class="form-control" />
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Notes</label>
                    <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger">Dispatch</button>
                    <a asp-action="Dispatches" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
