@model IEnumerable<MedyxHMS.Models.BirthRecord>
@{
    ViewData["Title"] = "Birth Records";
}

<div class="container-fluid mt-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="mb-0"><i class="fas fa-baby text-info me-2"></i>Birth Records</h4>
            <small class="text-muted">Hospital birth certificates &amp; records</small>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Deaths" class="btn btn-outline-secondary btn-sm">
                <i class="fas fa-book-dead me-1"></i>Death Records
            </a>
            <a asp-action="CreateBirth" class="btn btn-primary btn-sm">
                <i class="fas fa-plus me-1"></i>New Birth Record
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">@TempData["SuccessMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    <div class="card shadow-sm">
        <div class="card-body table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Cert #</th>
                        <th>Baby Name</th>
                        <th>Gender</th>
                        <th>Date of Birth</th>
                        <th>Weight (kg)</th>
                        <th>Mother</th>
                        <th>Delivery Type</th>
                        <th>Doctor</th>
                        <th>Cert Issued</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var b in Model)
                    {
                        <tr>
                            <td><code>@b.CertificateNumber</code></td>
                            <td>@b.BabyName</td>
                            <td>@b.Gender</td>
                            <td>@b.DateOfBirth.ToString("MMM dd, yyyy")</td>
                            <td>@b.WeightKg.ToString("F2")</td>
                            <td>@b.MotherName</td>
                            <td>@b.DeliveryType</td>
                            <td>@b.AttendingDoctorName</td>
                            <td>
                                @if (b.CertificateIssued)
                                {
                                    <span class="badge bg-success">Issued</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Pending</span>
                                }
                            </td>
                            <td>
                                <a asp-action="BirthDetails" asp-route-id="@b.Id" class="btn btn-sm btn-outline-primary">View</a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="10" class="text-center text-muted py-4">No birth records found.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Charts Row -->
    <div class="row mb-4">
        <div class="col-lg-6 mb-4">
            <div class="card shadow">
                <div class="card-header py-3"><h6 class="m-0 font-weight-bold text-primary">Birth Records by Month</h6></div>
                <div class="card-body"><canvas id="birthMonthChart" height="260"></canvas></div>
            </div>
        </div>
        <div class="col-lg-6 mb-4">
            <div class="card shadow">
                <div class="card-header py-3"><h6 class="m-0 font-weight-bold text-info">Gender Distribution</h6></div>
                <div class="card-body"><canvas id="birthGenderChart" height="260"></canvas></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function() {
            var records = @Html.Raw(Json.Serialize(Model.Select(b => new { month = b.DateOfBirth.ToString("MMM yyyy"), gender = b.Gender ?? "Unknown" })));
            var monthCounts = {}, genderCounts = {};
            records.forEach(function(r) {
                monthCounts[r.month] = (monthCounts[r.month] || 0) + 1;
                genderCounts[r.gender] = (genderCounts[r.gender] || 0) + 1;
            });
            new Chart(document.getElementById('birthMonthChart'), {
                type: 'bar',
                data: { labels: Object.keys(monthCounts).length > 0 ? Object.keys(monthCounts) : ['No Data'], datasets: [{ label: 'Births', data: Object.keys(monthCounts).length > 0 ? Object.values(monthCounts) : [0], backgroundColor: '#4e73df' }] },
                options: { responsive: true, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } }, x: { ticks: { maxRotation: 30 } } } }
            });
            new Chart(document.getElementById('birthGenderChart'), {
                type: 'doughnut',
                data: { labels: Object.keys(genderCounts).length > 0 ? Object.keys(genderCounts) : ['No Data'], datasets: [{ data: Object.keys(genderCounts).length > 0 ? Object.values(genderCounts) : [1], backgroundColor: ['#36b9cc','#e74a3b','#858796'], borderWidth: 2 }] },
                options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
            });
        })();
    </script>
}
