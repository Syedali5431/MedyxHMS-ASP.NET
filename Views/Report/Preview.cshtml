@model MedyxHMS.Models.ReportExecutionResult
@{
    var template = ViewData["Template"] as MedyxHMS.Models.ReportTemplate;
    ViewData["Title"] = "Report Preview";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="mb-0"><i class="fas fa-eye"></i> Preview: @(template?.Name ?? "Template")</h3>
        <a href="@Url.Action("Builder")" class="btn btn-outline-secondary btn-sm">Back to Builder</a>
    </div>

    <div class="card">
        <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
            <span>Execution Result</span>
            <span class="badge bg-dark">@Model.TotalRecords records</span>
        </div>
        <div class="card-body">
            @if (!Model.Success)
            {
                <div class="alert alert-warning mb-0">@Model.Message</div>
            }
            else if (Model.Data != null && Model.Data.Any())
            {
                <div class="table-responsive">
                    <table class="table table-bordered table-striped table-sm">
                        <thead class="table-light">
                            <tr>
                                @foreach (var key in Model.Data.First().Keys)
                                {
                                    <th>@key</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.Data)
                            {
                                <tr>
                                    @foreach (var value in row.Values)
                                    {
                                        <td>@value</td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-secondary mb-0">No data available for this template.</div>
            }
        </div>
    </div>
</div>
