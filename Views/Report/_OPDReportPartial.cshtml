@model OPDReportViewModel

@{
    ViewData["Title"] = "OPD Report";
}

<div class="card h-100">
    <div class="card-header bg-warning text-dark">
        <h5 class="mb-0"><i class="fas fa-clinic-medical me-2"></i>OPD Report (R4)</h5>
    </div>
    <div class="card-body">
        <!-- Filter Section -->
        <div class="row mb-3">
            <div class="col-md-4">
                <label class="form-label">Start Date</label>
                <input type="date" id="startDate" class="form-control" value="@Model.StartDate.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-4">
                <label class="form-label">End Date</label>
                <input type="date" id="endDate" class="form-control" value="@Model.EndDate.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-4 d-flex align-items-end">
                <button class="btn btn-primary w-100" onclick="reloadReport()">Generate</button>
            </div>
        </div>

        <!-- Summary Statistics -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <h6 class="card-title">Total Visits</h6>
                        <h4 class="text-primary">@Model.TotalVisits</h4>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <h6 class="card-title">Unique Patients</h6>
                        <h4 class="text-success">@Model.UniquePatients</h4>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <h6 class="card-title">Total Fees</h6>
                        <h4 class="text-info">@Model.TotalConsultationFees.ToString("C")</h4>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card text-center">
                    <div class="card-body">
                        <h6 class="card-title">Avg Consultation</h6>
                        <h4 class="text-warning">@Model.AverageConsultationFee.ToString("C")</h4>
                    </div>
                </div>
            </div>
        </div>

        <!-- Payment Status Summary -->
        <div class="row mb-3">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-body">
                        <h6 class="card-title">Payment Status</h6>
                        <div class="row">
                            <div class="col-6 text-center">
                                <small class="text-muted">Paid</small>
                                <h5 class="text-success">@Model.PaidVisits</h5>
                            </div>
                            <div class="col-6 text-center">
                                <small class="text-muted">Pending</small>
                                <h5 class="text-warning">@Model.PendingPaymentVisits</h5>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            @if (Model.VisitsByDoctor != null && Model.VisitsByDoctor.Any())
            {
                <div class="col-md-6">
                    <h6>Top Doctors (by visit count)</h6>
                    <div class="list-group">
                        @foreach (var item in Model.VisitsByDoctor.Take(5))
                        {
                            <div class="list-group-item d-flex justify-content-between">
                                <span>@item.Key</span>
                                <strong>@item.Value visits</strong>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        <!-- Export Buttons -->
        <div class="mb-3">
            <button class="btn btn-sm btn-outline-success" onclick="exportToPDF()"><i class="fas fa-file-pdf"></i> PDF</button>
            <button class="btn btn-sm btn-outline-success" onclick="exportToExcel()"><i class="fas fa-file-excel"></i> Excel</button>
            <button class="btn btn-sm btn-outline-secondary" onclick="window.print()"><i class="fas fa-print"></i> Print</button>
        </div>

        <!-- OPD Visits Table -->
        <div class="table-responsive">
            <table class="table table-striped table-bordered">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Patient</th>
                        <th>Doctor</th>
                        <th>Visit Date</th>
                        <th>Diagnosis</th>
                        <th>Consultation Fee</th>
                        <th>Payment Status</th>
                        <th>Created By</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.OPDVisitData != null && Model.OPDVisitData.Any())
                    {
                        foreach (var visit in Model.OPDVisitData)
                        {
                            var visitType = ((object)visit).GetType();
                            <tr>
                                <td>@(visitType.GetProperty("Id")?.GetValue(visit)?.ToString() ?? "-")</td>
                                <td>@(visitType.GetProperty("PatientName")?.GetValue(visit)?.ToString() ?? "-")</td>
                                <td>@(visitType.GetProperty("DoctorName")?.GetValue(visit)?.ToString() ?? "-")</td>
                                <td>@(visitType.GetProperty("VisitDate")?.GetValue(visit)?.ToString() ?? "-")</td>
                                <td>@(visitType.GetProperty("Diagnosis")?.GetValue(visit)?.ToString() ?? "-")</td>
                                <td class="text-end">@{var fee = (decimal?)visitType.GetProperty("ConsultationFee")?.GetValue(visit) ?? 0; @fee.ToString("C")}</td>
                                <td>
                                    @{
                                        var paymentStatus = visitType.GetProperty("PaymentStatus")?.GetValue(visit)?.ToString() ?? "-";
                                        var paymentBadge = paymentStatus == "Paid" ? "bg-success" : paymentStatus == "Pending" ? "bg-warning" : "bg-secondary";
                                    }
                                    <span class="badge @paymentBadge">@paymentStatus</span>
                                </td>
                                <td>@(visitType.GetProperty("CreatedBy")?.GetValue(visit)?.ToString() ?? "-")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted">No OPD visits found for the selected date range.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
function reloadReport() {
    const startDate = document.getElementById('startDate').value;
    const endDate = document.getElementById('endDate').value;
    location.href = `@Url.Action("OPDLegacyReport")?startDate=${startDate}&endDate=${endDate}`;
}

function exportToPDF() {
    const startDate = document.getElementById('startDate').value;
    const endDate = document.getElementById('endDate').value;
    window.location.href = `@Url.Action("ExportLegacyReport", "Report")?reportKey=R4&format=pdf&startDate=${startDate}&endDate=${endDate}`;
}

function exportToExcel() {
    const startDate = document.getElementById('startDate').value;
    const endDate = document.getElementById('endDate').value;
    window.location.href = `@Url.Action("ExportLegacyReport", "Report")?reportKey=R4&format=excel&startDate=${startDate}&endDate=${endDate}`;
}
</script>
