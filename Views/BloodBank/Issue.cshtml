@model BloodIssue
@{
    ViewData["Title"] = "Issue Blood";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Issue Blood</h2>
        <a class="btn btn-secondary" asp-action="Index">Back</a>
    </div>

    <div class="card">
        <div class="card-body">
            <form method="post" asp-action="Issue">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Patient</label>
                        <select asp-for="PatientId" class="form-select" required>
                            <option value="">Select patient</option>
                            @foreach (var p in (IEnumerable<Patient>)ViewBag.Patients)
                            {
                                <option value="@p.Id">@p.FirstName @p.LastName - @p.PatientId</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Blood Group</label>
                        <select asp-for="BloodGroup" class="form-select" required>
                            <option value="">Select group</option>
                            @foreach (var i in (IEnumerable<BloodInventory>)ViewBag.Inventory)
                            {
                                <option value="@i.BloodGroup">@i.BloodGroup (Available: @i.UnitsAvailable)</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="UnitsIssued" class="form-label"></label>
                        <input asp-for="UnitsIssued" type="number" min="1" class="form-control" required />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="CrossMatchStatus" class="form-label"></label>
                        <select asp-for="CrossMatchStatus" class="form-select">
                            <option>Pending</option>
                            <option>Verified</option>
                            <option>Not Required</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="RequestedBy" class="form-label"></label>
                        <input asp-for="RequestedBy" class="form-control" />
                    </div>
                    <div class="col-12">
                        <label asp-for="Notes" class="form-label"></label>
                        <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                    </div>
                </div>

                <div class="mt-3">
                    <button class="btn btn-primary" type="submit">Issue and Bill</button>
                </div>
            </form>
        </div>
    </div>
</div>
