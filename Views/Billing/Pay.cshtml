@using MedyxHMS.ViewModels
@{
    ViewData["Title"] = "Pay Bill";
    Layout = "~/Views/PatientPortal/Shared/_Layout.cshtml";
}

@model PaymentViewModel

<div class="pay-bill-header mb-4">
    <div class="row align-items-center">
        <div class="col-md-8">
            <h1 class="page-title">
                <i class="fas fa-credit-card text-primary"></i> Pay Bill
            </h1>
            <p class="text-muted">Complete the payment for your selected bill.</p>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-body">
                <form asp-action="Pay" method="post">
                    <input type="hidden" asp-for="BillId" />
                    <div class="mb-3">
                        <label class="form-label">Bill Number</label>
                        <input class="form-control" value="@Model.BillNumber" readonly />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Patient Name</label>
                        <input class="form-control" value="@Model.PatientName" readonly />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Bill Amount</label>
                        <input class="form-control" value="₹@Model.BillAmount.ToString("N2")" readonly />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Pending Amount</label>
                        <input class="form-control" value="₹@Model.PendingAmount.ToString("N2")" readonly />
                    </div>
                    <div class="mb-3">
                        <label asp-for="Amount" class="form-label"></label>
                        <input asp-for="Amount" class="form-control" />
                        <span asp-validation-for="Amount" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="PaymentMethod" class="form-label"></label>
                        <select asp-for="PaymentMethod" class="form-select" id="PaymentMethodSelect">
                            @foreach (var method in Model.PaymentMethods)
                            {
                                <option value="@method">@method</option>
                            }
                        </select>
                        <span asp-validation-for="PaymentMethod" class="text-danger"></span>
                    </div>

                    <!-- Active Gateway Display (shown when "Online" is selected) -->
                    <div id="GatewayInfoBox" class="mb-3 p-3 bg-light border rounded d-none">
                        <small class="text-muted">Payment will be processed through:</small>
                        <div class="text-center mt-2">
                            <img id="GatewayLogo" src="" alt="Gateway" class="img-fluid" style="max-height: 60px;" />
                            <p id="GatewayName" class="mt-2 mb-0 fw-bold"></p>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Notes" class="form-label"></label>
                        <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Notes" class="text-danger"></span>
                    </div>
                    <button type="submit" class="btn btn-success">
                        <i class="fas fa-credit-card"></i> Pay Now
                    </button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card sticky-top" style="top: 20px;">
            <div class="card-header bg-light">
                <h5 class="mb-0">Payment Tips</h5>
            </div>
            <div class="card-body">
                <ul class="list-unstyled">
                    <li class="mb-2"><i class="fas fa-check text-success"></i> Secure payment processing.</li>
                    <li class="mb-2"><i class="fas fa-check text-success"></i> Save your transaction ID for record.</li>
                    <li class="mb-2"><i class="fas fa-check text-success"></i> Payments are credited instantly.</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        const gatewayMapping = {
            paypal: { name: 'PayPal', logo: '/images/gateways/paypal.png' },
            stripe: { name: 'Stripe', logo: '/images/gateways/stripe.png' },
            payu: { name: 'PayU', logo: '/images/gateways/payu.png' },
            ccavenue: { name: 'CCAvenue', logo: '/images/gateways/ccavenue.png' },
            instamojo: { name: 'Instamojo', logo: '/images/gateways/instamojo.png' },
            paystack: { name: 'Paystack', logo: '/images/gateways/paystack.png' },
            razorpay: { name: 'Razorpay', logo: '/images/gateways/razorpay.jpg' },
            paytm: { name: 'Paytm', logo: '/images/gateways/paytm.jpg' },
            midtrans: { name: 'Midtrans', logo: '/images/gateways/midtrans.jpg' },
            pesapal: { name: 'Pesapal', logo: '/images/gateways/pesapal.jpg' },
            flutterwave: { name: 'Flutterwave', logo: '/images/gateways/flutterwave.png' },
            ipayafrica: { name: 'iPay Africa', logo: '/images/gateways/ipayafrica.png' },
            jazzcash: { name: 'JazzCash', logo: '/images/gateways/jazzcash.jpg' },
            billplz: { name: 'Billplz', logo: '/images/gateways/billplz.jpg' },
            sslcommerz: { name: 'SSLCommerz', logo: '/images/gateways/sslcommerz.png' },
            walkingm: { name: 'Walkingm', logo: '/images/gateways/walkingm.png' },
            easypaisa: { name: 'EasyPaisa', logo: '/images/gateways/easypaisa.png' }
        };

        let activeGateway = '@Model.ActiveGateway?.ToLower() ?? "none"';

        document.addEventListener('DOMContentLoaded', function() {
            const select = document.getElementById('PaymentMethodSelect');
            const infoBox = document.getElementById('GatewayInfoBox');
            const logo = document.getElementById('GatewayLogo');
            const name = document.getElementById('GatewayName');

            function updateGatewayDisplay() {
                const method = select.value;
                if (method === 'Online' && activeGateway && activeGateway !== 'none') {
                    const gateway = gatewayMapping[activeGateway];
                    if (gateway) {
                        logo.src = gateway.logo;
                        name.textContent = gateway.name;
                        infoBox.classList.remove('d-none');
                    }
                } else {
                    infoBox.classList.add('d-none');
                }
            }

            select.addEventListener('change', updateGatewayDisplay);
            updateGatewayDisplay(); // Initial display
        });
    </script>
}


@section Styles {
    <style>
        .page-title { font-weight: 600; }
        .pay-bill-header { border-bottom: 2px solid #e9ecef; padding-bottom: 1rem; margin-bottom: 1.5rem; }
    </style>
}
