@model ThemeManagementViewModel
@{
    ViewData["Title"] = "Theme Management";
}

<div class="container-fluid py-3">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-2">
        <div>
            <h4 class="mb-0">System Management - Theme Management</h4>
            <small class="text-muted">Select your personal workspace theme. This preference follows your account across roles.</small>
        </div>
        <div>
            <span class="badge bg-secondary">Current Theme: @Model.CurrentUserTheme</span>
            @if (Model.PreferenceSince.HasValue)
            {
                <span class="badge bg-light text-dark border">Updated: @Model.PreferenceSince.Value.ToString("yyyy-MM-dd HH:mm") UTC</span>
            }
        </div>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success py-2">@successMessage</div>
    }
    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="alert alert-danger py-2">@errorMessage</div>
    }

    <div class="row g-3">
        @foreach (var theme in Model.AvailableThemes)
        {
            var isCurrent = string.Equals(Model.CurrentUserTheme, theme.ThemeId, StringComparison.OrdinalIgnoreCase);
            <div class="col-md-6 col-xl-4">
                <div class="card h-100 @(isCurrent ? "border-primary shadow-sm" : "")">
                    <div class="card-body d-flex flex-column">
                        <div class="theme-preview mb-3 @theme.PreviewClass"></div>
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="mb-0">@theme.Name</h5>
                            @if (isCurrent)
                            {
                                <span class="badge bg-primary">Active</span>
                            }
                        </div>
                        <p class="text-muted small flex-grow-1">@theme.Description</p>

                        <form method="post" asp-action="SelectTheme" class="theme-select-form" data-theme-name="@theme.Name">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="themeId" value="@theme.ThemeId" />
                            <button type="submit" class="btn @(isCurrent ? "btn-outline-primary" : "btn-primary") w-100" @(isCurrent ? "disabled" : "")>
                                @(isCurrent ? "Currently Applied" : "Apply This Theme")
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.theme-select-form').forEach(function (form) {
            form.addEventListener('submit', function (event) {
                var themeName = form.getAttribute('data-theme-name') || 'selected theme';
                var confirmed = window.confirm('Apply this theme?\n\nTheme: ' + themeName);
                if (!confirmed) {
                    event.preventDefault();
                }
            });
        });
    </script>
}
