@model MedyxHMS.ViewModels.IPDDashboardViewModel
@{
    ViewData["Title"] = "IPD Dashboard";
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-12">
            <h2><i class="fas fa-procedures"></i> IPD Dashboard</h2>
            <p class="text-muted">Overview of inpatient admissions and occupancy</p>
        </div>
    </div>

    <!-- Key Metrics -->
    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <div class="card border-left-primary shadow h-100 py-2">
                <div class="card-body">
                    <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Current Admissions</div>
                    <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.CurrentAdmissions</div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card border-left-success shadow h-100 py-2">
                <div class="card-body">
                    <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Available Beds</div>
                    <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.AvailableBeds</div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card border-left-info shadow h-100 py-2">
                <div class="card-body">
                    <div class="text-xs font-weight-bold text-info text-uppercase mb-1">Total Beds</div>
                    <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.TotalBeds</div>
                </div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card border-left-warning shadow h-100 py-2">
                <div class="card-body">
                    <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">Avg. Stay Duration</div>
                    <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.AverageStayDuration.ToString("F1") days</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts Row -->
    <div class="row mb-4">
        <div class="col-lg-6 mb-4">
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Admissions by Department</h6>
                </div>
                <div class="card-body">
                    @if (Model.AdmissionsByDepartment != null && Model.AdmissionsByDepartment.Any())
                    {
                        <canvas id="departmentChart" width="100%" height="300"></canvas>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-building fa-3x text-gray-300 mb-3"></i>
                            <h5 class="text-gray-500">No Department Data</h5>
                            <p class="text-muted">No IPD admissions have been categorized yet.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="col-lg-6 mb-4">
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-info">Ward Occupancy</h6>
                </div>
                <div class="card-body">
                    @if (Model.WardOccupancy != null && Model.WardOccupancy.Any())
                    {
                        <canvas id="wardChart" width="100%" height="300"></canvas>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-procedures fa-3x text-gray-300 mb-3"></i>
                            <h5 class="text-gray-500">No Ward Data</h5>
                            <p class="text-muted">No ward occupancy data available.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Admissions Table -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Recent Admissions</h6>
                </div>
                <div class="card-body">
                    @if (Model.RecentAdmissions != null && Model.RecentAdmissions.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-bordered">
                                <thead>
                                    <tr>
                                        <th>Patient</th>
                                        <th>Ward</th>
                                        <th>Bed</th>
                                        <th>Date</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var admission in Model.RecentAdmissions)
                                    {
                                        <tr>
                                            <td>@admission.PatientName</td>
                                            <td>@admission.WardName</td>
                                            <td>@admission.BedNumber</td>
                                            <td>@admission.AdmissionDate.ToString("MMM dd, yyyy")</td>
                                            <td><span class="badge badge-@admission.StatusBadgeClass">@admission.Status</span></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-user-clock fa-3x text-gray-300 mb-3"></i>
                            <h5 class="text-gray-500">No Recent Admissions</h5>
                            <p class="text-muted">No IPD admissions have been recorded recently.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Discharges Table -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-success">Recent Discharges</h6>
                </div>
                <div class="card-body">
                    @if (Model.RecentDischarges != null && Model.RecentDischarges.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-bordered">
                                <thead>
                                    <tr>
                                        <th>Patient</th>
                                        <th>Ward</th>
                                        <th>Bed</th>
                                        <th>Date</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var discharge in Model.RecentDischarges)
                                    {
                                        <tr>
                                            <td>@discharge.PatientName</td>
                                            <td>@discharge.WardName</td>
                                            <td>@discharge.BedNumber</td>
                                            <td>@discharge.DischargeDate?.ToString("MMM dd, yyyy")</td>
                                            <td><span class="badge badge-@discharge.StatusBadgeClass">@discharge.Status</span></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-user-check fa-3x text-gray-300 mb-3"></i>
                            <h5 class="text-gray-500">No Recent Discharges</h5>
                            <p class="text-muted">No IPD discharges have been recorded recently.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        $(document).ready(function() {
            // Department Chart
            @if (Model.AdmissionsByDepartment != null && Model.AdmissionsByDepartment.Any())
            {
                <text>var deptCtx = document.getElementById('departmentChart').getContext('2d');
                new Chart(deptCtx, {
                    type: 'doughnut',
                    data: {
                        labels: @Html.Raw(Json.Serialize(Model.AdmissionsByDepartment.Keys)),
                        datasets: [{
                            data: @Html.Raw(Json.Serialize(Model.AdmissionsByDepartment.Values)),
                            backgroundColor: ['#4e73df', '#1cc88a', '#36b9cc', '#f6c23e', '#e74a3b'],
                            borderWidth: 1
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        legend: { position: 'bottom' }
                    }
                });</text>
            }
            // Ward Chart
            @if (Model.WardOccupancy != null && Model.WardOccupancy.Any())
            {
                <text>var wardCtx = document.getElementById('wardChart').getContext('2d');
                new Chart(wardCtx, {
                    type: 'bar',
                    data: {
                        labels: @Html.Raw(Json.Serialize(Model.WardOccupancy.Select(w => w.Name))),
                        datasets: [{
                            label: 'Occupied Beds',
                            data: @Html.Raw(Json.Serialize(Model.WardOccupancy.Select(w => w.OccupiedBeds))),
                            backgroundColor: '#36b9cc',
                            borderColor: '#2c9faf',
                            borderWidth: 1
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            yAxes: [{
                                ticks: { beginAtZero: true, precision: 0 }
                            }]
                        },
                        legend: { display: false }
                    }
                });</text>
            }
        });
    </script>
}
