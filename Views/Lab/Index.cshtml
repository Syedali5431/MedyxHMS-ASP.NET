@model List<LabTest>

@{
    ViewData["Title"] = "Lab Test Catalog";
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2><i class="fas fa-flask"></i> Lab Test Catalog</h2>
            <p class="text-muted">Manage laboratory tests and procedures</p>
        </div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("CreateTest", "Lab")" class="btn btn-primary">
                <i class="fas fa-plus"></i> New Test
            </a>
            <a href="@Url.Action("OrderTest", "Lab")" class="btn btn-success">
                <i class="fas fa-microscope"></i> Order Test
            </a>
            <a href="@Url.Action("Results", "Lab")" class="btn btn-info">
                <i class="fas fa-file-medical"></i> View Results
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @* Search & Filter *@
    <form method="get" asp-action="Index" class="row g-2 mb-3">
        <div class="col-md-3">
            <input type="text" name="search" class="form-control form-control-sm" placeholder="Search by name or code..." value="@ViewBag.Search" />
        </div>
        <div class="col-auto">
            <input type="date" name="from" class="form-control form-control-sm" value="@ViewBag.FromDate" />
        </div>
        <div class="col-auto">
            <input type="date" name="to" class="form-control form-control-sm" value="@ViewBag.ToDate" />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-sm btn-primary"><i class="fas fa-search me-1"></i>Search</button>
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Clear</a>
        </div>
    </form>

    <div class="card">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="fas fa-list"></i> Available Tests (@Model.Count total)</h5>
        </div>
        <div class="card-body">
            @if (Model.Count > 0)
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Test Name</th>
                                <th>Code</th>
                                <th>Category</th>
                                <th>Price</th>
                                <th>Prep Time</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var test in Model)
                            {
                                <tr>
                                    <td><strong>@test.TestName</strong></td>
                                    <td><code>@test.TestCode</code></td>
                                    <td><span class="badge bg-info">@test.Category</span></td>
                                    <td class="text-end"><strong>Rs. @test.Price.ToString("N2")</strong></td>
                                    <td>@test.PreparationTimeHours hours</td>
                                    <td>
                                        @if (test.IsActive)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Inactive</span>
                                        }
                                    </td>
                                    <td>
                                        <a href="@Url.Action("EditTest", "Lab", new { id = test.Id })" class="btn btn-sm btn-warning">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <form method="post" action="@Url.Action("DeleteTest", "Lab", new { id = test.Id })" style="display:inline;">
                                            <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure?')">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                @if ((int)ViewBag.TotalPages > 1)
                {
                    <nav aria-label="Page navigation">
                        <ul class="pagination justify-content-center">
                            @for (int i = 1; i <= (int)ViewBag.TotalPages; i++)
                            {
                                <li class="page-item @(i == (int)ViewBag.CurrentPage ? "active" : "")">
                                    <a class="page-link" href="@Url.Action("Index", "Lab", new { page = i, search = ViewBag.Search as string, from = ViewBag.FromDate as string, to = ViewBag.ToDate as string })">@i</a>
                                </li>
                            }
                        </ul>
                    </nav>
                }
            }
            else
            {
                <div class="alert alert-info">No lab tests found. <a href="@Url.Action("CreateTest", "Lab")">Create one now</a></div>
            }
        </div>
    </div>
</div>

<style>
    .table-hover tbody tr:hover {
        background-color: #f5f5f5;
    }
</style>
