@model MedyxHMS.Controllers.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid">
    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="h3 mb-0 text-gray-800">Dashboard</h1>
            <p class="text-muted">Welcome to @Model?.HospitalSettings?.Name</p>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-lg-4 mb-3 mb-lg-0">
            <div class="card shadow h-100">
                <div class="card-header py-3">
                    <h6 class="m-0 fw-bold text-primary">Allowed Modules</h6>
                    <small class="text-muted">Expand a module and select an option.</small>
                </div>
                <div class="card-body module-explorer-sidebar">
                    @if (Model?.ModuleExplorer != null && Model.ModuleExplorer.Any())
                    {
                        <div class="accordion" id="moduleExplorerAccordion">
                            @for (var i = 0; i < Model.ModuleExplorer.Count; i++)
                            {
                                var module = Model.ModuleExplorer[i];
                                var headingId = $"moduleHeading-{i}";
                                var collapseId = $"moduleCollapse-{i}";
                                var isFirst = i == 0;

                                <div class="accordion-item mb-2 border rounded">
                                    <h2 class="accordion-header" id="@headingId">
                                        <button class="accordion-button @(isFirst ? string.Empty : "collapsed")"
                                                type="button"
                                                data-bs-toggle="collapse"
                                                data-bs-target="#@collapseId"
                                                aria-expanded="@(isFirst ? "true" : "false")"
                                                aria-controls="@collapseId">
                                            <i class="@module.Icon me-2"></i>
                                            @module.Title
                                        </button>
                                    </h2>
                                    <div id="@collapseId"
                                         class="accordion-collapse collapse @(isFirst ? "show" : string.Empty)"
                                         aria-labelledby="@headingId"
                                         data-bs-parent="#moduleExplorerAccordion">
                                        <div class="accordion-body py-2">
                                            <ul class="list-group list-group-flush">
                                                @foreach (var item in module.Items)
                                                {
                                                    <li class="list-group-item px-0 py-2 border-0">
                                                        <button type="button"
                                                                class="btn btn-sm btn-outline-primary w-100 text-start module-option-btn"
                                                                data-module-title="@module.Title"
                                                                data-module-description="@module.Description"
                                                                data-option-label="@item.Label"
                                                                data-option-description="@item.Description"
                                                                data-controller="@item.Controller"
                                                                data-action="@item.Action"
                                                                data-area="@item.Area">
                                                            @item.Label
                                                        </button>
                                                    </li>
                                                }
                                            </ul>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning mb-0">
                            No modules are currently available for this user.
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card shadow h-100 module-explorer-details">
                <div class="card-header py-3 d-flex align-items-center justify-content-between">
                    <h6 class="m-0 fw-bold text-primary">Module Option Details</h6>
                    <a id="module-option-open-link" href="#" class="btn btn-primary btn-sm disabled" aria-disabled="true">Open</a>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <div class="text-uppercase small text-muted">Module</div>
                        <h5 id="module-detail-title" class="mb-1">Select a module option</h5>
                        <p id="module-detail-description" class="text-muted mb-0">Pick an option from the left sidebar to see details here.</p>
                    </div>
                    <hr />
                    <div>
                        <div class="text-uppercase small text-muted">Option</div>
                        <h6 id="option-detail-title" class="mb-1">No option selected</h6>
                        <p id="option-detail-description" class="text-muted mb-0">The selected option details will appear here.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="row mb-4">
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-primary shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                                Total Patients
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@Model?.TotalPatients</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-users fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-success shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                                Today's Appointments
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@Model?.TodayAppointments</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-calendar-check fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-info shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-info text-uppercase mb-1">
                                Monthly Revenue
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@Model?.MonthlyRevenue.ToString("C")</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-dollar-sign fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-warning shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">
                                Pending Bills
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@Model?.PendingBills</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-file-invoice-dollar fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Appointments -->
    <div class="row">
        <div class="col-xl-8 col-lg-7">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Recent Appointments</h6>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-bordered" width="100%" cellspacing="0">
                            <thead>
                                <tr>
                                    <th>Patient</th>
                                    <th>Doctor</th>
                                    <th>Date & Time</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model?.RecentAppointments != null)
                                {
                                    @foreach (var appointment in Model.RecentAppointments)
                                    {
                                        <tr>
                                            <td>@appointment.Patient?.FirstName @appointment.Patient?.LastName</td>
                                            <td>@appointment.Doctor?.FirstName @appointment.Doctor?.LastName</td>
                                            <td>@appointment.AppointmentDate.ToShortDateString() @appointment.AppointmentTime</td>
                                            <td>
                                                <span class="badge badge-@(appointment.Status == "Confirmed" ? "success" : appointment.Status == "Pending" ? "warning" : "secondary")">
                                                    @appointment.Status
                                                </span>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="col-xl-4 col-lg-5">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Quick Actions</h6>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        @if (Model?.FeatureToggles?.PatientPortal == true)
                        {
                            <a asp-controller="Patient" asp-action="Create" class="btn btn-outline-primary">Add New Patient</a>
                        }
                        @if (Model?.FeatureToggles?.AppointmentSystem == true)
                        {
                            <a asp-controller="Appointment" asp-action="Create" class="btn btn-outline-success">Schedule Appointment</a>
                        }
                        @if (Model?.FeatureToggles?.BillingModule == true)
                        {
                            <a asp-controller="Billing" asp-action="Create" class="btn btn-outline-info">Create Bill</a>
                        }
                        @if (Model?.FeatureToggles?.OPDModule == true)
                        {
                            <a asp-controller="OPD" asp-action="Create" class="btn btn-outline-warning">OPD Visit</a>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            var optionButtons = document.querySelectorAll('.module-option-btn');
            var moduleTitle = document.getElementById('module-detail-title');
            var moduleDescription = document.getElementById('module-detail-description');
            var optionTitle = document.getElementById('option-detail-title');
            var optionDescription = document.getElementById('option-detail-description');
            var openLink = document.getElementById('module-option-open-link');

            function resolveUrl(btn) {
                var controller = btn.getAttribute('data-controller');
                var action = btn.getAttribute('data-action') || 'Index';
                var area = btn.getAttribute('data-area');
                var path = '/';

                if (area) {
                    path += area + '/';
                }

                path += controller + '/' + action;
                return path;
            }

            function activateButton(selectedBtn) {
                optionButtons.forEach(function (btn) {
                    btn.classList.remove('active');
                });

                selectedBtn.classList.add('active');

                moduleTitle.textContent = selectedBtn.getAttribute('data-module-title') || 'Module';
                moduleDescription.textContent = selectedBtn.getAttribute('data-module-description') || '';
                optionTitle.textContent = selectedBtn.getAttribute('data-option-label') || 'Option';
                optionDescription.textContent = selectedBtn.getAttribute('data-option-description') || '';

                var url = resolveUrl(selectedBtn);
                openLink.href = url;
                openLink.classList.remove('disabled');
                openLink.setAttribute('aria-disabled', 'false');
            }

            optionButtons.forEach(function (btn) {
                btn.addEventListener('click', function () {
                    activateButton(btn);
                });
            });

            if (optionButtons.length > 0) {
                activateButton(optionButtons[0]);
            }
        }());
    </script>
}