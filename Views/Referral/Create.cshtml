@model Referral
@{
    ViewData["Title"] = "Create Referral";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Create Referral / TPA Case</h2>
        <a class="btn btn-secondary" asp-action="Index">Back</a>
    </div>

    <div class="card">
        <div class="card-body">
            <form method="post" asp-action="Create">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Patient</label>
                        <select asp-for="PatientId" class="form-select" required>
                            <option value="">Select patient</option>
                            @foreach (var p in (IEnumerable<Patient>)ViewBag.Patients)
                            {
                                <option value="@p.Id">@p.FirstName @p.LastName - @p.PatientId</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="ReferralType" class="form-label"></label>
                        <select asp-for="ReferralType" class="form-select">
                            <option>External</option>
                            <option>Internal</option>
                            <option>TPA</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="ReferredTo" class="form-label"></label>
                        <input asp-for="ReferredTo" class="form-control" required />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="ReferralDate" class="form-label"></label>
                        <input asp-for="ReferralDate" type="date" class="form-control" value="@Model.ReferralDate.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="TpaProvider" class="form-label"></label>
                        <input asp-for="TpaProvider" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="TpaPolicyNumber" class="form-label"></label>
                        <input asp-for="TpaPolicyNumber" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="ApprovedAmount" class="form-label"></label>
                        <input asp-for="ApprovedAmount" type="number" min="0" step="0.01" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Status" class="form-label"></label>
                        <select asp-for="Status" class="form-select">
                            <option>Pending</option>
                            <option>Approved</option>
                            <option>Rejected</option>
                            <option>Completed</option>
                        </select>
                    </div>
                    <div class="col-12">
                        <label asp-for="ReferralReason" class="form-label"></label>
                        <textarea asp-for="ReferralReason" class="form-control" rows="2"></textarea>
                    </div>
                    <div class="col-12">
                        <label asp-for="Notes" class="form-label"></label>
                        <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                    </div>
                </div>

                <div class="mt-3">
                    <button class="btn btn-primary" type="submit">Save Referral</button>
                </div>
            </form>
        </div>
    </div>
</div>
