@inject MedyxHMS.Services.Interfaces.ISettingService SettingService
@{
    string NormalizeColor(string? value, string fallback)
    {
        if (string.IsNullOrWhiteSpace(value))
            return fallback;

        var trimmed = value.Trim();
        return System.Text.RegularExpressions.Regex.IsMatch(trimmed, "^#[0-9a-fA-F]{6}$")
            ? trimmed
            : fallback;
    }

    var primaryColor = NormalizeColor(await SettingService.GetSettingValueAsync("PublicSitePrimaryColor"), "#1a5276");
    var accentColor = NormalizeColor(await SettingService.GetSettingValueAsync("PublicSiteAccentColor"), "#2980b9");
    var surfaceColor = NormalizeColor(await SettingService.GetSettingValueAsync("PublicSiteSurfaceColor"), "#f4f8fb");

    var headingStyleRaw = (await SettingService.GetSettingValueAsync("PublicSiteHeadingStyle") ?? "Normal").Trim();
    var headingTransform = headingStyleRaw.Equals("Uppercase", StringComparison.OrdinalIgnoreCase)
        ? "uppercase"
        : headingStyleRaw.Equals("Capitalize", StringComparison.OrdinalIgnoreCase)
            ? "capitalize"
            : "none";

    var buttonStyleRaw = (await SettingService.GetSettingValueAsync("PublicSiteButtonStyle") ?? "Rounded").Trim();
    var buttonRadius = buttonStyleRaw.Equals("Pill", StringComparison.OrdinalIgnoreCase)
        ? "999px"
        : buttonStyleRaw.Equals("Square", StringComparison.OrdinalIgnoreCase)
            ? "0px"
            : "0.5rem";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Medyx Hospital</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        :root {
            --site-primary: @primaryColor;
            --site-accent: @accentColor;
            --site-surface: @surfaceColor;
            --site-heading-transform: @headingTransform;
            --site-button-radius: @buttonRadius;
        }
        body { background: var(--site-surface); }
        h1, h2, h3, h4, h5 { text-transform: var(--site-heading-transform); }
        .site-header { background: var(--site-primary); color: #fff; }
        .site-header a { color: color-mix(in srgb, var(--site-accent) 45%, #ffffff 55%); }
        .site-header a:hover { color: #fff; }
        .site-hero { background: linear-gradient(135deg, var(--site-primary), var(--site-accent)); color:#fff; padding:60px 0; }
        .notice-card { border-left: 4px solid var(--site-accent); }
        .badge-Notice { background: var(--site-accent); }
        .badge-News { background:#27ae60; }
        .badge-Event { background:#e67e22; }
        .badge-Program { background:#8e44ad; }
        .site-hero .btn, .site-footer .btn, .btn {
            border-radius: var(--site-button-radius);
        }
        .btn-primary {
            background-color: var(--site-primary);
            border-color: var(--site-primary);
        }
        .btn-primary:hover {
            background-color: var(--site-accent);
            border-color: var(--site-accent);
        }
        footer.site-footer { background:#1a2533; color:#adb5bd; padding:30px 0; }
    </style>
</head>
<body>
    <header class="site-header py-3">
        <div class="container d-flex justify-content-between align-items-center">
            <a class="fs-4 fw-bold text-decoration-none text-white" asp-controller="Site" asp-action="Index">
                🏥 Medyx Hospital
            </a>
            <nav class="d-flex gap-3 align-items-center flex-wrap">
                @if (ViewBag.MenuItems is List<MedyxHMS.Models.CmsMenuItem> menuItems && menuItems.Any())
                {
                    foreach (var item in menuItems)
                    {
                        <a href="@item.Url" class="text-decoration-none"
                           @(item.OpenInNewTab ? Html.Raw("target=\"_blank\" rel=\"noopener\"") : Html.Raw(""))>
                            @item.Label
                        </a>
                    }
                }
                else
                {
                    <a asp-controller="Site" asp-action="Notices" asp-route-type="Notice" class="text-decoration-none">Notices</a>
                    <a asp-controller="Site" asp-action="Notices" asp-route-type="News" class="text-decoration-none">News</a>
                    <a asp-controller="Site" asp-action="Doctors" class="text-decoration-none">Doctors</a>
                    <a asp-controller="Site" asp-action="BookAppointment" class="text-decoration-none">Book Appointment</a>
                }
                <a asp-controller="Site" asp-action="ContactUs" class="text-decoration-none">Contact Us</a>
                <a asp-controller="Site" asp-action="Careers" class="text-decoration-none">Careers</a>
                <a asp-controller="Site" asp-action="Location" class="text-decoration-none">Location</a>
                <a asp-controller="Account" asp-action="Login" class="btn btn-outline-light btn-sm ms-2">Staff Login</a>
            </nav>
        </div>
    </header>

    <main>
        @RenderBody()
    </main>

    <footer class="site-footer mt-5">
        <div class="container text-center">
            <p class="mb-1">&copy; @DateTime.Now.Year Medyx Hospital Management System. All rights reserved.</p>
            <p class="small mb-0">
                <a asp-controller="Site" asp-action="BookAppointment" class="text-decoration-none text-secondary me-3">Book Appointment</a>
                <a asp-controller="Site" asp-action="Notices" class="text-decoration-none text-secondary me-3">Notices</a>
                <a asp-controller="Site" asp-action="ContactUs" class="text-decoration-none text-secondary me-3">Contact Us</a>
                <a asp-controller="Site" asp-action="Careers" class="text-decoration-none text-secondary me-3">Careers</a>
                <a asp-controller="Site" asp-action="Location" class="text-decoration-none text-secondary me-3">Location</a>
                <a asp-controller="Account" asp-action="Login" class="text-decoration-none text-secondary">Staff Portal</a>
            </p>
        </div>
    </footer>

    <a class="chatbot-fab"
       asp-controller="Chatbot"
       asp-action="Index"
       title="Open AI Assistant"
       aria-label="Open AI Assistant">
        AI
    </a>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
