@model MedyxHMS.ViewModels.CmsPageEditViewModel
@{
    var isNew = Model.Id == 0;
    ViewData["Title"] = isNew ? "Create Page" : "Edit Page";
}

<div class="container-fluid py-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">CMS Pages</a></li>
            <li class="breadcrumb-item active">@ViewData["Title"]</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-header">
                    <h4 class="mb-0">@ViewData["Title"]</h4>
                </div>
                <div class="card-body p-4">

                    <form asp-action="@(isNew ? "CreatePage" : "EditPage")"
                          asp-route-id="@(isNew ? null : Model.Id.ToString())"
                          method="post"
                          enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="Title" class="form-label fw-semibold"></label>
                            <input asp-for="Title" class="form-control" id="titleInput" placeholder="Page Title" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Slug" class="form-label fw-semibold">
                                Slug
                                <small class="text-muted fw-normal">(URL identifier, e.g. about-us)</small>
                            </label>
                            <div class="input-group">
                                <span class="input-group-text text-muted">/site/page/</span>
                                <input asp-for="Slug" class="form-control" id="slugInput" placeholder="my-page-slug" />
                            </div>
                            <span asp-validation-for="Slug" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="MetaDescription" class="form-label fw-semibold"></label>
                            <input asp-for="MetaDescription" class="form-control" maxlength="300"
                                   placeholder="Brief description for search engines (up to 300 characters)" />
                            <span asp-validation-for="MetaDescription" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="FeaturedImageFile" class="form-label fw-semibold"></label>
                            <input asp-for="FeaturedImageFile" type="file" class="form-control" accept=".jpg,.jpeg,.png" />
                            @if (!string.IsNullOrWhiteSpace(Model.FeaturedImage))
                            {
                                <input type="hidden" asp-for="FeaturedImage" />
                                <div class="mt-2">
                                    <img src="/@Model.FeaturedImage" alt="Featured image" style="max-height:120px;" class="rounded border" />
                                </div>
                            }
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="FontFamily" class="form-label fw-semibold"></label>
                                <select asp-for="FontFamily" class="form-select">
                                    <option value="">Default</option>
                                    <option value="Georgia, 'Times New Roman', serif">Serif (Georgia)</option>
                                    <option value="'Trebuchet MS', 'Segoe UI', sans-serif">Sans (Trebuchet)</option>
                                    <option value="'Courier New', monospace">Monospace (Courier New)</option>
                                    <option value="'Lucida Sans', 'Segoe UI', sans-serif">Lucida Sans</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="FontSizePx" class="form-label fw-semibold"></label>
                                <input asp-for="FontSizePx" type="number" class="form-control" min="12" max="40" />
                                <span asp-validation-for="FontSizePx" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Content" class="form-label fw-semibold">Content (HTML)</label>
                            <textarea asp-for="Content" class="form-control font-monospace" rows="12"
                                      placeholder="Enter page HTML content..."></textarea>
                            <span asp-validation-for="Content" class="text-danger small"></span>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label asp-for="Status" class="form-label fw-semibold"></label>
                                <select asp-for="Status" class="form-select">
                                    <option value="Draft">Draft</option>
                                    <option value="Published">Published</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="SortOrder" class="form-label fw-semibold"></label>
                                <input asp-for="SortOrder" type="number" class="form-control" min="0" />
                            </div>
                            <div class="col-md-4 d-flex align-items-end">
                                <div class="form-check mb-2">
                                    <input asp-for="ShowInMenu" class="form-check-input" type="checkbox" />
                                    <label asp-for="ShowInMenu" class="form-check-label fw-semibold">Show in Public Menu</label>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-primary">
                                @(isNew ? "Create Page" : "Save Changes")
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        // Auto-generate slug from title (only on create)
        @if (isNew)
        {
            <text>
            document.getElementById('titleInput').addEventListener('input', function () {
                var slug = this.value.toLowerCase()
                    .replace(/[^a-z0-9\s-]/g, '')
                    .trim()
                    .replace(/\s+/g, '-')
                    .replace(/-+/g, '-');
                document.getElementById('slugInput').value = slug;
            });
            </text>
        }
    </script>
}
