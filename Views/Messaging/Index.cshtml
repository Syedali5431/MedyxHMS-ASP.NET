@model IEnumerable<MedyxHMS.Models.InternalMessage>
@{
    ViewData["Title"] = "Inbox";
    var isAdmin = User.IsInRole("Admin") || User.IsInRole("SuperAdmin");
}

<div class="container-fluid mt-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="mb-0"><i class="fas fa-envelope text-primary me-2"></i>Messaging</h4>
            <small class="text-muted">Internal staff communication</small>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Sent" class="btn btn-outline-secondary btn-sm">Sent</a>
            @if (isAdmin)
            {
                <a asp-action="Broadcast" class="btn btn-outline-warning btn-sm">
                    <i class="fas fa-bullhorn me-1"></i>Broadcast
                </a>
            }
            <a asp-action="Compose" class="btn btn-primary btn-sm">
                <i class="fas fa-pen me-1"></i>Compose
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">@TempData["SuccessMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width:3%"></th>
                        <th>Subject</th>
                        <th>From</th>
                        <th>Received</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in Model)
                    {
                        <tr class="@(!m.IsRead ? "fw-semibold" : "")">
                            <td class="text-center">
                                @if (m.IsBroadcast)
                                {
                                    <i class="fas fa-bullhorn text-warning" title="Broadcast"></i>
                                }
                                else if (!m.IsRead)
                                {
                                    <i class="fas fa-circle text-primary" style="font-size:0.5rem"></i>
                                }
                            </td>
                            <td>
                                <a asp-action="Read" asp-route-id="@m.Id" class="text-decoration-none text-dark">
                                    @m.Subject
                                </a>
                            </td>
                            <td><small>@m.SenderId</small></td>
                            <td><small>@m.SentAt.ToLocalTime().ToString("MMM dd, HH:mm")</small></td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a asp-action="Compose" asp-route-replyToId="@m.Id" class="btn btn-sm btn-outline-secondary">Reply</a>
                                    <form asp-action="Delete" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@m.Id" />
                                        <input type="hidden" name="folder" value="inbox" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete?')">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="5" class="text-center text-muted py-4">Inbox is empty.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Charts Row -->
    <div class="row mb-4">
        <div class="col-lg-6 mb-4">
            <div class="card shadow">
                <div class="card-header py-3"><h6 class="m-0 font-weight-bold text-primary">Messages by Read Status</h6></div>
                <div class="card-body"><canvas id="msgReadChart" height="260"></canvas></div>
            </div>
        </div>
        <div class="col-lg-6 mb-4">
            <div class="card shadow">
                <div class="card-header py-3"><h6 class="m-0 font-weight-bold text-info">Message Volume (Last 7 Days)</h6></div>
                <div class="card-body"><canvas id="msgVolumeChart" height="260"></canvas></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function() {
            var messages = @Html.Raw(Json.Serialize(Model.Select(m => new { isRead = m.IsRead, sent = m.SentAt.ToString("yyyy-MM-dd") })));
            var readCount = 0, unreadCount = 0;
            var dayCounts = {};
            var today = new Date();
            for (var i = 6; i >= 0; i--) { var d = new Date(today); d.setDate(d.getDate()-i); dayCounts[d.toISOString().slice(0,10)] = 0; }
            messages.forEach(function(m) {
                if (m.isRead) readCount++; else unreadCount++;
                if (dayCounts.hasOwnProperty(m.sent)) dayCounts[m.sent]++;
            });
            new Chart(document.getElementById('msgReadChart'), {
                type: 'doughnut',
                data: { labels: ['Read', 'Unread'], datasets: [{ data: [readCount, unreadCount], backgroundColor: ['#1cc88a','#e74a3b'], borderWidth: 2 }] },
                options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
            });
            new Chart(document.getElementById('msgVolumeChart'), {
                type: 'line',
                data: { labels: Object.keys(dayCounts), datasets: [{ label: 'Messages', data: Object.values(dayCounts), borderColor: '#4e73df', backgroundColor: 'rgba(78,115,223,0.1)', tension: 0.4 }] },
                options: { responsive: true, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } } }
            });
        })();
    </script>
}
