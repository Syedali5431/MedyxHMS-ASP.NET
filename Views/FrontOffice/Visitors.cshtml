@model VisitorPageViewModel
@{
    ViewData["Title"] = "Visitor Tracking";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Visitor Tracking</h2>
        <a class="btn btn-secondary" asp-action="Index">Back</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="card mb-4">
        <div class="card-header"><strong>New Visitor</strong></div>
        <div class="card-body">
            <form method="post" asp-action="AddVisitor" class="row g-3 align-items-end">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Date" />
                <div class="col-md-3"><label class="form-label">Name</label><input asp-for="NewVisitor.VisitorName" class="form-control" required /></div>
                <div class="col-md-2"><label class="form-label">Phone</label><input asp-for="NewVisitor.Phone" class="form-control" /></div>
                <div class="col-md-2"><label class="form-label">Purpose</label><input asp-for="NewVisitor.Purpose" class="form-control" /></div>
                <div class="col-md-2"><label class="form-label">Meet</label><input asp-for="NewVisitor.PersonToMeet" class="form-control" /></div>
                <div class="col-md-2"><label class="form-label">Visit Date</label><input asp-for="NewVisitor.VisitDate" type="date" class="form-control" value="@Model.Date.ToString("yyyy-MM-dd")" /></div>
                <div class="col-md-1"><button class="btn btn-primary w-100" type="submit">Add</button></div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-body table-responsive">
            <table class="table table-striped table-bordered">
                <thead><tr><th>Name</th><th>Phone</th><th>Purpose</th><th>Meet</th><th>In</th><th>Out</th><th>Status</th><th>Action</th></tr></thead>
                <tbody>
                    @if (Model.Visitors.Any())
                    {
                        @foreach (var v in Model.Visitors)
                        {
                            <tr>
                                <td>@v.VisitorName</td><td>@v.Phone</td><td>@v.Purpose</td><td>@v.PersonToMeet</td>
                                <td>@v.CheckInTime.ToLocalTime().ToString("HH:mm")</td>
                                <td>@(v.CheckOutTime.HasValue ? v.CheckOutTime.Value.ToLocalTime().ToString("HH:mm") : "-")</td>
                                <td>@v.Status</td>
                                <td>
                                    @if (v.Status == "CheckedIn")
                                    {
                                        <form method="post" asp-action="CheckOutVisitor">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@v.Id" />
                                            <input type="hidden" name="date" value="@Model.Date.ToString("yyyy-MM-dd")" />
                                            <button class="btn btn-sm btn-success" type="submit">Check Out</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="8" class="text-center text-muted">No visitors found.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
