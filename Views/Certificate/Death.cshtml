@model CertificateIndexViewModel
@{
    ViewData["Title"] = "Death Certificate Management";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2><i class="fas fa-heart-broken me-2"></i>Death Certificate Management</h2>
            <p class="text-muted mb-0">Generate, track, and print death certificates for patient deaths registered with the hospital</p>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Death Certificate Workflow</h5>
                </div>
                <div class="card-body">

                    <button class="btn btn-primary mb-3" data-bs-toggle="modal" data-bs-target="#deathCertModal">
                        <i class="fas fa-plus me-1"></i>New Death Certificate
                    </button>

                    <!-- Modal for Death Certificate Generator -->
                    <div class="modal fade" id="deathCertModal" tabindex="-1" aria-labelledby="deathCertModalLabel" aria-hidden="true">
                        <div class="modal-dialog modal-lg">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title" id="deathCertModalLabel">New Death Certificate</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                </div>
                                <div class="modal-body">
                                    @await Html.PartialAsync("~/Views/BirthDeath/CreateDeath.cshtml", new MedyxHMS.Models.DeathRecord { DateOfDeath = DateTime.Today })
                                </div>
                            </div>
                        </div>
                    </div>

                    <h6 class="mb-3">Process Overview</h6>
                    <ol class="list-group list-group-numbered">
                        <li class="list-group-item">
                            <strong>Enter Deceased Details</strong>
                            <p class="text-muted mb-0 mt-1">Fill in patient information and death event details</p>
                        </li>
                        <li class="list-group-item">
                            <strong>Record Cause of Death</strong>
                            <p class="text-muted mb-0 mt-1">Document the medical cause as certified by the physician</p>
                        </li>
                        <li class="list-group-item">
                            <strong>Select Template</strong>
                            <p class="text-muted mb-0 mt-1">Choose a death certificate template (default or custom)</p>
                        </li>
                        <li class="list-group-item">
                            <strong>Preview & Generate</strong>
                            <p class="text-muted mb-0 mt-1">Review the certificate and generate the document</p>
                        </li>
                        <li class="list-group-item">
                            <strong>Print & Archive</strong>
                            <p class="text-muted mb-0 mt-1">Print the certificate and store in the patient record</p>
                        </li>
                    </ol>

                    <hr class="my-4" />

                    <h6 class="mb-3">Available Actions</h6>
                    <div class="alert alert-warning">
                        <p class="mb-0">
                            <i class="fas fa-clock me-2"></i>
                            <strong>Coming Soon:</strong> Death certificate generation will be enabled in Phase 2. 
                            Check back soon for full functionality.
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Quick Reference</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <h6>Required Information</h6>
                        <ul class="small text-muted">
                            <li>Deceased's full name</li>
                            <li>Date of death</li>
                            <li>Time of death</li>
                            <li>Place of death</li>
                            <li>Age at death</li>
                            <li>Cause of death (ICD-10 code)</li>
                            <li>Certifying physician</li>
                            <li>Registration details</li>
                        </ul>
                    </div>
                    <hr />
                    <div>
                        <h6>Compliance Notes</h6>
                        <p class="small text-muted mb-0">
                            All death certificates follow legal requirements and are digitally tracked for audit compliance.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.list-group-item {
    border-left: 4px solid #dc3545;
    padding-left: 1.5rem;
}
.list-group-item strong {
    color: #212529;
}
</style>
