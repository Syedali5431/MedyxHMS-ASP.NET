@model MedyxHMS.Controllers.PrescriptionController.PrescriptionListViewModel

@{
    ViewData["Title"] = "Prescriptions";
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h3>Prescriptions</h3>
        </div>
        <div class="col-md-4 text-end">
            @if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin") || User.IsInRole("Doctor"))
            {
                <a href="@Url.Action("Create")" class="btn btn-primary">
                    <i class="fas fa-plus"></i> New Prescription
                </a>
                <a href="@Url.Action("Medicines")" class="btn btn-info">
                    <i class="fas fa-pills"></i> Manage Medicines
                </a>
            }
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Medicine</th>
                        <th>Dosage</th>
                        <th>Frequency</th>
                        <th>Duration (days)</th>
                        <th>Quantity</th>
                        <th>Total Price</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Prescriptions.Any())
                    {
                        @foreach (var prescription in Model.Prescriptions)
                        {
                            <tr>
                                <td>@prescription.MedicineName</td>
                                <td>@prescription.Dosage</td>
                                <td>@prescription.Frequency</td>
                                <td>@prescription.Duration</td>
                                <td>@prescription.Quantity</td>
                                <td>@prescription.TotalPrice.ToString("C")</td>
                                <td>@prescription.FormattedCreatedDate</td>
                                <td>
                                    <a href="@Url.Action("Details", new { id = prescription.Id })" class="btn btn-sm btn-info">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    @if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
                                    {
                                        <form method="post" action="@Url.Action("Delete", new { id = prescription.Id })" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete?')">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4">No prescriptions found</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Charts Row -->
    <div class="row mb-4">
        <div class="col-lg-6 mb-4">
            <div class="card shadow">
                <div class="card-header py-3"><h6 class="m-0 font-weight-bold text-primary">Top Medicines Prescribed</h6></div>
                <div class="card-body"><canvas id="prescTopMedChart" height="260"></canvas></div>
            </div>
        </div>
        <div class="col-lg-6 mb-4">
            <div class="card shadow">
                <div class="card-header py-3"><h6 class="m-0 font-weight-bold text-info">Prescriptions Overview</h6></div>
                <div class="card-body"><canvas id="prescOverviewChart" height="260"></canvas></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function() {
            var prescriptions = @Html.Raw(Json.Serialize(Model.Prescriptions));
            var medicineCounts = {};
            prescriptions.forEach(function(p) {
                var m = p.medicineName || 'Unknown'; medicineCounts[m] = (medicineCounts[m] || 0) + p.quantity;
            });
            var sortedEntries = Object.entries(medicineCounts).sort(function(a,b) { return b[1]-a[1]; }).slice(0, 8);
            new Chart(document.getElementById('prescTopMedChart'), {
                type: 'bar',
                data: { labels: sortedEntries.map(function(e){ return e[0]; }), datasets: [{ label: 'Qty', data: sortedEntries.map(function(e){ return e[1]; }), backgroundColor: '#4e73df' }] },
                options: { responsive: true, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } }, x: { ticks: { maxRotation: 30 } } } }
            });
            new Chart(document.getElementById('prescOverviewChart'), {
                type: 'doughnut',
                data: { labels: ['Total Prescriptions', 'Unique Medicines'], datasets: [{ data: [prescriptions.length, Object.keys(medicineCounts).length], backgroundColor: ['#1cc88a','#f6c23e'], borderWidth: 2 }] },
                options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
            });
        })();
    </script>
}
