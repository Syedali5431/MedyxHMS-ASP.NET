@model MedyxHMS.Models.Bed
@{
    var isEdit = Model.Id > 0;
    ViewData["Title"] = isEdit ? "Edit Bed" : "Add New Bed";
    var wards = (ViewBag.Wards as IEnumerable<MedyxHMS.Models.Ward>) ?? Enumerable.Empty<MedyxHMS.Models.Ward>();
    var bedTypes = new[] { "General", "ICU", "Private", "Semi-private", "Isolation", "Emergency" };
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 text-gray-800">
            <i class="fas fa-bed me-2"></i>@ViewData["Title"]
        </h1>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="fas fa-arrow-left me-1"></i>Back to Beds
        </a>
    </div>

    <div class="card shadow mb-4" style="max-width:600px">
        <div class="card-body">
            <form method="post" asp-action="@(isEdit ? "Edit" : "Create")">
                @Html.AntiForgeryToken()
                @if (isEdit)
                {
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="CreatedDate" />
                    <input type="hidden" asp-for="Status" />
                    <input type="hidden" asp-for="PatientId" />
                }

                <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="WardId" class="form-label fw-bold">Ward <span class="text-danger">*</span></label>
                    <select asp-for="WardId" class="form-select" required>
                        <option value="">— Select Ward —</option>
                        @foreach (var w in wards)
                        {
                            <option value="@w.Id">@w.Name</option>
                        }
                    </select>
                    <span asp-validation-for="WardId" class="text-danger"></span>
                </div>

                @* Location hierarchy fields — shown for both Create and Edit *@
                <div class="row g-2 mb-3">
                    <div class="col-md-4">
                        <label asp-for="Block" class="form-label fw-bold">Block Name <span class="text-danger">*</span></label>
                        <input asp-for="Block" class="form-control" placeholder="e.g. A, Block 1" maxlength="100" required />
                        <span asp-validation-for="Block" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Floor" class="form-label fw-bold">Floor No <span class="text-danger">*</span></label>
                        <input asp-for="Floor" class="form-control" placeholder="e.g. 1, Ground, G1" maxlength="50" required />
                        <span asp-validation-for="Floor" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="RoomNumber" class="form-label fw-bold">Room Number <span class="text-danger">*</span></label>
                        <input asp-for="RoomNumber" class="form-control" placeholder="e.g. 101, ICU-1" maxlength="50" required />
                        <span asp-validation-for="RoomNumber" class="text-danger"></span>
                    </div>
                </div>

                @* Number of Beds — only shown on Create; beds are auto-numbered from Room + sequence *@
                @if (!isEdit)
                {
                    <div class="mb-3">
                        <label class="form-label fw-bold">Number of Beds to Add <span class="text-danger">*</span></label>
                        <input name="numberOfBeds" type="number" min="1" max="50" value="1" class="form-control" required
                               style="max-width:140px" />
                        <div class="form-text">
                            Beds will be auto-numbered as <strong>&lt;Room&gt;-B01</strong>, <strong>&lt;Room&gt;-B02</strong>, &hellip;
                            If the room already has beds they will continue from the next available number.
                        </div>
                    </div>
                }
                else
                {
                    @* On Edit allow bed number correction *@
                    <div class="mb-3">
                        <label asp-for="BedNumber" class="form-label fw-bold">Bed Number</label>
                        <input asp-for="BedNumber" class="form-control" />
                        <span asp-validation-for="BedNumber" class="text-danger"></span>
                    </div>
                }

                <div class="mb-3">
                    <label asp-for="BedType" class="form-label fw-bold">Bed Type <span class="text-danger">*</span></label>
                    <select asp-for="BedType" class="form-select" id="bedTypeSelect" required>
                        <option value="">— Select Type —</option>
                        @foreach (var t in bedTypes)
                        {
                            <option value="@t">@t</option>
                        }
                    </select>
                    <span asp-validation-for="BedType" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="DailyCharges" class="form-label fw-bold">Daily Charges</label>
                    <div class="input-group">
                        <span class="input-group-text">$</span>
                        <input asp-for="DailyCharges" type="number" step="0.01" min="0" class="form-control" />
                    </div>
                    <span asp-validation-for="DailyCharges" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <div class="form-check">
                        <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                        <label asp-for="IsActive" class="form-check-label">Active</label>
                    </div>
                </div>

                <div id="icuNote" class="alert alert-info d-none">
                    <i class="fas fa-info-circle me-2"></i>ICU beds automatically require Admin approval for assignment.
                </div>
                <div id="isoNote" class="alert alert-warning d-none">
                    <i class="fas fa-shield-virus me-2"></i>Isolation beds are marked with the isolation flag.
                </div>

                <div class="d-flex gap-2 mt-3">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save me-1"></i>@(isEdit ? "Save Changes" : "Create Beds")
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('bedTypeSelect').addEventListener('change', function () {
            document.getElementById('icuNote').classList.toggle('d-none', this.value !== 'ICU');
            document.getElementById('isoNote').classList.toggle('d-none', this.value !== 'Isolation');
        });
        // Trigger on load for edit page
        document.getElementById('bedTypeSelect').dispatchEvent(new Event('change'));
    </script>
}
