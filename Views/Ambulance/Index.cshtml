@model IEnumerable<MedyxHMS.Models.AmbulanceVehicle>
@{
    ViewData["Title"] = "Ambulance Management";
    var isAdmin = User.IsInRole("Admin") || User.IsInRole("SuperAdmin");
}

<div class="container-fluid mt-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="mb-0"><i class="fas fa-ambulance text-danger me-2"></i>Ambulance Management</h4>
            <small class="text-muted">Vehicles &amp; dispatch tracking</small>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Dispatches" class="btn btn-outline-primary btn-sm">
                <i class="fas fa-map-marked-alt me-1"></i>Dispatches
            </a>
            @if (isAdmin)
            {
                <a asp-action="Create" class="btn btn-primary btn-sm">
                    <i class="fas fa-plus me-1"></i>Add Vehicle
                </a>
            }
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-3 mb-4">
        @foreach (var v in Model)
        {
            var statusBadge = v.Status switch
            {
                "Dispatched"   => "bg-warning text-dark",
                "Maintenance"  => "bg-danger",
                _              => "bg-success"
            };
            <div class="col-md-4 col-lg-3">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h6 class="fw-bold mb-0">@v.VehicleNumber</h6>
                            <span class="badge @statusBadge">@v.Status</span>
                        </div>
                        <p class="small mb-1"><i class="fas fa-car-side me-1 text-muted"></i>@v.Model</p>
                        <p class="small mb-1"><i class="fas fa-user me-1 text-muted"></i>@v.DriverName</p>
                        <p class="small mb-0"><i class="fas fa-phone me-1 text-muted"></i>@v.DriverContact</p>
                    </div>
                    @if (isAdmin)
                    {
                        <div class="card-footer bg-transparent border-0 pt-0">
                            <a asp-action="Edit" asp-route-id="@v.Id" class="btn btn-sm btn-outline-secondary w-100">Edit</a>
                        </div>
                    }
                </div>
            </div>
        }
        @if (!Model.Any())
        {
            <div class="col-12">
                <div class="alert alert-info">No vehicles registered yet.</div>
            </div>
        }
    </div>

    <a asp-action="Dispatch" class="btn btn-danger">
        <i class="fas fa-truck-loading me-1"></i>Dispatch Ambulance
    </a>
</div>
