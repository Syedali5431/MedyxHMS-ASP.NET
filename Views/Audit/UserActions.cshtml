@model UserActionLogViewModel
@{
    ViewData["Title"] = "User Action Logs";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2>User Action Logs</h2>
            <p class="text-muted mb-0">Authentication and activity trail from UserActionLogs</p>
        </div>
        <a class="btn btn-outline-secondary" asp-action="Index">Back to Audit Logs</a>
    </div>

    <div class="card mb-4">
        <div class="card-header"><strong>Filters</strong></div>
        <div class="card-body">
            <form method="get" asp-action="UserActions" class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">User Id</label>
                    <input type="text" class="form-control" name="userId" value="@Model.UserId" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">Start Date</label>
                    <input type="date" class="form-control" name="startDate" value="@Model.StartDate?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-3">
                    <label class="form-label">End Date</label>
                    <input type="date" class="form-control" name="endDate" value="@Model.EndDate?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button class="btn btn-primary w-100" type="submit">Apply</button>
                    <a class="btn btn-outline-secondary w-100" asp-action="UserActions">Reset</a>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-body table-responsive">
            <table class="table table-striped table-bordered align-middle">
                <thead>
                    <tr>
                        <th>Time (UTC)</th>
                        <th>User Id</th>
                        <th>Action Type</th>
                        <th>Status</th>
                        <th>IP</th>
                        <th>Details</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.UserActionLogs != null && Model.UserActionLogs.Any())
                    {
                        @foreach (var log in Model.UserActionLogs)
                        {
                            <tr>
                                <td>@log.LoggedDate.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                <td>@(string.IsNullOrWhiteSpace(log.UserId) ? "System" : log.UserId)</td>
                                <td>@log.ActionType</td>
                                <td>
                                    <span class="badge @(log.Status == "Success" ? "bg-success" : "bg-danger")">@log.Status</span>
                                </td>
                                <td>@log.IPAddress</td>
                                <td>@log.Details</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted">No user action logs found.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
