@model MedyxHMS.ViewModels.PublicAppointmentDuplicateReviewViewModel
@{
    ViewData["Title"] = "Review Duplicate Requests";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-1">Review Duplicate Requests</h2>
            <p class="text-muted mb-0">
                Same phone, doctor, date, and time as request #@Model.PrimaryRequest.Id.
            </p>
        </div>
        <div>
            <a asp-action="ReviewDuplicatesExport" asp-route-id="@Model.PrimaryRequest.Id" asp-route-format="csv" class="btn btn-outline-primary btn-sm">Export CSV</a>
            <a asp-action="ReviewDuplicatesExport" asp-route-id="@Model.PrimaryRequest.Id" asp-route-format="pdf" class="btn btn-outline-danger btn-sm">Export PDF</a>
            <a asp-action="AppointmentRequests" asp-route-duplicatesOnly="true" class="btn btn-outline-secondary btn-sm">Back to Duplicates</a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Matched requests</div>
                    <div class="fs-3 fw-bold">@Model.TotalMatches</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Active requests</div>
                    <div class="fs-3 fw-bold">@Model.ActiveMatches</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Phone</div>
                    <div class="fw-semibold">@Model.PrimaryRequest.Phone</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small">Requested slot</div>
                    <div class="fw-semibold">@Model.PrimaryRequest.PreferredDate.ToString("dd MMM yyyy")</div>
                    <div class="small text-muted">@DateTime.Today.Add(Model.PrimaryRequest.PreferredTime).ToString("hh:mm tt")</div>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0 small">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Patient</th>
                        <th>Patient ID</th>
                        <th>Doctor</th>
                        <th>Status</th>
                        <th>Submitted</th>
                        <th>Notes</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var request in Model.MatchingRequests)
                    {
                        <tr class="@(request.Id == Model.PrimaryRequest.Id ? "table-warning" : string.Empty)">
                            <td>@request.Id</td>
                            <td>
                                <strong>@request.PatientName</strong><br />
                                <span class="text-muted">@request.Phone</span>
                            </td>
                            <td>
                                @if (request.Patient != null)
                                {
                                    <span class="badge bg-light text-dark border">@request.Patient.PatientId</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td>
                                @if (request.Doctor != null)
                                {
                                    <text>Dr. @request.Doctor.FirstName @request.Doctor.LastName</text>
                                }
                                else
                                {
                                    <text>—</text>
                                }
                            </td>
                            <td>
                                <span class="badge @(request.Status == "Confirmed" ? "bg-success" : request.Status == "Cancelled" ? "bg-danger" : "bg-warning text-dark")">
                                    @request.Status
                                </span>
                            </td>
                            <td>@request.CreatedAt.ToString("dd MMM yyyy HH:mm")</td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(request.AdminNotes))
                                {
                                    @request.AdminNotes
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td>
                                @if (request.Status == "Pending")
                                {
                                    <form asp-action="UpdateRequestStatus" method="post" class="d-flex flex-column gap-1">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@request.Id" />
                                        <input type="hidden" name="returnToDuplicateReview" value="true" />
                                        <textarea name="adminNotes" rows="2" class="form-control form-control-sm" maxlength="300" placeholder="Add review note (optional)">@request.AdminNotes</textarea>
                                        <div class="d-flex gap-1">
                                            <button type="submit" name="status" value="Confirmed" class="btn btn-success btn-sm">Confirm</button>
                                            <button type="submit" name="status" value="Cancelled" class="btn btn-danger btn-sm">Cancel</button>
                                        </div>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>