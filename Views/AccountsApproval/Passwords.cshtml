@model MedyxHMS.ViewModels.PasswordManagementIndexViewModel
@{
    ViewData["Title"] = "Password Management";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Password Management</h2>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Accounts Approval</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }

    <form method="get" class="row g-2 mb-3">
        <div class="col-md-4">
            <input name="search" value="@Model.SearchTerm" class="form-control form-control-sm" placeholder="Search by name, email, employee ID" />
        </div>
        <div class="col-auto">
            <button class="btn btn-secondary btn-sm" type="submit">Search</button>
        </div>
    </form>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Employee ID</th>
                        <th>Roles</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                @if (!Model.Users.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">No users found.</td></tr>
                }
                else
                {
                    foreach (var row in Model.Users)
                    {
                        <tr>
                            <td>@row.FullName</td>
                            <td>@row.Email</td>
                            <td>@row.EmployeeId</td>
                            <td>@string.Join(", ", row.Roles)</td>
                            <td>@(row.IsActive ? "Active" : "Inactive")</td>
                            <td>
                                @if (row.CanResetPassword)
                                {
                                    <a asp-action="ResetPassword" asp-route-userId="@row.UserId" class="btn btn-sm btn-primary">Reset Password</a>
                                }
                                else
                                {
                                    <span class="text-muted small">Not permitted</span>
                                }
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
