{
  "OpenAI": {
    "Enabled": false,
    "BaseUrl": "https://api.openai.com",
    "ApiKey": "",
    "Model": "gpt-4o-mini"
  },
  "Security": {
    "Cors": {
      "AllowedOrigins": [
        "https://localhost:5001",
        "http://localhost:5000"
      ],
      "AllowedMethods": [ "GET", "POST", "OPTIONS" ],
      "AllowedHeaders": [ "Content-Type", "X-Requested-With", "RequestVerificationToken" ],
      "AllowCredentials": false
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
