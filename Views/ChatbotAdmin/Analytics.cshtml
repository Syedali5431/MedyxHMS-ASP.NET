@model MedyxHMS.ViewModels.ChatbotAdminAnalyticsViewModel
@{
    ViewData["Title"] = "Chatbot Analytics";
}

<div class="container py-4">
    <h2 class="h4 mb-3">Chatbot Analytics</h2>

    <form method="get" class="row g-2 mb-3">
        <div class="col-md-3">
            <label class="form-label" for="days">Window (days)</label>
            <input id="days" name="days" type="number" min="1" max="365" value="@Model.Days" class="form-control" />
        </div>
        <div class="col-md-2 align-self-end">
            <button class="btn btn-outline-primary" type="submit">Refresh</button>
        </div>
    </form>

    <div class="row g-3 mb-3">
        <div class="col-md-3"><div class="card"><div class="card-body"><div class="text-muted small">Total Sessions</div><div class="h4 mb-0">@Model.Snapshot.TotalSessions</div></div></div></div>
        <div class="col-md-3"><div class="card"><div class="card-body"><div class="text-muted small">Total Messages</div><div class="h4 mb-0">@Model.Snapshot.TotalMessages</div></div></div></div>
        <div class="col-md-3"><div class="card"><div class="card-body"><div class="text-muted small">Escalation Rate</div><div class="h4 mb-0">@((Model.Snapshot.EscalationRate * 100m).ToString("0.0"))%</div></div></div></div>
        <div class="col-md-3"><div class="card"><div class="card-body"><div class="text-muted small">Unresolved Rate</div><div class="h4 mb-0">@((Model.Snapshot.UnresolvedRate * 100m).ToString("0.0"))%</div></div></div></div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <h5 class="mb-3">Top Question Categories</h5>
            @if (Model.Snapshot.CategoryCounts.Count == 0)
            {
                <p class="text-muted mb-0">No category data yet.</p>
            }
            else
            {
                <table class="table table-sm align-middle">
                    <thead>
                        <tr>
                            <th>Category</th>
                            <th class="text-end">Count</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model.Snapshot.CategoryCounts.OrderByDescending(i => i.Value))
                    {
                        <tr>
                            <td>@item.Key</td>
                            <td class="text-end">@item.Value</td>
                        </tr>
                    }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>
