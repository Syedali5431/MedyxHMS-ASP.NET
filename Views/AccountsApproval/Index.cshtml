@model MedyxHMS.ViewModels.AccountsApprovalIndexViewModel
@{
    ViewData["Title"] = "Accounts Approval";
    int.TryParse(TempData["RejectErrorRequestId"]?.ToString(), out var rejectErrorRequestId);
    var rejectErrorMessage = TempData["RejectErrorMessage"]?.ToString();
    var rejectErrorReason = TempData["RejectErrorReason"]?.ToString() ?? string.Empty;
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Accounts Approval</h2>
        <a asp-action="Passwords" class="btn btn-outline-primary btn-sm">Password Management</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <form method="get" class="row g-2 mb-3">
        <div class="col-md-3">
            <select name="status" class="form-select form-select-sm">
                <option value="Pending" selected="@(Model.StatusFilter == "Pending")">Pending</option>
                <option value="Approved" selected="@(Model.StatusFilter == "Approved")">Approved</option>
                <option value="Rejected" selected="@(Model.StatusFilter == "Rejected")">Rejected</option>
                <option value="All" selected="@(Model.StatusFilter == "All")">All</option>
            </select>
        </div>
        <div class="col-auto">
            <button class="btn btn-secondary btn-sm" type="submit">Filter</button>
        </div>
    </form>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Employee ID</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Requested (UTC)</th>
                        <th>Approved By</th>
                        <th>Notes</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                @if (!Model.Requests.Any())
                {
                    <tr><td colspan="9" class="text-center text-muted py-4">No account requests found.</td></tr>
                }
                else
                {
                    foreach (var row in Model.Requests)
                    {
                        <tr>
                            <td>@row.FullName</td>
                            <td>@row.Email</td>
                            <td>@row.EmployeeId</td>
                            <td>@row.RequestedRole</td>
                            <td>
                                <span class="badge @(row.Status == "Approved" ? "bg-success" : row.Status == "Rejected" ? "bg-danger" : "bg-warning text-dark")">@row.Status</span>
                            </td>
                            <td>@row.RequestedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@(string.IsNullOrWhiteSpace(row.ApprovedBy) ? "-" : row.ApprovedBy)</td>
                            <td>@(string.IsNullOrWhiteSpace(row.Notes) ? "-" : row.Notes)</td>
                            <td>
                                @if (row.Status == "Pending")
                                {
                                    <form asp-action="Approve" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@row.RequestId" />
                                        <button type="submit" class="btn btn-sm btn-success">Approve</button>
                                    </form>
                                    <form asp-action="Reject" method="post" class="d-inline ms-1">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@row.RequestId" />
                                        <input type="text"
                                               name="reason"
                                               value="@(rejectErrorRequestId == row.RequestId ? rejectErrorReason : string.Empty)"
                                               class="form-control form-control-sm d-inline-block @(rejectErrorRequestId == row.RequestId && !string.IsNullOrWhiteSpace(rejectErrorMessage) ? "is-invalid" : string.Empty)"
                                               style="width: 180px;"
                                               placeholder="Reject reason"
                                               maxlength="250"
                                               required />
                                        <button type="submit" class="btn btn-sm btn-outline-danger ms-1">Reject</button>
                                        @if (rejectErrorRequestId == row.RequestId && !string.IsNullOrWhiteSpace(rejectErrorMessage))
                                        {
                                            <div class="invalid-feedback d-block">@rejectErrorMessage</div>
                                        }
                                    </form>
                                }
                                else
                                {
                                    <span class="text-muted small">Processed</span>
                                }
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
