@model IEnumerable<MedyxHMS.Models.GeneratedReport>

@{
    ViewData["Title"] = "Generated Reports";
    var reportType = ViewData["ReportType"] as string;
    var startDate = ViewData["StartDate"] as DateTime?;
    var endDate = ViewData["EndDate"] as DateTime?;
}

<div class="container-fluid mt-4">
    <div class="card">
        <div class="card-header bg-secondary text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0"><i class="fas fa-file-alt me-2"></i>Generated Reports</h4>
            <a asp-action="Index" class="btn btn-light btn-sm">Back to Reports</a>
        </div>
        <div class="card-body">
            <form method="get" class="row g-2 mb-3">
                <div class="col-md-3">
                    <input name="reportType" class="form-control" placeholder="Report Type" value="@reportType" />
                </div>
                <div class="col-md-3">
                    <input type="date" name="startDate" class="form-control" value="@startDate?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-3">
                    <input type="date" name="endDate" class="form-control" value="@endDate?.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-3">
                    <button class="btn btn-secondary w-100" type="submit">Filter</button>
                </div>
            </form>

            <div class="table-responsive">
                <table class="table table-striped table-bordered align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Name</th>
                            <th>Type</th>
                            <th>Date Range</th>
                            <th>Format</th>
                            <th>Status</th>
                            <th>Created</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var report in Model)
                            {
                                <tr>
                                    <td>@report.ReportName</td>
                                    <td>@report.ReportType</td>
                                    <td>@report.FromDate.ToString("yyyy-MM-dd") to @report.ToDate.ToString("yyyy-MM-dd")</td>
                                    <td>@report.FileFormat</td>
                                    <td>@report.Status</td>
                                    <td>@report.CreatedDate.ToString("yyyy-MM-dd HH:mm")</td>
                                    <td>
                                        <a asp-action="EditReport" asp-route-id="@report.Id" class="btn btn-sm btn-primary">Edit</a>
                                        <form asp-action="DeleteReport" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@report.Id" />
                                            <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete this report?');">Delete</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted">No generated reports found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
