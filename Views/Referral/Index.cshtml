@model IEnumerable<Referral>
@{
    ViewData["Title"] = "Referrals & TPA";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Referrals and TPA</h2>
        <a class="btn btn-primary" asp-action="Create">Create Referral</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="card">
        <div class="card-body table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Patient</th>
                        <th>Type</th>
                        <th>Referred To</th>
                        <th>Status</th>
                        <th>TPA Provider</th>
                        <th>Approved</th>
                        <th>Bill</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.ReferralDate.ToString("MMM dd, yyyy")</td>
                            <td>@item.Patient?.FirstName @item.Patient?.LastName</td>
                            <td>@item.ReferralType</td>
                            <td>@item.ReferredTo</td>
                            <td>@item.Status</td>
                            <td>@(string.IsNullOrWhiteSpace(item.TpaProvider) ? "-" : item.TpaProvider)</td>
                            <td>@(item.ApprovedAmount.HasValue ? item.ApprovedAmount.Value.ToString("N2") : "-")</td>
                            <td>@(item.BillId.HasValue ? item.BillId.Value.ToString() : "-")</td>
                            <td>
                                <form method="post" asp-action="UpdateStatus" class="d-flex gap-2">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <select class="form-select form-select-sm" name="status">
                                        <option selected="@(item.Status == "Pending")">Pending</option>
                                        <option selected="@(item.Status == "Approved")">Approved</option>
                                        <option selected="@(item.Status == "Rejected")">Rejected</option>
                                        <option selected="@(item.Status == "Completed")">Completed</option>
                                    </select>
                                    <button class="btn btn-sm btn-outline-primary" type="submit">Save</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Charts Row -->
    <div class="row mb-4">
        <div class="col-lg-6 mb-4">
            <div class="card shadow">
                <div class="card-header py-3"><h6 class="m-0 font-weight-bold text-primary">Referral Status</h6></div>
                <div class="card-body"><canvas id="refStatusChart" height="260"></canvas></div>
            </div>
        </div>
        <div class="col-lg-6 mb-4">
            <div class="card shadow">
                <div class="card-header py-3"><h6 class="m-0 font-weight-bold text-info">Referral Overview</h6></div>
                <div class="card-body"><canvas id="refBarChart" height="260"></canvas></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function() {
            var refs = @Html.Raw(Json.Serialize(Model.Select(r => new { status = r.Status })));
            var counts = {};
            refs.forEach(function(r) { counts[r.status] = (counts[r.status] || 0) + 1; });
            new Chart(document.getElementById('refStatusChart'), {
                type: 'doughnut',
                data: { labels: Object.keys(counts).length > 0 ? Object.keys(counts) : ['No Data'], datasets: [{ data: Object.keys(counts).length > 0 ? Object.values(counts) : [1], backgroundColor: ['#f6c23e','#1cc88a','#e74a3b','#4e73df','#858796'], borderWidth: 2 }] },
                options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
            });
            new Chart(document.getElementById('refBarChart'), {
                type: 'bar',
                data: { labels: Object.keys(counts).length > 0 ? Object.keys(counts) : ['No Data'], datasets: [{ label: 'Referrals', data: Object.keys(counts).length > 0 ? Object.values(counts) : [0], backgroundColor: '#4e73df' }] },
                options: { responsive: true, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } } }
            });
        })();
    </script>
}
