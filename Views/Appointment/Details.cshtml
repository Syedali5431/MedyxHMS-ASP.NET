@model MedyxHMS.ViewModels.AppointmentDetailsViewModel

@{
    ViewData["Title"] = "Appointment Details";
}

<div class="container-fluid">
    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="h3 mb-0 text-gray-800">Appointment Details</h1>
                    <p class="text-muted">@Model.Patient?.FullName with @Model.Doctor?.Name</p>
                </div>
                <div>
                    @if (User.HasPermission("Appointment", "Edit"))
                    {
                        <a href="@Url.Action("UpdateStatus", "Appointment", new { id = Model.Appointment.Id })" class="btn btn-warning">
                            <i class="fas fa-edit"></i> Update Status
                        </a>
                        <a href="@Url.Action("Edit", "Appointment", new { id = Model.Appointment.Id })" class="btn btn-secondary ml-2">
                            <i class="fas fa-pencil-alt"></i> Edit Details
                        </a>
                    }
                    <a href="@Url.Action("Index", "Appointment")" class="btn btn-info ml-2">
                        <i class="fas fa-arrow-left"></i> Back to Appointments
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Appointment Overview -->
    <div class="row mb-4">
        <div class="col-lg-8">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Appointment Information</h6>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <div class="mb-3">
                                <i class="fas fa-calendar text-primary mr-2"></i>
                                <strong>Date & Time:</strong><br>
                                <span class="h5">@Model.Appointment.FormattedDateTime</span>
                                @if (Model.Appointment.AppointmentDate.Date == DateTime.Today)
                                {
                                    <br><span class="badge badge-success">Today</span>
                                }
                                else if (Model.Appointment.AppointmentDate.Date == DateTime.Today.AddDays(1))
                                {
                                    <br><span class="badge badge-warning">Tomorrow</span>
                                }
                            </div>
                            <div class="mb-3">
                                <i class="fas fa-stethoscope text-info mr-2"></i>
                                <strong>Appointment Type:</strong><br>
                                <span class="badge badge-secondary">@Model.Appointment.AppointmentType</span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="mb-3">
                                <i class="fas fa-user-md text-success mr-2"></i>
                                <strong>Status:</strong><br>
                                <span class="badge @Model.Appointment.StatusBadgeClass">@Model.Appointment.Status</span>
                            </div>
                            <div class="mb-3">
                                <i class="fas fa-clock text-muted mr-2"></i>
                                <strong>Created:</strong><br>
                                @Model.Appointment.CreatedDate.ToString("MMM dd, yyyy 'at' hh:mm tt")
                                @if (!string.IsNullOrEmpty(Model.Appointment.CreatedBy))
                                {
                                    <br><small class="text-muted">by @Model.Appointment.CreatedBy</small>
                                }
                            </div>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Appointment.Symptoms))
                    {
                        <hr>
                        <div>
                            <i class="fas fa-heartbeat text-danger mr-2"></i>
                            <strong>Symptoms:</strong><br>
                            <p class="mt-2">@Model.Appointment.Symptoms</p>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.Appointment.Notes))
                    {
                        <hr>
                        <div>
                            <i class="fas fa-sticky-note text-warning mr-2"></i>
                            <strong>Notes:</strong><br>
                            <p class="mt-2">@Model.Appointment.Notes</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <!-- Quick Actions -->
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-info">Quick Actions</h6>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        @if (User.HasPermission("Appointment", "Edit"))
                        {
                            <a href="@Url.Action("UpdateStatus", "Appointment", new { id = Model.Appointment.Id })" class="btn btn-warning">
                                <i class="fas fa-edit"></i> Update Status
                            </a>
                            <a href="@Url.Action("Edit", "Appointment", new { id = Model.Appointment.Id })" class="btn btn-secondary">
                                <i class="fas fa-pencil-alt"></i> Edit Details
                            </a>
                        }
                        @if (User.HasPermission("Patient", "View"))
                        {
                            <a href="@Url.Action("Details", "Patient", new { id = Model.Appointment.PatientId })" class="btn btn-info">
                                <i class="fas fa-user"></i> View Patient
                            </a>
                        }
                        <a href="@Url.Action("Create", "Appointment", new { patientId = Model.Appointment.PatientId })" class="btn btn-success">
                            <i class="fas fa-plus"></i> New Appointment
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Patient and Doctor Information -->
    <div class="row mb-4">
        <div class="col-lg-6">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-success">Patient Information</h6>
                </div>
                <div class="card-body">
                    @if (Model.Patient != null)
                    {
                        <div class="text-center mb-3">
                            <div class="avatar-circle bg-success text-white mx-auto" style="width: 60px; height: 60px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 24px;">
                                @Model.Patient.FullName.Split(' ').Select(n => n.First()).FirstOrDefault()
                            </div>
                            <h5 class="mt-2">@Model.Patient.FullName</h5>
                            <p class="text-muted">@Model.Patient.PatientId</p>
                        </div>

                        <div class="row text-left">
                            <div class="col-6">
                                <strong>Age:</strong><br>
                                <span class="text-primary">@Model.Patient.Age years</span>
                            </div>
                            <div class="col-6">
                                <strong>Phone:</strong><br>
                                <a href="tel:@Model.Patient.Phone" class="text-primary">@Model.Patient.Phone</a>
                            </div>
                        </div>

                        <hr>

                        <div class="text-center">
                            <a href="@Url.Action("Details", "Patient", new { id = Model.Patient.Id })" class="btn btn-outline-primary btn-sm">
                                <i class="fas fa-eye"></i> View Full Profile
                            </a>
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted">
                            <i class="fas fa-user-times fa-2x mb-2"></i>
                            <p>Patient information not available</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-info">Doctor Information</h6>
                </div>
                <div class="card-body">
                    @if (Model.Doctor != null)
                    {
                        <div class="text-center mb-3">
                            <div class="avatar-circle bg-info text-white mx-auto" style="width: 60px; height: 60px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 24px;">
                                @Model.Doctor.Name.Split(' ').Select(n => n.First()).FirstOrDefault()
                            </div>
                            <h5 class="mt-2">@Model.Doctor.Name</h5>
                            <p class="text-muted">@Model.Doctor.Specialization</p>
                        </div>

                        <div class="row text-left">
                            <div class="col-6">
                                <strong>Department:</strong><br>
                                <span class="text-primary">@Model.Doctor.Department</span>
                            </div>
                            <div class="col-6">
                                <strong>Status:</strong><br>
                                @if (Model.Doctor.IsActive)
                                {
                                    <span class="badge badge-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge badge-secondary">Inactive</span>
                                }
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted">
                            <i class="fas fa-user-md fa-2x mb-2"></i>
                            <p>Doctor information not available</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Related Information -->
    <div class="row">
        <div class="col-lg-6">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-warning">Patient's Recent Appointments</h6>
                </div>
                <div class="card-body">
                    @if (Model.PatientRecentAppointments != null && Model.PatientRecentAppointments.Any())
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var appointment in Model.PatientRecentAppointments)
                            {
                                <a href="@Url.Action("Details", "Appointment", new { id = appointment.Id })"
                                   class="list-group-item list-group-item-action">
                                    <div class="d-flex w-100 justify-content-between">
                                        <h6 class="mb-1">@appointment.AppointmentType</h6>
                                        <small>@appointment.AppointmentDate.ToString("MMM dd")</small>
                                    </div>
                                    <p class="mb-1">@appointment.DoctorName</p>
                                    <small class="text-muted">@appointment.Status</small>
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-3 text-muted">
                            <i class="fas fa-calendar-times fa-2x mb-2"></i>
                            <p>No recent appointments</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-secondary">Doctor's Today's Appointments</h6>
                </div>
                <div class="card-body">
                    @if (Model.DoctorTodayAppointments != null && Model.DoctorTodayAppointments.Any())
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var appointment in Model.DoctorTodayAppointments)
                            {
                                <a href="@Url.Action("Details", "Appointment", new { id = appointment.Id })"
                                   class="list-group-item list-group-item-action">
                                    <div class="d-flex w-100 justify-content-between">
                                        <h6 class="mb-1">@appointment.PatientName</h6>
                                        <small>@appointment.AppointmentTime.ToString(@"hh\:mm tt")</small>
                                    </div>
                                    <p class="mb-1">@appointment.AppointmentType</p>
                                    <small class="text-muted">@appointment.Status</small>
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-3 text-muted">
                            <i class="fas fa-clock fa-2x mb-2"></i>
                            <p>No appointments today</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Add any client-side functionality here
        });
    </script>
}