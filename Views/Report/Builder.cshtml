@model List<MedyxHMS.Models.ReportTemplate>
@{
    ViewData["Title"] = "Report Builder";
    var selectedType = ViewData["ReportType"]?.ToString() ?? string.Empty;
    var availableTypes = (ViewData["AvailableTypes"] as List<string>) ?? new List<string>();
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="mb-0"><i class="fas fa-tools"></i> Report Template Builder</h3>
        <a href="@Url.Action("Index")" class="btn btn-outline-secondary btn-sm">Back to Reports</a>
    </div>

    <div class="card mb-4">
        <div class="card-header bg-primary text-white">Create New Template</div>
        <div class="card-body">
            <form asp-action="CreateTemplate" method="post">
                @Html.AntiForgeryToken()
                <div class="row g-2">
                    <div class="col-md-3">
                        <input type="text" name="name" class="form-control" placeholder="Template name" required />
                    </div>
                    <div class="col-md-3">
                        <input type="text" name="reportType" class="form-control" placeholder="Report type" required />
                    </div>
                    <div class="col-md-4">
                        <input type="text" name="description" class="form-control" placeholder="Description" />
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary w-100">Create</button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>Existing Templates</span>
            <form method="get" class="d-flex gap-2">
                <select class="form-select form-select-sm" name="reportType">
                    <option value="">All types</option>
                    @foreach (var type in availableTypes)
                    {
                        if (selectedType == type)
                        {
                            <option value="@type" selected>@type</option>
                        }
                        else
                        {
                            <option value="@type">@type</option>
                        }
                    }
                </select>
                <button type="submit" class="btn btn-sm btn-outline-primary">Filter</button>
            </form>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Name</th>
                            <th>Type</th>
                            <th>Status</th>
                            <th>Fields</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (Model.Any())
                    {
                        foreach (var template in Model)
                        {
                            <tr>
                                <td>@template.Name</td>
                                <td>@template.ReportType</td>
                                <td>
                                    @if (template.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </td>
                                <td>@(template.Fields?.Count ?? 0)</td>
                                <td class="d-flex gap-1">
                                    <a class="btn btn-sm btn-outline-primary" href="@Url.Action("Design", new { id = template.Id })">Design</a>
                                    <a class="btn btn-sm btn-outline-info" href="@Url.Action("Preview", new { id = template.Id })">Preview</a>
                                    <form asp-action="CloneTemplate" method="post" class="d-flex gap-1">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@template.Id" />
                                        <input type="text" name="newName" class="form-control form-control-sm" placeholder="Clone name" />
                                        <button type="submit" class="btn btn-sm btn-outline-dark">Clone</button>
                                    </form>
                                    <form asp-action="DeleteTemplate" method="post" onsubmit="return confirm('Delete this template?');">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@template.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-3">No templates found.</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
