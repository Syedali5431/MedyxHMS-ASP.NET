@model GenerateIdCardViewModel
@{
    ViewData["Title"] = "Generate ID Card";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Generate ID Card</h2>
        <a class="btn btn-secondary" asp-action="Index">Back</a>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="card">
        <div class="card-body">
            <form method="post" asp-action="GenerateIdCard">
                @Html.AntiForgeryToken()
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Staff</label>
                        <select asp-for="IdCard.StaffId" class="form-select" required>
                            <option value="">Select staff</option>
                            @foreach (var s in Model.StaffOptions)
                            {
                                <option value="@s.Id">@s.FirstName @s.LastName (@s.EmployeeId)</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3"><label class="form-label">Card Number</label><input asp-for="IdCard.CardNumber" class="form-control" placeholder="Auto if blank" /></div>
                    <div class="col-md-3"><label class="form-label">Issue Date</label><input asp-for="IdCard.IssueDate" type="date" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")" /></div>
                    <div class="col-md-3"><label class="form-label">Expiry Date</label><input asp-for="IdCard.ExpiryDate" type="date" class="form-control" /></div>
                    <div class="col-md-3"><label class="form-label">Status</label><select asp-for="IdCard.Status" class="form-select"><option>Active</option><option>Inactive</option><option>Replaced</option></select></div>
                    <div class="col-md-6"><label class="form-label">Notes</label><input asp-for="IdCard.Notes" class="form-control" /></div>
                </div>
                <div class="mt-3">
                    <button class="btn btn-primary" type="submit">Generate ID Card</button>
                </div>
            </form>
        </div>
    </div>
</div>
