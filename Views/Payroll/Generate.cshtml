@model PayrollGenerateViewModel
@{
    ViewData["Title"] = "Generate Payroll";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Generate Payroll</h2>
        <a class="btn btn-secondary" asp-action="Index">Back</a>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="card">
        <div class="card-body">
            <form method="post" asp-action="Generate">
                @Html.AntiForgeryToken()
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Staff</label>
                        <select asp-for="StaffId" class="form-select" required>
                            <option value="">Select staff</option>
                            @foreach (var s in Model.StaffOptions)
                            {
                                <option value="@s.Id">@s.FirstName @s.LastName (@s.EmployeeId)</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Payroll Month</label>
                        <input asp-for="PayrollMonth" type="month" class="form-control" value="@Model.PayrollMonth.ToString("yyyy-MM")" required />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Allowances</label>
                        <input asp-for="Allowances" type="number" min="0" step="0.01" class="form-control" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Deductions</label>
                        <input asp-for="Deductions" type="number" min="0" step="0.01" class="form-control" />
                    </div>
                    <div class="col-md-9">
                        <label class="form-label">Notes</label>
                        <input asp-for="Notes" class="form-control" />
                    </div>
                </div>

                <div class="mt-3">
                    <button class="btn btn-primary" type="submit">Generate Payroll</button>
                </div>
            </form>
        </div>
    </div>
</div>
