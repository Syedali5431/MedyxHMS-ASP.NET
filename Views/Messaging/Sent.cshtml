@model IEnumerable<MedyxHMS.Models.InternalMessage>
@{
    ViewData["Title"] = "Sent Messages";
}

<div class="container-fluid mt-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0"><i class="fas fa-paper-plane text-secondary me-2"></i>Sent</h4>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Inbox</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">@TempData["SuccessMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Subject</th>
                        <th>To</th>
                        <th>Sent</th>
                        <th>Read</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in Model)
                    {
                        <tr>
                            <td>
                                <a asp-action="Read" asp-route-id="@m.Id" class="text-decoration-none text-dark">
                                    @m.Subject
                                </a>
                                @if (m.IsBroadcast)
                                {
                                    <span class="badge bg-warning text-dark ms-1">Broadcast</span>
                                }
                            </td>
                            <td><small>@(m.IsBroadcast ? "All Staff" : m.RecipientId)</small></td>
                            <td><small>@m.SentAt.ToLocalTime().ToString("MMM dd, HH:mm")</small></td>
                            <td>
                                @if (m.IsRead)
                                {
                                    <span class="badge bg-success">Read</span>
                                }
                                else
                                {
                                    <span class="badge bg-light text-muted border">Unread</span>
                                }
                            </td>
                            <td>
                                <form asp-action="Delete" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@m.Id" />
                                    <input type="hidden" name="folder" value="sent" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete?')">
                                        <i class="fas fa-trash-alt"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="5" class="text-center text-muted py-4">No sent messages.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
