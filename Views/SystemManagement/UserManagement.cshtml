@model UserManagementViewVM
@{
    ViewData["Title"] = "User Management";
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2 class="mb-0">
                <i class="fas fa-users"></i> User Management
            </h2>
            <small class="text-muted">Manage system users, activate/deactivate accounts</small>
        </div>
        <div class="col-md-4 text-end">
            <span class="badge bg-success me-2">Active: @Model.ActiveUsers</span>
            <span class="badge bg-danger">Inactive: @Model.InactiveUsers</span>
        </div>
    </div>

    <!-- Filter Panel -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" id="filterForm" class="row g-3">
                <div class="col-md-4">
                    <label for="search" class="form-label">Search by Email, Name, or ID</label>
                    <input type="text" class="form-control" id="search" name="search" placeholder="Search..." value="@Model.SearchTerm">
                </div>
                <div class="col-md-3">
                    <label for="statusFilter" class="form-label">Status Filter</label>
                    <select class="form-select" id="statusFilter" name="statusFilter">
                        <option value="All" selected="@(Model.StatusFilter == "All")">All Users</option>
                        <option value="Active" selected="@(Model.StatusFilter == "Active")">Active Only</option>
                        <option value="Inactive" selected="@(Model.StatusFilter == "Inactive")">Inactive Only</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label for="roleFilter" class="form-label">Role Filter</label>
                    <select class="form-select" id="roleFilter" name="roleFilter">
                        <option value="">All Roles</option>
                        @foreach (var role in Model.AvailableRoles)
                        {
                            <option value="@role" selected="@(Model.RoleFilter == role)">@role</option>
                        }
                    </select>
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-search"></i> Filter
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- User Table -->
    <div class="card">
        <div class="table-responsive">
            @if (Model.Rows.Count > 0)
            {
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 5%;">Sr#</th>
                            <th style="width: 20%;">Email</th>
                            <th style="width: 15%;">Name</th>
                            <th style="width: 15%;">Roles</th>
                            <th style="width: 10%;">Status</th>
                            <th style="width: 15%;">Last Login</th>
                            <th style="width: 10%;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model.Rows)
                        {
                            <tr class="@(row.IsActive ? "" : "table-secondary")">
                                <td>@row.SerialNo</td>
                                <td>@row.Email</td>
                                <td>@row.FullName</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(row.RolesList))
                                    {
                                        @foreach (var role in row.RolesList.Split(", "))
                                        {
                                            <span class="badge bg-info">@role</span>
                                        }
                                    }
                                </td>
                                <td>
                                    @if (row.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Inactive</span>
                                    }
                                </td>
                                <td>
                                    @if (row.LastLoginDate.HasValue)
                                    {
                                        <small>@row.LastLoginDate.Value.ToString("MMM dd, yyyy hh:mm tt")</small>
                                    }
                                    else
                                    {
                                        <small class="text-muted">Never</small>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm" role="group">
                                        <button type="button" class="btn btn-outline-info" title="View Details" data-bs-toggle="modal" data-bs-target="#userDetailsModal" onclick="loadUserDetails('@row.UserId')">
                                            <i class="fas fa-eye"></i>
                                        </button>
                                        @if (Model.IsSuperAdminOrAdmin)
                                        {
                                            @if (row.IsActive)
                                            {
                                                <button type="button" class="btn btn-outline-danger" title="Deactivate User" onclick="deactivateUser('@row.UserId', '@row.Email')">
                                                    <i class="fas fa-ban"></i>
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="button" class="btn btn-outline-success" title="Activate User" onclick="activateUser('@row.UserId', '@row.Email')">
                                                    <i class="fas fa-check"></i>
                                                </button>
                                            }
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="alert alert-info m-4" role="alert">
                    <i class="fas fa-info-circle"></i> No users found matching your criteria.
                </div>
            }
        </div>
        <div class="card-footer text-muted small">
            Total Users: @Model.TotalUsers | Active: @Model.ActiveUsers | Inactive: @Model.InactiveUsers
        </div>
    </div>
</div>

<!-- User Details Modal -->
<div class="modal fade" id="userDetailsModal" tabindex="-1" aria-labelledby="userDetailsLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="userDetailsLabel">User Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="userDetailsContent">
                <div class="text-center">
                    <div class="spinner-border" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Password Reset Modal -->
<div class="modal fade" id="passwordResetModal" tabindex="-1" aria-labelledby="passwordResetLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="passwordResetLabel">User Activation & Password Reset</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>User has been activated. They must reset their password before logging in.</p>
                <div class="alert alert-info small">
                    <strong>Temporary Password:</strong><br>
                    <code id="tempPasswordText"></code>
                    <button class="btn btn-sm btn-outline-secondary" onclick="copyToClipboard('tempPasswordText')">Copy</button>
                </div>
                <p>
                    <strong>Password Reset Link:</strong><br>
                    <input type="text" class="form-control" id="resetLinkText" readonly>
                    <button class="btn btn-sm btn-outline-secondary mt-2" onclick="copyToClipboard('resetLinkText')">Copy Link</button>
                </p>
                <p class="text-muted small">
                    <i class="fas fa-info-circle"></i> Share this password reset link with the user, or send it via email.
                </p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function loadUserDetails(userId) {
            $.get(`/SystemManagement/UserDetails?userId=${userId}`, function (data) {
                $('#userDetailsContent').html(data);
            }).fail(function () {
                $('#userDetailsContent').html('<div class="alert alert-danger">Failed to load user details.</div>');
            });
        }

        function deactivateUser(userId, email) {
            if (confirm(`Deactivate user ${email}? They will not be able to log in.`)) {
                $.post('/SystemManagement/MarkUserInactive', { userId: userId }, function (response) {
                    if (response.success) {
                        showAlert(response.message, 'success');
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        showAlert(response.message || 'Failed to deactivate user.', 'danger');
                    }
                }).fail(function () {
                    showAlert('Error occurred. Please try again.', 'danger');
                });
            }
        }

        function activateUser(userId, email) {
            if (confirm(`Activate user ${email}? They will need to reset their password before logging in.`)) {
                $.post('/SystemManagement/MarkUserActive', { userId: userId }, function (response) {
                    if (response.success) {
                        showAlert('User activated. Showing password reset details...', 'success');
                        $('#tempPasswordText').text(response.tempPassword);
                        const baseUrl = window.location.origin;
                        const resetLink = `${baseUrl}/Account/ResetPassword?code=${response.resetCode}`;
                        $('#resetLinkText').val(resetLink);
                        var modal = new bootstrap.Modal(document.getElementById('passwordResetModal'), {});
                        modal.show();
                        setTimeout(() => location.reload(), 3000);
                    } else {
                        showAlert(response.message || 'Failed to activate user.', 'danger');
                    }
                }).fail(function () {
                    showAlert('Error occurred. Please try again.', 'danger');
                });
            }
        }

        function copyToClipboard(elementId) {
            const text = document.getElementById(elementId).textContent || document.getElementById(elementId).value;
            navigator.clipboard.writeText(text).then(() => {
                showAlert('Copied to clipboard!', 'info');
            });
        }

        function showAlert(message, type) {
            const alertHtml = `<div class="alert alert-${type} alert-dismissible fade show" role="alert">
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>`;
            $(alertHtml).prependTo('.container-fluid').delay(5000).fadeOut(() => $(this).remove());
        }
    </script>
}
