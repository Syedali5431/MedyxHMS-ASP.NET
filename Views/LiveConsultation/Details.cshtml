@model MedyxHMS.Models.LiveConsultationSession
@{
    ViewData["Title"] = "Session Details";
    var statusBadge = Model.Status switch
    {
        "InProgress" => "bg-warning text-dark",
        "Completed"  => "bg-success",
        "Cancelled"  => "bg-danger",
        _            => "bg-secondary"
    };
}

<div class="container mt-3" style="max-width:680px">
    <div class="d-flex align-items-center mb-3 gap-2">
        <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
            <i class="fas fa-arrow-left me-1"></i>All Sessions
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">@TempData["SuccessMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <div>
                <h5 class="mb-0">@Model.DoctorName &amp; @Model.PatientName</h5>
                <small class="text-muted">@Model.ScheduledAt.ToLocalTime().ToString("dddd, MMMM dd, yyyy 'at' HH:mm")</small>
            </div>
            <span class="badge @statusBadge fs-6">@Model.Status</span>
        </div>
        <div class="card-body">
            <div class="row mb-2">
                <div class="col-4 fw-semibold text-muted">Platform</div>
                <div class="col-8">@Model.Platform</div>
            </div>
            <div class="row mb-2">
                <div class="col-4 fw-semibold text-muted">Duration</div>
                <div class="col-8">@Model.DurationMinutes minutes</div>
            </div>
            @if (!string.IsNullOrEmpty(Model.MeetingId))
            {
                <div class="row mb-2">
                    <div class="col-4 fw-semibold text-muted">Meeting ID</div>
                    <div class="col-8"><code>@Model.MeetingId</code></div>
                </div>
            }
            @if (!string.IsNullOrEmpty(Model.MeetingPassword))
            {
                <div class="row mb-2">
                    <div class="col-4 fw-semibold text-muted">Password</div>
                    <div class="col-8"><code>@Model.MeetingPassword</code></div>
                </div>
            }
            @if (!string.IsNullOrEmpty(Model.Notes))
            {
                <div class="row mb-3">
                    <div class="col-4 fw-semibold text-muted">Notes</div>
                    <div class="col-8">@Model.Notes</div>
                </div>
            }

            @if (Model.Status == "Scheduled" || Model.Status == "InProgress")
            {
                <a href="@Model.MeetingLink" target="_blank" class="btn btn-success me-2">
                    <i class="fas fa-video me-1"></i>Join Meeting
                </a>
            }
        </div>
        <div class="card-footer bg-transparent">
            <div class="d-flex gap-2 flex-wrap">
                @if (Model.Status != "Cancelled" && Model.Status != "Completed")
                {
                    <form asp-action="UpdateStatus" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <input type="hidden" name="status" value="InProgress" />
                        <button type="submit" class="btn btn-warning btn-sm">Mark In Progress</button>
                    </form>
                    <form asp-action="UpdateStatus" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <input type="hidden" name="status" value="Completed" />
                        <button type="submit" class="btn btn-success btn-sm">Mark Completed</button>
                    </form>
                    <form asp-action="Cancel" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Cancel this session?')">Cancel Session</button>
                    </form>
                }
            </div>
        </div>
    </div>
</div>
