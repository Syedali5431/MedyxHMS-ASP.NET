@model IEnumerable<MedyxHMS.Models.TpaClaim>
@{
    ViewData["Title"] = "TPA Claims";
}

<div class="container-fluid mt-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h4 class="mb-0"><i class="fas fa-file-invoice text-primary me-2"></i>TPA Claims</h4>
            <small class="text-muted">Insurance claim tracking &amp; settlement</small>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Providers</a>
            <a asp-action="CreateClaim" class="btn btn-primary btn-sm">
                <i class="fas fa-plus me-1"></i>New Claim
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">@TempData["SuccessMessage"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
    }

    <div class="card shadow-sm">
        <div class="card-body table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Claim #</th>
                        <th>TPA Provider</th>
                        <th>Patient</th>
                        <th>Claim Date</th>
                        <th>Claimed</th>
                        <th>Approved</th>
                        <th>Settled</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model)
                    {
                        var statusBadge = c.Status switch
                        {
                            "Approved" => "bg-success",
                            "Rejected" => "bg-danger",
                            "Settled"  => "bg-primary",
                            _          => "bg-warning text-dark"
                        };
                        <tr>
                            <td><code>@c.ClaimNumber</code></td>
                            <td>@c.TpaProvider?.Name</td>
                            <td>@(c.Patient != null ? $"{c.Patient.FirstName} {c.Patient.LastName}" : c.PatientId.ToString())</td>
                            <td>@c.ClaimDate.ToString("MMM dd, yyyy")</td>
                            <td class="text-end">@c.ClaimedAmount.ToString("N2")</td>
                            <td class="text-end">@(c.ApprovedAmount.HasValue ? c.ApprovedAmount.Value.ToString("N2") : "-")</td>
                            <td class="text-end">@(c.SettledAmount.HasValue ? c.SettledAmount.Value.ToString("N2") : "-")</td>
                            <td><span class="badge @statusBadge">@c.Status</span></td>
                            <td>
                                <form asp-action="UpdateClaimStatus" method="post" class="d-flex gap-1 align-items-center">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@c.Id" />
                                    <select name="status" class="form-select form-select-sm" style="width:120px">
                                        <option value="Pending" selected="@(c.Status=="Pending")">Pending</option>
                                        <option value="Approved" selected="@(c.Status=="Approved")">Approved</option>
                                        <option value="Rejected" selected="@(c.Status=="Rejected")">Rejected</option>
                                        <option value="Settled" selected="@(c.Status=="Settled")">Settled</option>
                                    </select>
                                    <input name="approvedAmount" type="number" step="0.01" class="form-control form-control-sm" style="width:110px" value="@c.ApprovedAmount" placeholder="Approved" />
                                    <input name="settledAmount" type="number" step="0.01" class="form-control form-control-sm" style="width:110px" value="@c.SettledAmount" placeholder="Settled" />
                                    <button type="submit" class="btn btn-sm btn-outline-primary">Update</button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="9" class="text-center text-muted py-4">No TPA claims found.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
