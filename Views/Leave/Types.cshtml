@model LeaveTypeViewModel
@{
    ViewData["Title"] = "Leave Types";
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Leave Types</h2>
        <a class="btn btn-secondary" asp-action="Index">Back to Leave Requests</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="row">
        <div class="col-md-5">
            <div class="card mb-4">
                <div class="card-header"><strong>Create Leave Type</strong></div>
                <div class="card-body">
                    <form method="post" asp-action="CreateType">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label">Name</label>
                            <input asp-for="NewLeaveType.Name" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <input asp-for="NewLeaveType.Description" class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Default Days Per Year</label>
                            <input asp-for="NewLeaveType.DefaultDaysPerYear" type="number" min="0" class="form-control" required />
                        </div>
                        <div class="form-check mb-3">
                            <input asp-for="NewLeaveType.IsActive" class="form-check-input" />
                            <label class="form-check-label">Active</label>
                        </div>
                        <button class="btn btn-primary" type="submit">Create</button>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-md-7">
            <div class="card">
                <div class="card-header"><strong>Existing Leave Types</strong></div>
                <div class="card-body table-responsive">
                    <table class="table table-striped table-bordered">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Description</th>
                                <th>Days/Year</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.LeaveTypes.Any())
                            {
                                @foreach (var item in Model.LeaveTypes)
                                {
                                    <tr>
                                        <td>@item.Name</td>
                                        <td>@item.Description</td>
                                        <td>@item.DefaultDaysPerYear</td>
                                        <td>
                                            <span class="badge @(item.IsActive ? "bg-success" : "bg-secondary")">
                                                @(item.IsActive ? "Active" : "Inactive")
                                            </span>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted">No leave types configured.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
