@model GenerateCertificateViewModel
@{
    ViewData["Title"] = "Generate Certificate";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Generate Certificate</h2>
        <a class="btn btn-secondary" asp-action="Index">Back</a>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="card">
        <div class="card-body">
            <form method="post" asp-action="GenerateCertificate">
                @Html.AntiForgeryToken()
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Staff</label>
                        <select asp-for="Certificate.StaffId" class="form-select" required>
                            <option value="">Select staff</option>
                            @foreach (var s in Model.StaffOptions)
                            {
                                <option value="@s.Id">@s.FirstName @s.LastName (@s.EmployeeId)</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3"><label class="form-label">Type</label><input asp-for="Certificate.CertificateType" class="form-control" placeholder="Experience" required /></div>
                    <div class="col-md-3"><label class="form-label">Issue Date</label><input asp-for="Certificate.IssueDate" type="date" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")" /></div>
                    <div class="col-md-12"><label class="form-label">Title</label><input asp-for="Certificate.Title" class="form-control" required /></div>
                    <div class="col-md-12"><label class="form-label">Content</label><textarea asp-for="Certificate.Content" class="form-control" rows="4"></textarea></div>
                </div>
                <div class="mt-3">
                    <button class="btn btn-primary" type="submit">Generate</button>
                </div>
            </form>
        </div>
    </div>
</div>
