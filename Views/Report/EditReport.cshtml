@model MedyxHMS.Models.GeneratedReport

@{
    ViewData["Title"] = "Edit Generated Report";
}

<div class="container-fluid mt-4">
    <div class="card">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0"><i class="fas fa-edit me-2"></i>Edit Generated Report</h4>
        </div>
        <div class="card-body">
            <form asp-action="EditReport" method="post">
                @Html.AntiForgeryToken()
                <input asp-for="Id" type="hidden" />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="ReportName" class="form-label"></label>
                        <input asp-for="ReportName" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="ReportType" class="form-label"></label>
                        <input asp-for="ReportType" class="form-control" />
                    </div>
                    <div class="col-12">
                        <label asp-for="Description" class="form-label"></label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="FromDate" class="form-label"></label>
                        <input asp-for="FromDate" type="date" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="ToDate" class="form-label"></label>
                        <input asp-for="ToDate" type="date" class="form-control" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="DepartmentId" class="form-label"></label>
                        <input asp-for="DepartmentId" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="FileFormat" class="form-label"></label>
                        <select asp-for="FileFormat" class="form-select">
                            <option>PDF</option>
                            <option>Excel</option>
                            <option>HTML</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Status" class="form-label"></label>
                        <select asp-for="Status" class="form-select">
                            <option>Available</option>
                            <option>Archived</option>
                            <option>Deleted</option>
                        </select>
                    </div>
                </div>

                <div class="mt-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                    <a asp-action="GeneratedReports" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
