@model MedyxHMS.Models.InternalMessage
@{
    ViewData["Title"] = "Compose Message";
}

<div class="container mt-3">
    <h4><i class="fas fa-pen text-primary me-2"></i>Compose Message</h4>
    <div class="card mt-3 shadow-sm" style="max-width:640px">
        <div class="card-body">
            <form asp-action="Compose" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ParentMessageId" />
                <div class="mb-3">
                    <label class="form-label fw-semibold">To <span class="text-danger">*</span></label>
                    <select asp-for="RecipientId" class="form-select">
                        <option value="">-- Select recipient --</option>
                        @foreach (var s in ViewBag.Staff)
                        {
                            <option value="@s.Id">@s.UserName (@s.Email)</option>
                        }
                    </select>
                    <span asp-validation-for="RecipientId" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Subject <span class="text-danger">*</span></label>
                    <input asp-for="Subject" class="form-control" />
                    <span asp-validation-for="Subject" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Message <span class="text-danger">*</span></label>
                    <textarea asp-for="Body" class="form-control" rows="6"></textarea>
                    <span asp-validation-for="Body" class="text-danger small"></span>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-paper-plane me-1"></i>Send
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
