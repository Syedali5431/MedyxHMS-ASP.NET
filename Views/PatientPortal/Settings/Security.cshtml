@model PatientPortalSecuritySettingsViewModel
@{
    ViewData["Title"] = "Security Settings";
    Layout = "~/Views/PatientPortal/Shared/_Layout.cshtml";
}

<div class="py-4">
    <h3 class="mb-4"><i class="fas fa-lock me-2"></i>Security Settings</h3>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header bg-light">
                    <h6 class="mb-0">Two-Factor Authentication</h6>
                </div>
                <div class="card-body">
                    @if (Model.TwoFactorEnabled)
                    {
                        <p class="text-success mb-3"><i class="fas fa-check-circle me-1"></i>Enabled</p>
                    }
                    else
                    {
                        <p class="text-warning mb-3"><i class="fas fa-exclamation-triangle me-1"></i>Disabled</p>
                    }

                    <form asp-action="EnableTwoFactor" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-primary">
                            <i class="fas fa-shield-alt me-1"></i>
                            @(Model.TwoFactorEnabled ? "Reconfigure 2FA" : "Enable 2FA")
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header bg-light">
                    <h6 class="mb-0">Session & Password</h6>
                </div>
                <div class="card-body">
                    <p class="mb-2"><strong>Last Password Change:</strong> @Model.LastPasswordChange.ToString("MMM dd, yyyy")</p>
                    <p class="mb-3"><strong>Active Sessions:</strong> @Model.ActiveSessions</p>
                    <a asp-controller="Dashboard" asp-action="ChangePassword" class="btn btn-outline-secondary">
                        <i class="fas fa-key me-1"></i>Change Password
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-4 d-flex gap-2">
        <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left me-1"></i>Back to Settings</a>
        <a asp-action="Privacy" class="btn btn-outline-secondary"><i class="fas fa-user-shield me-1"></i>Privacy</a>
    </div>
</div>
