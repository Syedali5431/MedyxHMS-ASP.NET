@model LeaveRequestCreateViewModel
@{
    ViewData["Title"] = "Leave Request";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Submit Leave Request</h2>
        <a class="btn btn-secondary" asp-action="Index">Back</a>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="card">
        <div class="card-body">
            <form method="post" asp-action="Request">
                @Html.AntiForgeryToken()
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Staff</label>
                        <select asp-for="LeaveRequest.StaffId" class="form-select" required>
                            <option value="">Select staff</option>
                            @foreach (var s in Model.StaffOptions)
                            {
                                <option value="@s.Id">@s.FirstName @s.LastName (@s.EmployeeId)</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Leave Type</label>
                        <select asp-for="LeaveRequest.LeaveTypeId" class="form-select" required>
                            <option value="">Select leave type</option>
                            @foreach (var t in Model.LeaveTypes)
                            {
                                <option value="@t.Id">@t.Name (@t.DefaultDaysPerYear days/year)</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Start Date</label>
                        <input asp-for="LeaveRequest.StartDate" type="date" class="form-control" value="@Model.LeaveRequest.StartDate.ToString("yyyy-MM-dd")" required />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">End Date</label>
                        <input asp-for="LeaveRequest.EndDate" type="date" class="form-control" value="@Model.LeaveRequest.EndDate.ToString("yyyy-MM-dd")" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Reason</label>
                        <input asp-for="LeaveRequest.Reason" class="form-control" required />
                    </div>
                </div>

                <div class="mt-3">
                    <button class="btn btn-primary" type="submit">Submit Request</button>
                </div>
            </form>
        </div>
    </div>
</div>
