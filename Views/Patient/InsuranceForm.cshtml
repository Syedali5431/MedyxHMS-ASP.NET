@model MedyxHMS.Models.PatientInsurance
@{
    ViewData["Title"] = "Add Insurance";
    bool isEdit = Model.Id > 0;
}

<div class="container-fluid">
    <div class="row">
        <div class="col-md-7 mx-auto">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="fas fa-shield-alt me-2"></i>@(isEdit ? "Edit" : "Add") Insurance — @ViewBag.PatientName</h5>
                </div>
                <div class="card-body">
                    <form asp-action="@(isEdit ? "InsuranceEdit" : "InsuranceCreate")" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="PatientId" />

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="ProviderName" class="form-label"></label>
                                <input asp-for="ProviderName" class="form-control" />
                                <span asp-validation-for="ProviderName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="PolicyNumber" class="form-label"></label>
                                <input asp-for="PolicyNumber" class="form-control" />
                                <span asp-validation-for="PolicyNumber" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="InsurancePlan" class="form-label"></label>
                                <input asp-for="InsurancePlan" class="form-control" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="HolderName" class="form-label"></label>
                                <input asp-for="HolderName" class="form-control" />
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <label asp-for="ValidFrom" class="form-label"></label>
                                <input asp-for="ValidFrom" type="date" class="form-control" />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label asp-for="ValidTo" class="form-label"></label>
                                <input asp-for="ValidTo" type="date" class="form-control" />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label asp-for="ContactNumber" class="form-label"></label>
                                <input asp-for="ContactNumber" type="tel" class="form-control" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                        </div>
                        <div class="mb-3 form-check">
                            <input asp-for="IsActive" class="form-check-input" />
                            <label asp-for="IsActive" class="form-check-label">Active</label>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="InsuranceList" asp-route-patientId="@Model.PatientId" class="btn btn-secondary">Cancel</a>
                            <button type="submit" class="btn btn-primary"><i class="fas fa-save me-1"></i>Save</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
