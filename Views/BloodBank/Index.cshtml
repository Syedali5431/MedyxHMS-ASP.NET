@model IEnumerable<BloodInventory>
@{
    ViewData["Title"] = "Blood Bank";
    var issues = ViewBag.Issues as IEnumerable<BloodIssue> ?? Enumerable.Empty<BloodIssue>();
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Blood Bank</h2>
        <a class="btn btn-primary" asp-action="Issue">Issue Blood</a>
    </div>

    @* Blood Group Filter *@
    <form method="get" asp-action="Index" class="row g-2 mb-3">
        <div class="col-auto">
            <select name="bloodGroup" class="form-select form-select-sm" onchange="this.form.submit()">
                <option value="">All Blood Groups</option>
                @foreach (var bg in new[] { "A+", "A-", "B+", "B-", "AB+", "AB-", "O+", "O-" })
                {
                    <option value="@bg" selected="@(ViewBag.FilterBloodGroup == bg ? "selected" : null)">@bg</option>
                }
            </select>
        </div>
        @if (!string.IsNullOrEmpty(ViewBag.FilterBloodGroup as string))
        {
            <div class="col-auto">
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary">Clear</a>
            </div>
        }
    </form>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
    }

    <div class="card mb-4">
        <div class="card-header"><strong>Inventory</strong></div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered">
                    <thead>
                        <tr>
                            <th>Blood Group</th>
                            <th>Units Available</th>
                            <th>Reserved</th>
                            <th>Minimum Level</th>
                            <th>Last Updated</th>
                            <th>Update</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.BloodGroup</td>
                                <td class="@(item.UnitsAvailable <= item.MinimumLevel ? "text-danger fw-bold" : "")">@item.UnitsAvailable</td>
                                <td>@item.UnitsReserved</td>
                                <td>@item.MinimumLevel</td>
                                <td>@item.LastUpdatedDate.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</td>
                                <td>
                                    <form method="post" asp-action="UpdateInventory" class="d-flex gap-2">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="bloodGroup" value="@item.BloodGroup" />
                                        <input class="form-control form-control-sm" type="number" name="unitsAvailable" value="@item.UnitsAvailable" min="0" />
                                        <input class="form-control form-control-sm" type="number" name="minimumLevel" value="@item.MinimumLevel" min="0" />
                                        <button class="btn btn-sm btn-outline-primary" type="submit">Save</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header"><strong>Recent Blood Issues</strong></div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Patient</th>
                            <th>Group</th>
                            <th>Units</th>
                            <th>Cross Match</th>
                            <th>Bill</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var issue in issues)
                        {
                            <tr>
                                <td>@issue.IssueDate.ToLocalTime().ToString("MMM dd, yyyy HH:mm")</td>
                                <td>@issue.Patient?.FirstName @issue.Patient?.LastName</td>
                                <td>@issue.BloodGroup</td>
                                <td>@issue.UnitsIssued</td>
                                <td>@issue.CrossMatchStatus</td>
                                <td>@(issue.BillId.HasValue ? issue.BillId.Value.ToString() : "-")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Charts Row -->
    <div class="row mb-4">
        <div class="col-lg-6 mb-4">
            <div class="card shadow">
                <div class="card-header py-3"><h6 class="m-0 font-weight-bold text-danger">Blood Group Inventory</h6></div>
                <div class="card-body"><canvas id="bloodInventoryChart" height="260"></canvas></div>
            </div>
        </div>
        <div class="col-lg-6 mb-4">
            <div class="card shadow">
                <div class="card-header py-3"><h6 class="m-0 font-weight-bold text-info">Blood Issues by Group</h6></div>
                <div class="card-body"><canvas id="bloodIssueChart" height="260"></canvas></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function() {
            var inventory = @Html.Raw(Json.Serialize(Model));
            var issues = @Html.Raw(Json.Serialize(ViewBag.Issues as IEnumerable<dynamic> ?? new dynamic[0]));
            var invLabels = inventory.map(function(i) { return i.bloodGroup; });
            var invData = inventory.map(function(i) { return i.unitsAvailable; });
            var issueCounts = {};
            @{
                var bbIssues = ViewBag.Issues as IEnumerable<MedyxHMS.Models.BloodIssue>;
                if (bbIssues != null)
                {
                    <text>var issuesList = @Html.Raw(Json.Serialize(bbIssues.GroupBy(i => i.BloodGroup).Select(g => new { group = g.Key, count = g.Count() })));
                    issuesList.forEach(function(i) { issueCounts[i.group] = i.count; });</text>
                }
            }
            new Chart(document.getElementById('bloodInventoryChart'), {
                type: 'bar',
                data: { labels: invLabels, datasets: [{ label: 'Units', data: invData, backgroundColor: '#e74a3b' }] },
                options: { responsive: true, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } } }
            });
            new Chart(document.getElementById('bloodIssueChart'), {
                type: 'doughnut',
                data: { labels: Object.keys(issueCounts).length > 0 ? Object.keys(issueCounts) : invLabels, datasets: [{ data: Object.keys(issueCounts).length > 0 ? Object.values(issueCounts) : invData.map(function() { return 0; }), backgroundColor: ['#4e73df','#1cc88a','#f6c23e','#e74a3b','#36b9cc','#858796','#fd7e14','#6610f2'], borderWidth: 2 }] },
                options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
            });
        })();
    </script>
}
