@model MedyxHMS.ViewModels.PatientIndexViewModel

@{
    ViewData["Title"] = "Patient Management";
}

<div class="container-fluid">
    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="h3 mb-0 text-gray-800">Patient Management</h1>
                    <p class="text-muted">Manage patient records and information</p>
                </div>
                <div>
                    @if (User.HasPermission("Patient", "Add"))
                    {
                        <a href="@Url.Action("Create", "Patient")" class="btn btn-primary">
                            <i class="fas fa-plus"></i> Add New Patient
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="row mb-4">
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-primary shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">
                                Total Patients
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.TotalPatients</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-users fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-success shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-success text-uppercase mb-1">
                                Active Patients
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.ActivePatients</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-user-check fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-warning shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">
                                Inactive Patients
                            </div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.InactivePatients</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-user-times fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Search and Filters -->
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <h6 class="m-0 font-weight-bold text-primary">Patient Records</h6>
                </div>
                <div class="col-md-6">
                    <form method="get" class="d-flex">
                        <input type="text" name="searchTerm" value="@Model.SearchTerm"
                               class="form-control" placeholder="Search by name, email, phone, or patient ID..."
                               autocomplete="off">
                        <button type="submit" class="btn btn-outline-primary ml-2">
                            <i class="fas fa-search"></i> Search
                        </button>
                        @if (!string.IsNullOrEmpty(Model.SearchTerm))
                        {
                            <a href="@Url.Action("Index", "Patient")" class="btn btn-outline-secondary ml-2">
                                <i class="fas fa-times"></i> Clear
                            </a>
                        }
                    </form>
                </div>
                <div class="col-12 mt-2 text-end">
                    <a href="@Url.Action("Export", "Patient", new { format = "csv", searchTerm = Model.SearchTerm })" class="btn btn-outline-primary btn-sm">
                        <i class="fas fa-file-csv"></i> Export CSV
                    </a>
                    <a href="@Url.Action("Export", "Patient", new { format = "pdf", searchTerm = Model.SearchTerm })" class="btn btn-outline-danger btn-sm ml-2">
                        <i class="fas fa-file-pdf"></i> Export PDF
                    </a>
                </div>
            </div>
        </div>

        <div class="card-body">
            @if (!Model.Patients.Any())
            {
                <div class="text-center py-5">
                    <i class="fas fa-users fa-3x text-gray-300 mb-3"></i>
                    <h5 class="text-gray-500">No patients found</h5>
                    @if (!string.IsNullOrEmpty(Model.SearchTerm))
                    {
                        <p class="text-muted">Try adjusting your search criteria or <a href="@Url.Action("Index", "Patient")">clear the search</a>.</p>
                    }
                    else
                    {
                        <p class="text-muted">Start by <a href="@Url.Action("Create", "Patient")">adding your first patient</a>.</p>
                    }
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-bordered" id="dataTable" width="100%" cellspacing="0">
                        <thead>
                            <tr>
                                <th>Patient ID</th>
                                <th>Name</th>
                                <th>Age/Gender</th>
                                <th>Contact</th>
                                <th>Blood Group</th>
                                <th>Status</th>
                                <th>Created</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var patient in Model.Patients)
                            {
                                <tr>
                                    <td>
                                        <span class="badge badge-info">@patient.PatientId</span>
                                    </td>
                                    <td>
                                        <strong>@patient.FullName</strong>
                                        @if (patient.LastVisitDate.HasValue)
                                        {
                                            <br><small class="text-muted">Last visit: @patient.LastVisitDate.Value.ToString("MMM dd, yyyy")</small>
                                        }
                                    </td>
                                    <td>
                                        @patient.Age years<br>
                                        <small class="text-muted">@patient.Gender</small>
                                    </td>
                                    <td>
                                        <i class="fas fa-envelope text-primary"></i> @patient.Email<br>
                                        <i class="fas fa-phone text-success"></i> @patient.Phone
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(patient.BloodGroup))
                                        {
                                            <span class="badge badge-danger">@patient.BloodGroup</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        @if (patient.IsActive)
                                        {
                                            <span class="badge badge-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-secondary">Inactive</span>
                                        }
                                    </td>
                                    <td>
                                        @patient.CreatedDate.ToString("MMM dd, yyyy")
                                    </td>
                                    <td>
                                        <div class="btn-group" role="group">
                                            @if (User.HasPermission("Patient", "View"))
                                            {
                                                <a href="@Url.Action("Details", "Patient", new { id = patient.Id })"
                                                   class="btn btn-sm btn-info" title="View Details">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                            }
                                            @if (User.HasPermission("Patient", "Edit"))
                                            {
                                                <a href="@Url.Action("Edit", "Patient", new { id = patient.Id })"
                                                   class="btn btn-sm btn-warning" title="Edit Patient">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                            }
                                            @if (User.HasPermission("Patient", "Delete"))
                                            {
                                                <a href="@Url.Action("Delete", "Patient", new { id = patient.Id })"
                                                   class="btn btn-sm btn-danger" title="Delete Patient">
                                                    <i class="fas fa-trash"></i>
                                                </a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Add any client-side functionality here
        $(document).ready(function() {
            // Initialize DataTable only when plugin is available.
            if ($.fn && $.fn.DataTable) {
                $('#dataTable').DataTable({
                    "pageLength": 25,
                    "order": [[ 6, "desc" ]] // Sort by created date descending
                });
            }
        });
    </script>
}