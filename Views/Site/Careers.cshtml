@model MedyxHMS.ViewModels.SiteCareersViewModel
@{
    ViewData["Title"] = "Careers";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
    ViewBag.MenuItems = Model.MenuItems;
}

<div class="container my-5">
    <h1 class="mb-3">Careers</h1>
    <div class="card shadow-sm border-0">
        <div class="card-body">
            <p class="mb-4">@Model.CareersContent</p>
            <p class="mb-0"><strong>Apply by email:</strong> @Model.ContactEmail</p>
        </div>
    </div>
</div>
