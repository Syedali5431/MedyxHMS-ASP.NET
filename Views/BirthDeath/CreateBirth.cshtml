@model MedyxHMS.Models.BirthRecord
@{
    ViewData["Title"] = "New Birth Record";
}

<div class="container mt-3">
    <h4><i class="fas fa-baby text-info me-2"></i>New Birth Record</h4>
    <div class="card mt-3 shadow-sm" style="max-width:700px">
        <div class="card-body">
            <form asp-action="CreateBirth" method="post">
                @Html.AntiForgeryToken()
                <div class="row g-3 mb-3">
                    <div class="col-6">
                        <label class="form-label fw-semibold">Baby Name <span class="text-danger">*</span></label>
                        <input asp-for="BabyName" class="form-control" />
                        <span asp-validation-for="BabyName" class="text-danger small"></span>
                    </div>
                    <div class="col-3">
                        <label class="form-label fw-semibold">Gender <span class="text-danger">*</span></label>
                        <select asp-for="Gender" class="form-select">
                            <option>Male</option>
                            <option>Female</option>
                            <option>Other</option>
                        </select>
                    </div>
                    <div class="col-3">
                        <label class="form-label fw-semibold">Weight (kg)</label>
                        <input asp-for="WeightKg" type="number" step="0.01" class="form-control" />
                    </div>
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-6">
                        <label class="form-label fw-semibold">Date of Birth <span class="text-danger">*</span></label>
                        <input asp-for="DateOfBirth" type="date" class="form-control" />
                        <span asp-validation-for="DateOfBirth" class="text-danger small"></span>
                    </div>
                    <div class="col-6">
                        <label class="form-label fw-semibold">Time of Birth</label>
                        <input asp-for="TimeOfBirth" type="time" class="form-control" />
                    </div>
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-6">
                        <label class="form-label fw-semibold">Mother's Name <span class="text-danger">*</span></label>
                        <input asp-for="MotherName" class="form-control" />
                        <span asp-validation-for="MotherName" class="text-danger small"></span>
                    </div>
                    <div class="col-6">
                        <label class="form-label fw-semibold">Father's Name</label>
                        <input asp-for="FatherName" class="form-control" />
                    </div>
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-6">
                        <label class="form-label fw-semibold">Guardian Contact</label>
                        <input asp-for="GuardianContact" class="form-control" />
                    </div>
                    <div class="col-6">
                        <label class="form-label fw-semibold">Delivery Type</label>
                        <select asp-for="DeliveryType" class="form-select">
                            <option>Normal</option>
                            <option>C-Section</option>
                        </select>
                    </div>
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-6">
                        <label class="form-label fw-semibold">Attending Doctor</label>
                        <input asp-for="AttendingDoctorName" class="form-control" />
                    </div>
                    <div class="col-6">
                        <label class="form-label fw-semibold">Certificate Issued</label>
                        <div class="form-check mt-2">
                            <input asp-for="CertificateIssued" type="checkbox" class="form-check-input" id="certIssued" />
                            <label class="form-check-label" for="certIssued">Yes, issue certificate</label>
                        </div>
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Notes</label>
                    <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Save Birth Record</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
