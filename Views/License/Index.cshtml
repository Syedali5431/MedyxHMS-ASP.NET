@model MedyxHMS.ViewModels.LicenseManagementViewModel
@{
    ViewData["Title"] = "License Management";
    var hasModulus = !string.IsNullOrWhiteSpace(Model.PublicKeyModulusHex);
    var hasExponent = !string.IsNullOrWhiteSpace(Model.PublicKeyExponentHex);
    var hasVerificationKey = !string.IsNullOrWhiteSpace(Model.VerificationKey);
    var keyState = hasModulus && hasExponent && hasVerificationKey ? "Ready" : "Consumed / Missing";
    var keyStateClass = hasModulus && hasExponent && hasVerificationKey ? "bg-success" : "bg-secondary";
}

<div class="row mb-4">
    <div class="col-12 d-flex justify-content-between align-items-center">
        <div>
            <h1 class="h3 mb-1">License Management</h1>
            <p class="text-muted mb-0">SuperAdmin-only renewal, expiry visibility, and reminder controls.</p>
        </div>
        <span class="badge bg-@(Model.Snapshot.State == MedyxHMS.Models.LicenseState.Expired ? "danger" : Model.Snapshot.State == MedyxHMS.Models.LicenseState.ExpiringSoon ? "warning text-dark" : "success") fs-6">
            @Model.Snapshot.State
        </span>
    </div>
</div>

@if (TempData["SuccessMessage"] is string successMessage)
{
    <div class="alert alert-success">@successMessage</div>
}

@if (TempData["ErrorMessage"] is string errorMessage)
{
    <div class="alert alert-danger">@errorMessage</div>
}

<div class="row g-4">
    <div class="col-lg-5">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h2 class="h5">Current License</h2>
                <dl class="row mb-0">
                    <dt class="col-sm-5">Reference</dt>
                    <dd class="col-sm-7">@Model.Snapshot.License.LicenseReference</dd>
                    <dt class="col-sm-5">Tenant ID</dt>
                    <dd class="col-sm-7">@Model.Snapshot.License.TenantId</dd>
                    <dt class="col-sm-5">Expiry</dt>
                    <dd class="col-sm-7">@Model.Snapshot.License.ExpiresAtUtc.ToString("yyyy-MM-dd")</dd>
                    <dt class="col-sm-5">Days Remaining</dt>
                    <dd class="col-sm-7">@Model.Snapshot.DaysRemaining</dd>
                    <dt class="col-sm-5">Max Concurrent Users</dt>
                    <dd class="col-sm-7">@Model.Snapshot.License.MaxConcurrentUsers</dd>
                    <dt class="col-sm-5">Signature Valid</dt>
                    <dd class="col-sm-7">@(Model.Snapshot.License.IsSignatureValid ? "Yes" : "No")</dd>
                    <dt class="col-sm-5">Reminder Due</dt>
                    <dd class="col-sm-7">@(Model.Snapshot.ReminderDue ? "Yes" : "No")</dd>
                    <dt class="col-sm-5">SuperAdmin Contact</dt>
                    <dd class="col-sm-7">@Model.Snapshot.SuperAdminContact</dd>
                    <dt class="col-sm-5">Billing Contact</dt>
                    <dd class="col-sm-7">@Model.Snapshot.BillingContact</dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h2 class="h5">Public Key Verification Settings</h2>
                <p class="mb-2">
                    <span class="badge @keyStateClass">Upload Key State: @keyState</span>
                </p>
                <form asp-action="SavePublicKey" method="post" class="mt-3">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label asp-for="PublicKeyModulusHex" class="form-label"></label>
                        <textarea asp-for="PublicKeyModulusHex" class="form-control" rows="4" spellcheck="false" placeholder="Paste RSA modulus hex from MedyxHMS-Lic public key file."></textarea>
                    </div>
                    <div class="mb-3">
                        <label asp-for="PublicKeyExponentHex" class="form-label"></label>
                        <input asp-for="PublicKeyExponentHex" class="form-control" spellcheck="false" placeholder="Usually 010001" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="VerificationKey" class="form-label"></label>
                        <input asp-for="VerificationKey" class="form-control" readonly />
                        <div class="form-text">Generated from modulus and exponent. Signed license files must carry this exact key.</div>
                    </div>
                    <button type="submit" class="btn btn-outline-primary">Save Verification Key</button>
                </form>

                <p class="text-muted small mt-2 mb-0">
                    Only vendor-side MedyxHMS-Lic should hold the private key. This application stores only public key components for signature verification.
                </p>

                <hr />

                <h2 class="h5">Upload Signed License (.lic)</h2>
                <form asp-action="Upload" method="post" enctype="multipart/form-data" class="mt-3">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label for="licenseFile" class="form-label">Signed License File</label>
                        <input type="file" id="licenseFile" name="licenseFile" class="form-control" accept=".lic" required />
                    </div>
                    <div class="mb-3">
                        <label for="publicKeyFile" class="form-label">Public Key File (.json) (Optional for key rotation)</label>
                        <input type="file" id="publicKeyFile" name="publicKeyFile" class="form-control" accept=".json" />
                        <div class="form-text">If this license was signed with a new keypair, upload the matching public key JSON to rotate keys automatically.</div>
                    </div>
                    <button type="submit" class="btn btn-success">Validate and Activate</button>
                </form>

                <hr />

                <h2 class="h5">Load License from Server File</h2>
                <p class="text-muted small mb-2">
                    Place <code>MedyxHMS.lic</code> in the application root directory, then click the button below to load it directly.
                </p>
                <form asp-action="LoadFromFile" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-secondary">Load from <code>MedyxHMS.lic</code></button>
                </form>

                <hr />

                <h2 class="h5">Security Policy</h2>
                <p class="text-muted mb-3">
                    Manual renewal is disabled. Only digitally signed <code>.lic</code> files generated by the vendor-side
                    MedyxHMS-Lic application can activate or update licensing entitlements.
                </p>

                <hr />

                <form asp-action="SendReminder" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-secondary">Send Manual Reminder</button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mt-1">
    <div class="col-lg-12">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h2 class="h5 mb-0">Active License Entitlement Matrix</h2>
                    <div class="d-flex gap-2 align-items-center">
                        @if (Model.IsLegacyFullAccessLicense)
                        {
                            <span class="badge bg-info text-dark">Legacy mode: all modules treated as licensed</span>
                        }
                        <a asp-action="ExportEntitlementMatrix" class="btn btn-sm btn-outline-primary">Export CSV</a>
                    </div>
                </div>

                @if (Model.ModuleEntitlements.Count == 0)
                {
                    <p class="text-muted mb-0">No modules are available to display.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Module</th>
                                    <th>Key</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                            @foreach (var item in Model.ModuleEntitlements)
                            {
                                <tr>
                                    <td>@item.DisplayName</td>
                                    <td>@item.Key</td>
                                    <td>
                                        @if (item.IsLicensed)
                                        {
                                            <span class="badge bg-success">Licensed</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark">Locked (Please buy this feature to use it)</span>
                                        }
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card shadow-sm">
            <div class="card-body">
                <h2 class="h5">Reminder History</h2>
                @if (Model.ReminderHistory.Count == 0)
                {
                    <p class="text-muted mb-0">No reminder activity recorded yet.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>When</th>
                                    <th>Type</th>
                                    <th>Status</th>
                                    <th>Sent</th>
                                </tr>
                            </thead>
                            <tbody>
                            @foreach (var reminder in Model.ReminderHistory)
                            {
                                <tr>
                                    <td>@reminder.TriggeredAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                                    <td>@reminder.ReminderType</td>
                                    <td>@reminder.Status</td>
                                    <td>@reminder.SentToCount</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card shadow-sm">
            <div class="card-body">
                <h2 class="h5">Audit History</h2>
                @if (Model.AuditHistory.Count == 0)
                {
                    <p class="text-muted mb-0">No license audit entries recorded yet.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>When</th>
                                    <th>Action</th>
                                    <th>Term</th>
                                    <th>Details</th>
                                </tr>
                            </thead>
                            <tbody>
                            @foreach (var audit in Model.AuditHistory)
                            {
                                <tr>
                                    <td>@audit.PerformedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                                    <td>@audit.ActionType</td>
                                    <td>@(audit.RenewalTermYears?.ToString() ?? "-")</td>
                                    <td>@audit.Details</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>