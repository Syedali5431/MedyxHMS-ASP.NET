@model MedyxHMS.ViewModels.SystemManagementReportListViewModel

@{
    ViewData["Title"] = "System Management - Report List";
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
}

<div class="container-fluid py-3">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-2">
        <div>
            <h4 class="mb-0">System Management - Report List</h4>
            <small class="text-muted">Stage 7 Part A: Report visibility management</small>
        </div>
        <div class="d-flex gap-2 align-items-center">
            <span class="badge bg-secondary">Active @Model.ActiveReports / @Model.TotalReports</span>
            @if (User.IsInRole("SuperAdmin") || User.IsInRole("Admin"))
            {
                <a asp-action="CreateReport" class="btn btn-sm btn-primary">
                    <i class="bi bi-plus-circle"></i> Create Report
                </a>
                <a asp-action="EditReport" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-pencil"></i> Edit Report
                </a>
                <a asp-action="UserManagement" class="btn btn-sm btn-outline-info">
                    <i class="bi bi-people"></i> User Management
                </a>
            }
            <a asp-action="DownloadReport" class="btn btn-sm btn-outline-success">
                <i class="bi bi-download"></i> Download Report
            </a>
            <a asp-action="ThemeManagement" class="btn btn-sm btn-outline-dark">
                <i class="bi bi-palette"></i> Theme Management
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert alert-success py-2">@successMessage</div>
    }
    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="alert alert-danger py-2">@errorMessage</div>
    }

    <form method="get" class="row g-2 mb-3">
        <div class="col-sm-8 col-md-6 col-lg-4">
            <input type="text"
                   name="search"
                   value="@Model.SearchTerm"
                   class="form-control"
                   placeholder="Search report by key, name, or purpose" />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary">Search</button>
            <a href="/SystemManagement/ReportManagement" class="btn btn-outline-secondary">Reset</a>
        </div>
    </form>

    @if (Model.IsSuperAdmin)
    {
        <p class="text-muted small mb-2">SuperAdmin can update report visibility and assign role-based access per report.</p>
    }
    else
    {
        <p class="text-muted small mb-2">Read-only view: you can view report metadata but cannot modify role or status settings.</p>
    }

    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle" id="reportListTable">
            <thead class="table-light">
                <tr>
                    <th style="width: 80px;">Sr#</th>
                    <th>Report Name</th>
                    <th>Purpose</th>
                    <th style="width: 280px;">Roles</th>
                    <th style="width: 170px;">Status</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Rows.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">No reports found.</td>
                    </tr>
                }
                else
                {
                    @foreach (var row in Model.Rows)
                    {
                        <tr>
                            <td>@row.SerialNo</td>
                            <td>
                                <strong>@row.Name</strong>
                                <div class="small text-muted">@row.Key</div>
                            </td>
                            <td>@row.Purpose</td>
                            @if (Model.IsSuperAdmin)
                            {
                                <td>
                                    <form method="post" action="/SystemManagement/SetReportRoles" class="d-flex flex-column gap-2">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="reportKey" value="@row.Key" />
                                        <input type="hidden" name="returnUrl" value="@returnUrl" />
                                        <select name="roles" multiple class="form-select form-select-sm" size="5">
                                            @foreach (var role in Model.AvailableRoles)
                                            {
                                                if (row.AssignedRoles.Contains(role, StringComparer.OrdinalIgnoreCase))
                                                {
                                                    <option value="@role" selected>@role</option>
                                                }
                                                else
                                                {
                                                    <option value="@role">@role</option>
                                                }
                                            }
                                        </select>
                                        <div class="small text-muted">Leave empty to allow all roles</div>
                                        <button type="submit" class="btn btn-sm btn-outline-primary w-100">Save Roles</button>
                                    </form>
                                </td>
                                <td>
                                    <form method="post" action="/SystemManagement/SetReportActive" class="d-flex flex-column gap-2">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="reportKey" value="@row.Key" />
                                        <input type="hidden" name="returnUrl" value="@returnUrl" />
                                        <select name="isActive" class="form-select form-select-sm mb-2">
                                            @if (row.IsActive)
                                            {
                                                <option value="true" selected>Active</option>
                                                <option value="false">Inactive</option>
                                            }
                                            else
                                            {
                                                <option value="true">Active</option>
                                                <option value="false" selected>Inactive</option>
                                            }
                                        </select>
                                        <button type="submit" class="btn btn-sm btn-primary w-100">Save Status</button>
                                    </form>
                                </td>
                            }
                            else
                            {
                                <td>
                                    <span class="small">@row.AssignedRolesText</span>
                                </td>
                                <td>
                                    @if (row.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </td>
                            }
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
