@model MedyxHMS.ViewModels.CmsMenuItemEditViewModel
@{
    ViewData["Title"] = "Add Menu Item";
}

<div class="container-fluid py-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Menu">Navigation Menu</a></li>
            <li class="breadcrumb-item active">Add Item</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm border-0">
                <div class="card-header"><h4 class="mb-0">Add Menu Item</h4></div>
                <div class="card-body p-4">

                    <form asp-action="CreateMenuItem" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="Label" class="form-label fw-semibold"></label>
                            <input asp-for="Label" class="form-control" placeholder="e.g. About Us" />
                            <span asp-validation-for="Label" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="CmsPageId" class="form-label fw-semibold"></label>
                            <select asp-for="CmsPageId" class="form-select" id="pageSelect">
                                <option value="">-- None (enter URL below) --</option>
                                @foreach (var p in Model.AvailablePages)
                                {
                                    <option value="@p.Id">@p.Title</option>
                                }
                            </select>
                            <small class="text-muted">Selecting a page will auto-fill the URL.</small>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Url" class="form-label fw-semibold">
                                URL
                                <small class="text-muted fw-normal">(override or custom external link)</small>
                            </label>
                            <input asp-for="Url" class="form-control" id="urlInput" placeholder="/site/page/about-us or https://..." />
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label asp-for="SortOrder" class="form-label fw-semibold"></label>
                                <input asp-for="SortOrder" type="number" class="form-control" min="0" />
                            </div>
                            <div class="col-md-4 d-flex align-items-end">
                                <div class="form-check mb-2">
                                    <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                                    <label asp-for="IsActive" class="form-check-label">Active</label>
                                </div>
                            </div>
                            <div class="col-md-4 d-flex align-items-end">
                                <div class="form-check mb-2">
                                    <input asp-for="OpenInNewTab" class="form-check-input" type="checkbox" />
                                    <label asp-for="OpenInNewTab" class="form-check-label">New Tab</label>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">Add Item</button>
                            <a asp-action="Menu" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.getElementById('pageSelect').addEventListener('change', function () {
            var selected = this.options[this.selectedIndex];
            if (selected.value) {
                var slug = selected.text.toLowerCase().replace(/[^a-z0-9\s-]/g, '').trim().replace(/\s+/g, '-');
                document.getElementById('urlInput').value = '/site/page/' + slug;
            }
        });
    </script>
}
