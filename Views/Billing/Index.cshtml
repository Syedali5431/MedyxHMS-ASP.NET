@using MedyxHMS.ViewModels
@{
    ViewData["Title"] = "Billing Overview";
    Layout = "~/Views/PatientPortal/Shared/_Layout.cshtml";
}

@model BillViewModel

<div class="billing-header mb-4">
    <div class="row align-items-center">
        <div class="col-md-8">
            <h1 class="page-title">
                <i class="fas fa-file-invoice-dollar text-primary"></i> Billing Overview
            </h1>
            <p class="text-muted">Review invoices, payments, and outstanding balances.</p>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Create" class="btn btn-primary">
                <i class="fas fa-plus-circle"></i> Create Bill
            </a>
            <a asp-action="Export" asp-route-format="csv" asp-route-filter="@Model.Filter" class="btn btn-outline-primary ms-2">
                <i class="fas fa-file-csv"></i> Export CSV
            </a>
            <a asp-action="Export" asp-route-format="pdf" asp-route-filter="@Model.Filter" class="btn btn-outline-danger ms-2">
                <i class="fas fa-file-pdf"></i> Export PDF
            </a>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form asp-action="Index" method="get" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label">Filter Status</label>
                <select name="filter" class="form-select">
                    <option value="all">All</option>
                    <option value="Unpaid">Unpaid</option>
                    <option value="Partially Paid">Partially Paid</option>
                    <option value="Paid">Paid</option>
                    <option value="Overdue">Overdue</option>
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="fas fa-filter"></i> Apply Filter
                </button>
            </div>
        </form>
    </div>
</div>

@if (Model.Bills != null && Model.Bills.Any())
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Bill #</th>
                    <th>Patient</th>
                    <th>Date</th>
                    <th>Total</th>
                    <th>Paid</th>
                    <th>Status</th>
                    <th>Due</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var bill in Model.Bills)
                {
                    <tr>
                        <td><strong>@bill.BillNumber</strong></td>
                        <td>@bill.PatientName</td>
                        <td>@bill.BillDate.ToString("MMM dd, yyyy")</td>
                        <td>₹@bill.TotalAmount.ToString("N2")</td>
                        <td>₹@bill.PaidAmount.ToString("N2")</td>
                        <td><span class="badge @bill.StatusBadgeClass">@bill.Status</span></td>
                        <td>@bill.DueDate?.ToString("MMM dd, yyyy")</td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@bill.Id" class="btn btn-sm btn-outline-primary me-1">
                                <i class="fas fa-eye"></i>
                            </a>
                            <a asp-action="DownloadReceipt" asp-route-id="@bill.Id" class="btn btn-sm btn-outline-danger me-1" title="Download Receipt PDF">
                                <i class="fas fa-file-pdf"></i>
                            </a>
                            @if (bill.CanPay)
                            {
                                <a asp-action="Pay" asp-route-id="@bill.Id" class="btn btn-sm btn-outline-success">
                                    <i class="fas fa-credit-card"></i>
                                </a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Billing pagination" class="mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)" asp-route-filter="@Model.Filter">Previous</a>
                </li>
                @for (var i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-filter="@Model.Filter">@i</a>
                    </li>
                }
                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)" asp-route-filter="@Model.Filter">Next</a>
                </li>
            </ul>
        </nav>
    }
}
else
{
    <div class="alert alert-info text-center py-4">
        <i class="fas fa-info-circle fa-2x mb-2"></i>
        <p class="mb-0">No bills found. Create a new bill using the button above.</p>
    </div>
}

@section Styles {
    <style>
        .page-title { font-weight: 600; }
        .billing-header { border-bottom: 2px solid #e9ecef; padding-bottom: 1rem; margin-bottom: 1.5rem; }
        .table-hover tbody tr:hover { background-color: #f8f9fa; }
    </style>
}
