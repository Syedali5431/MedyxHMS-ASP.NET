@model MedyxHMS.ViewModels.CmsNoticeEditViewModel
@{
    var isNew = Model.Id == 0;
    ViewData["Title"] = isNew ? "Create Notice" : "Edit Notice";
}

<div class="container-fluid py-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Notices">Notices</a></li>
            <li class="breadcrumb-item active">@ViewData["Title"]</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-header">
                    <h4 class="mb-0">@ViewData["Title"]</h4>
                </div>
                <div class="card-body p-4">

                    <form asp-action="@(isNew ? "CreateNotice" : "EditNotice")"
                          asp-route-id="@(isNew ? null : Model.Id.ToString())"
                          method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="Title" class="form-label fw-semibold"></label>
                            <input asp-for="Title" class="form-control" id="titleInput" placeholder="Notice Title" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Slug" class="form-label fw-semibold">
                                Slug
                                <small class="text-muted fw-normal">(URL identifier)</small>
                            </label>
                            <div class="input-group">
                                <span class="input-group-text text-muted">/site/notice/</span>
                                <input asp-for="Slug" class="form-control" id="slugInput" placeholder="my-notice-slug" />
                            </div>
                            <span asp-validation-for="Slug" class="text-danger small"></span>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="Type" class="form-label fw-semibold"></label>
                                <select asp-for="Type" class="form-select">
                                    <option value="Notice">Notice</option>
                                    <option value="News">News</option>
                                    <option value="Event">Event</option>
                                    <option value="Program">Program</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="PublishedAt" class="form-label fw-semibold"></label>
                                <input asp-for="PublishedAt" type="datetime-local" class="form-control" />
                                <span asp-validation-for="PublishedAt" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Summary" class="form-label fw-semibold">
                                Summary
                                <small class="text-muted fw-normal">(shown in listing cards)</small>
                            </label>
                            <textarea asp-for="Summary" class="form-control" rows="2" maxlength="500"
                                      placeholder="A short description for listing pages..."></textarea>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Content" class="form-label fw-semibold">Content (HTML)</label>
                            <textarea asp-for="Content" class="form-control font-monospace" rows="10"
                                      placeholder="Enter full HTML content..."></textarea>
                        </div>

                        <div class="mb-3">
                            <div class="form-check">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                                <label asp-for="IsActive" class="form-check-label fw-semibold">Active (visible on public site)</label>
                            </div>
                        </div>

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-primary">
                                @(isNew ? "Create Notice" : "Save Changes")
                            </button>
                            <a asp-action="Notices" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        @if (isNew)
        {
            <text>
            document.getElementById('titleInput').addEventListener('input', function () {
                var slug = this.value.toLowerCase()
                    .replace(/[^a-z0-9\s-]/g, '')
                    .trim()
                    .replace(/\s+/g, '-')
                    .replace(/-+/g, '-');
                document.getElementById('slugInput').value = slug;
            });
            </text>
        }
    </script>
}
