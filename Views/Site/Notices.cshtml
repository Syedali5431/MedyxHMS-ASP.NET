@model MedyxHMS.ViewModels.SiteNoticeListViewModel
@{
    ViewData["Title"] = Model.PageTitle;
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
    ViewBag.MenuItems = Model.MenuItems;
}

<div class="container my-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Site" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item active">@Model.PageTitle</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0">@Model.PageTitle</h2>
        <div class="d-flex gap-2">
            <a asp-action="Notices" asp-route-type="Notice"
               class="btn btn-sm @(Model.Type == "Notice" ? "btn-primary" : "btn-outline-primary")">Notices</a>
            <a asp-action="Notices" asp-route-type="News"
               class="btn btn-sm @(Model.Type == "News" ? "btn-success" : "btn-outline-success")">News</a>
            <a asp-action="Notices" asp-route-type="Event"
               class="btn btn-sm @(Model.Type == "Event" ? "btn-warning" : "btn-outline-warning")">Events</a>
            <a asp-action="Notices" asp-route-type="Program"
               class="btn btn-sm @(Model.Type == "Program" ? "btn-secondary" : "btn-outline-secondary")">Programs</a>
        </div>
    </div>

    <form method="get" class="row g-2 mb-4">
        <input type="hidden" name="type" value="@Model.Type" />
        <div class="col-md-6 col-lg-5">
            <input type="text" name="search" value="@Model.SearchTerm" class="form-control"
                   placeholder="Search title or summary..." />
        </div>
        <div class="col-auto">
            <button type="submit" class="btn btn-primary">Search</button>
            <a asp-action="Notices" asp-route-type="@Model.Type" class="btn btn-outline-secondary">Clear</a>
        </div>
    </form>

    @if (!Model.Notices.Any())
    {
        <div class="alert alert-info">No @Model.PageTitle.ToLower() at this time.</div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var notice in Model.Notices)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <span class="badge mb-2 badge-@notice.Type">@notice.Type</span>
                            <h6 class="card-title fw-bold">
                                <a asp-controller="Site" asp-action="NoticeDetail"
                                   asp-route-slug="@notice.Slug" class="text-decoration-none text-dark stretched-link">
                                    @notice.Title
                                </a>
                            </h6>
                            @if (!string.IsNullOrWhiteSpace(notice.Summary))
                            {
                                <p class="card-text text-muted small">@notice.Summary</p>
                            }
                        </div>
                        <div class="card-footer text-muted small bg-transparent">
                            @((notice.PublishedAt ?? notice.CreatedAt).ToString("dd MMM yyyy"))
                        </div>
                    </div>
                </div>
            }
        </div>

        @if (Model.TotalPages > 1)
        {
            <nav class="mt-4" aria-label="Notice pagination">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                        <a class="page-link" asp-action="Notices" asp-route-type="@Model.Type" asp-route-search="@Model.SearchTerm" asp-route-page="@(Model.Page - 1)" asp-route-pageSize="@Model.PageSize">Previous</a>
                    </li>
                    @for (var i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.Page ? "active" : "")">
                            <a class="page-link" asp-action="Notices" asp-route-type="@Model.Type" asp-route-search="@Model.SearchTerm" asp-route-page="@i" asp-route-pageSize="@Model.PageSize">@i</a>
                        </li>
                    }
                    <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                        <a class="page-link" asp-action="Notices" asp-route-type="@Model.Type" asp-route-search="@Model.SearchTerm" asp-route-page="@(Model.Page + 1)" asp-route-pageSize="@Model.PageSize">Next</a>
                    </li>
                </ul>
            </nav>
        }
    }
</div>
